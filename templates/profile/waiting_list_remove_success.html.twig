<section class="pop_box rcv2-modal rcv2-modal--success">
    <a data-remodal-action="close" class="rcv2-modal__close" aria-label="Cerrar">
        <i class="bi bi-x-lg" aria-hidden="true"></i>
    </a>
    <div class="rcv2-success">
        <div class="rcv2-success__icon">
            <i class="bi bi-calendar-x" aria-hidden="true"></i>
        </div>
        <p class="rcv2-success__title">¡Saliste de la lista de espera!</p>
        <p class="rcv2-success__sub">Tu solicitud fue cancelada correctamente.</p>
        <div class="rcv2-success__actions">
            <a href="{{ path('profile_waiting_list') }}" class="rcv2-btn-modal rcv2-btn-modal--outline">Ver lista de espera</a>
            <a href="{{ path('reservation_calendar', {'slug': config_first_branch_slug()}) }}" class="rcv2-btn-modal rcv2-btn-modal--primary">Reservar clase</a>
        </div>
    </div>
</section>
