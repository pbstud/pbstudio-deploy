<section class="pop_box rcv2-modal">

    <a data-remodal-action="close" class="rcv2-modal__close" aria-label="Cerrar">
        <i class="bi bi-x-lg" aria-hidden="true"></i>
    </a>

    <div class="rcv2-modal__body">

        {# ── Columna izquierda: encabezado + mapa seleccionable ── #}
        <div class="rcv2-modal__col rcv2-modal__col--left">

            <div class="rcv2-modal__state">
                <p class="rcv2-modal__state-title">¡Cambia tu reservación!</p>
                <p class="rcv2-modal__state-sub">Selecciona el nuevo lugar que prefieres.</p>
            </div>

            <div class="rcv2-modal__seats">
                <div class="classroom-layout">
                    <div class="seat-map-frame">
                        {{ include('reservation/_modal_seat_map.html.twig', {
                            mode:         'select',
                            slot_to_seat: slot_to_seat,
                            capacity:     capacity,
                            session:      session,
                            reservations: reservations,
                            user_places:  userReservations
                        }) }}
                    </div>
                </div>
            </div>

        </div>

        {# ── Columna derecha: resumen + CTA ── #}
        <div class="rcv2-modal__col rcv2-modal__col--right">

            <div class="rcv2-modal__summary">
                <div class="rcv2-modal__summary-header">
                    <i class="bi bi-{{ session.individual ? 'person' : 'people' }} rcv2-modal__summary-icon" aria-hidden="true"></i>
                </div>
                <p class="rcv2-modal__summary-name">{{ discipline }}</p>
                <dl class="rcv2-modal__summary-details">
                    <div class="rcv2-modal__summary-row">
                        <dt><i class="bi bi-clock" aria-hidden="true"></i></dt>
                        <dd>{{ session.timeStart|date('h:i a') }}</dd>
                    </div>
                    <div class="rcv2-modal__summary-row">
                        <dt><i class="bi bi-calendar3" aria-hidden="true"></i></dt>
                        <dd>{{ session.dateStart|date('d/m/Y') }}</dd>
                    </div>
                    <div class="rcv2-modal__summary-row">
                        <dt><i class="bi bi-person" aria-hidden="true"></i></dt>
                        <dd>{{ session.instructor.profile.firstname }}</dd>
                    </div>
                    <div class="rcv2-modal__summary-row">
                        <dt><i class="bi bi-geo-alt" aria-hidden="true"></i></dt>
                        <dd>
                            {% set branch_label = session.branchOffice.name %}
                            {% if session.branchOffice.plaza %}
                                {% set branch_label = branch_label ~ ' — ' ~ session.branchOffice.plaza %}
                            {% elseif session.branchOffice.zone %}
                                {% set branch_label = branch_label ~ ' — ' ~ session.branchOffice.zone %}
                            {% endif %}
                            {{ branch_label }}
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="rcv2-modal__actions">
                <a href="#" class="rcv2-btn-modal rcv2-btn-modal--primary btn-confirm btn-submit">
                    Confirmar cambio de reservación
                </a>
            </div>

        </div>
    </div>

    <div class="rcv2-modal__footer">
        <i class="bi bi-info-circle" aria-hidden="true"></i>
        <p>Puedes cancelar tu reservación hasta 12 horas antes sin penalización.</p>
    </div>

    <form id="frmReservation"
          action="{{ path('reservation_change_session', {
              'id': reservation.id,
              'sessionId': session.id
          }) }}"
          method="post" class="m-fjx">
        <input type="hidden" name="_token" value="{{ csrf_token('reservation_change_session') }}" />
        <input type="hidden" name="place_number" />
    </form>

</section>

<script>reservationInit();</script>
