<section class="pop_box">
    <div class="row clearfix">
        <a data-remodal-action="close" class="nav-toggle close"><span class="iconMenu"></span></a>

        {% if waitingList %}
            {% set session = waitingList.session %}

            <div class="center">
                <h3>¿Deseas salir de la lista de espera?</h3>
                <small>Tu lugar en espera será liberado para esta clase.</small>
            </div>

            <div class="clearfix class_pop {{ session.type|PackageSessionType|lower }}">
                <div class="grid-1-6 right reserve-{{ session.discipline|replace({' ': '-'})|lower }}">
                    <div class="class {{ session.discipline|replace({' ': '-'})|lower }}">
                        <span class="icon-{{ 'i' == session.type ? 'individual' : 'group' }}"></span>
                        <h6>{{ session.discipline }}</h6>
                        <p>{{ session.timeStart|date('h:i a') }}</p>
                        <p><strong>{{ session.instructor.profile.firstname }}</strong></p>
                    </div>
                    <p><small><b>Día:</b> {{ session.dateStart|date('d/m/y') }}</small></p>
                    {% set branch_label = session.branchOffice.name %}
                    {% if session.branchOffice.plaza %}
                        {% set branch_label = branch_label ~ ' - ' ~ session.branchOffice.plaza %}
                    {% elseif session.branchOffice.zone %}
                        {% set branch_label = branch_label ~ ' - ' ~ session.branchOffice.zone %}
                    {% endif %}
                    <p><small><b>Sucursal:</b> {{ branch_label }}</small></p>
                </div>
            </div>

            <form id="frmWaitingListRemove" action="{{ path('waiting_list_remove', { 'sessionId': session.id }) }}" method="post" class="m-fjx" style="display:none;">
                <input type="hidden" name="_token" value="{{ csrf_token('waiting_list_remove_' ~ session.id) }}" />
            </form>
            <div class="modal-actions">
                <a id="btn-waiting-list-remove" href="#" data-url="{{ path('waiting_list_remove', { 'sessionId': session.id }) }}" class="btn btn-submit">Cancelar lista de espera</a>
            </div>
        {% else %}
            <div class="center">
                <h3>Este registro ya no está disponible.</h3>
                <small>Actualiza la página para revisar tu lista de espera.</small>
            </div>
            <div class="modal-actions">
                <a href="{{ path('profile_waiting_list') }}" class="btn">Ir a lista de espera</a>
            </div>
        {% endif %}
    </div>
</section>

<script>
    waitingListRemoveInit();
</script>
