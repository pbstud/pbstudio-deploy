{% set reserveClass = discipline|replace({' ': '-'})|lower %}

<section class="pop_box rcv2-modal">

    <a data-remodal-action="close" class="rcv2-modal__close" aria-label="Cerrar">
        <i class="bi bi-x-lg" aria-hidden="true"></i>
    </a>

    <div class="rcv2-modal__body">

        {# ── Columna izquierda: estado + mapa (readonly) + WhatsApp ── #}
        <div class="rcv2-modal__col rcv2-modal__col--left">

            <div class="rcv2-modal__state">
                {% if waiting_list_cancel_status.is_from_waiting_list %}
                    <p class="rcv2-modal__state-title">Cancelación por lista de espera</p>
                    {% if waiting_list_cancel_status.is_within_grace_window %}
                        <div class="rcv2-modal__warning rcv2-modal__warning--info">
                            <i class="bi bi-check-circle" aria-hidden="true"></i>
                            <p>Esta reservación fue asignada desde lista de espera y aún está dentro de la ventana de 1 hora. Si cancelas ahora, se devuelve el cupo sin penalización.</p>
                        </div>
                    {% else %}
                        <div class="rcv2-modal__warning rcv2-modal__warning--alert">
                            <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                            <p>Esta reservación fue asignada desde lista de espera, pero la ventana de 1 hora ya venció. La cancelación seguirá el modelo de negocio normal.</p>
                        </div>
                    {% endif %}
                {% else %}
                    <p class="rcv2-modal__state-title">¿Deseas cancelar esta reservación?</p>
                    <p class="rcv2-modal__state-sub">Recuerda cancelar máximo {{ time_to_cancel }} horas antes de la clase.</p>
                {% endif %}
            </div>

            {# Mapa de asientos (solo vista) #}
            {% if slot_to_seat is not empty or capacity > 0 %}
                <div class="rcv2-modal__seats">
                    <div class="classroom-layout">
                        <div class="seat-map-frame">
                            {{ include('reservation/_modal_seat_map.html.twig', {
                                mode:         'view',
                                slot_to_seat: slot_to_seat,
                                capacity:     capacity,
                                session:      session,
                                reservations: reservations,
                                user_places:  [reservation.placeNumber]
                            }) }}
                        </div>
                    </div>
                </div>
            {% endif %}

            {# WhatsApp help #}
            <a href="{{ config_whatsapp_url() }}"
               target="_blank"
               rel="noopener noreferrer"
               class="rcv2-whatsapp-help">
                <span class="rcv2-whatsapp-help__icon">
                    <i class="bi bi-whatsapp" aria-hidden="true"></i>
                </span>
                <span class="rcv2-whatsapp-help__text">
                    <strong>¿Necesitas ayuda?</strong>
                    Escríbenos por WhatsApp
                </span>
                <i class="bi bi-chevron-right rcv2-whatsapp-help__arrow" aria-hidden="true"></i>
            </a>

        </div>

        {# ── Columna derecha: resumen + CTA ── #}
        <div class="rcv2-modal__col rcv2-modal__col--right">

            <div class="rcv2-modal__summary">
                <div class="rcv2-modal__summary-hero">
                    <i class="bi bi-{{ session.individual ? 'person' : 'people-fill' }}" aria-hidden="true"></i>
                    <p class="rcv2-modal__summary-classname">{{ discipline }}</p>
                    <p class="rcv2-modal__summary-time">{{ session.timeStart|date('h:i a') }}</p>
                    <p class="rcv2-modal__summary-instructor">{{ session.instructor.profile.firstname }}</p>
                </div>
                <hr class="rcv2-modal__summary-divider">
                <dl class="rcv2-modal__summary-details">
                    <div class="rcv2-modal__summary-row">
                        <dt><i class="bi bi-calendar3" aria-hidden="true"></i></dt>
                        <dd>Día: {{ session.dateStart|date('d/m/y') }}</dd>
                    </div>
                    <div class="rcv2-modal__summary-row">
                        <dt><i class="bi bi-geo-alt" aria-hidden="true"></i></dt>
                        <dd>
                            {% set branch_label = 'Sucursal: ' ~ session.branchOffice.name %}
                            {% if session.branchOffice.plaza %}
                                {% set branch_label = branch_label ~ ' — ' ~ session.branchOffice.plaza %}
                            {% elseif session.branchOffice.zone %}
                                {% set branch_label = branch_label ~ ' — ' ~ session.branchOffice.zone %}
                            {% endif %}
                            {{ branch_label }}
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="rcv2-modal__actions">
                <a
                    id="btn-reservation-cancel"
                    href="#"
                    data-url="{{ path('reservation_cancel', {'id': reservation.id}) }}"
                    class="rcv2-btn-modal rcv2-btn-modal--primary btn-submit"
                >Cancelar reservación</a>
            </div>

        </div>
    </div>

    <div class="rcv2-modal__footer">
        <i class="bi bi-stars" aria-hidden="true"></i>
        <p><strong>IMPORTANTE:</strong> Recuerda cancelar máximo {{ time_to_cancel }} horas antes de la clase para evitar penalización.</p>
    </div>

    <form id="frmReservationCancel"
          action="{{ path('reservation_cancel', {'id': reservation.id}) }}"
          method="post" class="m-fjx" style="display:none;">
        <input type="hidden" name="_token" value="{{ csrf_token('reservation_cancel') }}" />
    </form>

</section>

<script>reservationCancelInit();</script>
