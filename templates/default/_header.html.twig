<div x-data="{ navOpen: false, scrolled: (window.scrollY > 20) }"
     x-init="
         scrolled = (window.scrollY > 20);
         // Detectar si el hero cubre el header al restaurar posición (back/forward)
         if (document.readyState === 'complete') {
             scrolled = (window.scrollY > 20);
         } else {
             window.addEventListener('load', function(){ scrolled = (window.scrollY > 20); });
         }
     "
     @scroll.window="scrolled = (window.scrollY > 20)"
     @keydown.escape.window="navOpen = false">

{# HEADER BAR #}
<header
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
    :class="scrolled ? 'bg-white border-b border-linen shadow-sm' : 'bg-transparent border-b border-transparent'"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center h-16 gap-2 sm:gap-4">

        {# Logo #}
        <a href="{{ path('homepage') }}" class="flex-shrink-0 mr-1 sm:mr-3">
            <img src="{{ asset('images/logo-pbstudio.svg') }}" alt="P&amp;B Studio" class="h-8 w-auto" style="filter: brightness(0);">
        </a>

        {# Nav links: aparecen gradualmente según ancho de pantalla #}
        <nav class="flex items-center gap-0" aria-label="Navegación principal">
            {# Clases: desde sm (640px) #}
            <a href="{{ path('class_descriptions_index') }}"
               class="pbs-nav-clases max-sm:hidden sm:flex items-center gap-1.5 px-2 py-2 text-xs font-bold tracking-widest uppercase text-charcoal hover:text-terracota transition-colors">
                <i class="bi bi-activity text-base" aria-hidden="true"></i>
                Clases
            </a>
            {# Paquetes: desde sm (640px) #}
            <a href="{{ path('package_index') }}"
               class="pbs-nav-paquetes max-sm:hidden sm:flex items-center gap-1.5 px-2 py-2 text-xs font-bold tracking-widest uppercase text-charcoal hover:text-terracota transition-colors">
                <i class="bi bi-wallet2 text-base" aria-hidden="true"></i>
                Paquetes
            </a>
            {# Horarios: desde md (768px) #}
            <a href="{{ path('reservation_calendar', {'slug': config_first_branch_slug()}) }}"
               class="max-md:hidden md:flex items-center gap-1.5 px-2 py-2 text-xs font-bold tracking-widest uppercase text-charcoal hover:text-terracota transition-colors">
                <i class="bi bi-calendar-date text-base" aria-hidden="true"></i>
                Horarios / Reservar
            </a>

            {# WhatsApp — estilo botón Reservar clase (charcoal + blanco) #}
            <a href="{{ config_whatsapp_url()|trim }}"
               target="_blank" rel="noopener noreferrer"
               aria-label="Contactar por WhatsApp"
               class="self-center inline-flex items-center gap-1.5 p-2 lg:px-3 lg:py-1.5 bg-charcoal text-white text-xs font-bold tracking-widest uppercase rounded-full hover:bg-charcoal/90 transition-colors">
                <i class="bi bi-whatsapp text-base leading-none" aria-hidden="true"></i>
                <span class="max-lg:hidden lg:inline">WhatsApp</span>
            </a>
        </nav>

        {# Spacer #}
        <div class="flex-1"></div>

        {# Derecha: siempre visible — flex-shrink-0 garantiza que no se comprima #}
        <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">

            {% if app.user %}

                {# Mi cuenta #}
                <a href="{{ path('profile') }}"
                   class="flex items-center gap-1.5 text-sm font-medium text-charcoal hover:text-terracota transition-colors">
                    <i class="bi bi-person text-xl" aria-hidden="true"></i>
                    <span class="max-lg:hidden lg:inline">Mi cuenta</span>
                </a>

                {# Centro de notificaciones #}
                {% if app.request.attributes.get('_route') != 'notifications' %}
                <div class="pb-bell-wrap"
                    data-notification-center
                    data-list-url="{{ path('api_notifications_list') }}"
                    data-unread-url="{{ path('api_notifications_unread_count') }}"
                    {% if not app.debug %}data-stream-url="{{ path('api_notifications_stream') }}"{% endif %}
                    data-mark-read-url-template="{{ path('api_notifications_mark_read', { id: '__ID__' }) }}"
                    data-mark-all-url="{{ path('api_notifications_mark_all_read') }}"
                >
                    <button type="button" class="pb-bell-btn" data-notification-bell
                            aria-label="Notificaciones" aria-expanded="false">
                        <i class="bi bi-bell pb-bell-icon-off" aria-hidden="true"></i>
                        <i class="bi bi-bell-fill pb-bell-icon-on" aria-hidden="true" hidden></i>
                    </button>
                    <span class="pb-badge" data-notification-badge hidden>0</span>
                    <div class="pb-overlay" data-notification-overlay></div>

                    <div class="pb-panel" data-notification-panel hidden>
                        <div class="pb-panel__head">
                            <span class="pb-panel__title">Notificaciones</span>
                            <div class="pb-panel__head-actions">
                                <button type="button" class="pb-panel__mark-all" data-mark-all>Marcar todas como leidas</button>
                                <button type="button" class="pb-panel__close" data-notification-close aria-label="Cerrar notificaciones">
                                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                        <div class="pb-tabs" data-notification-tabs>
                            <button type="button" class="pb-tab active" data-filter="all">Todas</button>
                            <button type="button" class="pb-tab" data-filter="unread">Sin leer <span class="pb-tab__count pb-tab__count--off" data-unread-pill-count>0</span></button>
                            <button type="button" class="pb-tab" data-filter="reserva">Reservas <span class="pb-tab__count pb-tab__count--off" data-filter-count="reserva" hidden>0</span></button>
                            <button type="button" class="pb-tab" data-filter="logro">Logros <span class="pb-tab__count pb-tab__count--off" data-filter-count="logro" hidden>0</span></button>
                            <button type="button" class="pb-tab" data-filter="sistema">Sistema <span class="pb-tab__count pb-tab__count--off" data-filter-count="sistema" hidden>0</span></button>
                        </div>
                        <ul class="pb-list" data-notification-list>
                            <li class="pb-empty">
                                <span class="pb-empty__icon"><i class="bi bi-bell-slash"></i></span>
                                <span class="pb-empty__text">Sin notificaciones por ahora</span>
                            </li>
                        </ul>
                        <div class="pb-panel__foot">
                            <a href="{{ path('notifications') }}">Ver todas las notificaciones</a>
                        </div>
                    </div>
                </div>
                {% endif %}

            {% else %}

                {# Login / Registro — data-remodal hasta migrar a Alpine #}
                <a href="#" data-url="{{ path('app_login') }}" data-remodal
                   class="text-sm font-medium text-charcoal hover:text-terracota transition-colors">
                    Iniciar sesión
                </a>
                <a href="#" data-url="{{ path('register') }}" data-remodal
                   class="max-md:hidden md:inline text-sm font-medium text-terracota hover:text-terracota-dark transition-colors">
                    Registrarse
                </a>

            {% endif %}

            {# Hamburger #}
            <button
                type="button"
                @click="navOpen = !navOpen; if(navOpen && window.NotificationCenter) NotificationCenter.closePanel()"
                :aria-expanded="navOpen.toString()"
                :aria-label="navOpen ? 'Cerrar menú' : 'Abrir menú'"
                class="p-2 rounded-md text-charcoal hover:text-terracota hover:bg-sand transition-colors"
            >
                <i x-show="!navOpen" class="bi bi-list text-2xl leading-none" aria-hidden="true"></i>
                <i x-show="navOpen"  class="bi bi-x-lg text-xl leading-none"  aria-hidden="true"></i>
            </button>

        </div>
    </div>
</header>

{# DRAWER — sidebar desde la derecha #}

{# Overlay: empieza bajo el header para no taparlo #}
<div
    x-show="navOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="navOpen = false"
    class="fixed top-16 left-0 right-0 bottom-0 z-30 bg-charcoal/30"
    aria-hidden="true"
></div>

{# Panel lateral — empieza bajo el header #}
<div
    x-show="navOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="translate-x-full"
    class="fixed top-16 right-0 z-40 w-64 bg-white shadow-md rounded-b-lg flex flex-col"
    id="mobile-nav"
>
    {# Links del menú #}
    <nav class="px-2 py-2" aria-label="Menú">
        <ul class="space-y-0.5">

            {# === Sidebar espeja lo que NO cabe en el header nav === #}
            {# Clases: en sidebar solo cuando < sm (640px) #}
            <li class="sm:hidden">
                <a href="{{ path('class_descriptions_index') }}" @click="navOpen = false"
                   class="pbs-nav-clases flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium text-charcoal hover:bg-sand hover:text-terracota transition-colors">
                    <i class="bi bi-activity text-base text-muted" aria-hidden="true"></i>
                    Clases
                </a>
            </li>
            {# Paquetes: en sidebar solo cuando < sm (640px) #}
            <li class="sm:hidden">
                <a href="{{ path('package_index') }}" @click="navOpen = false"
                   class="pbs-nav-paquetes flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium text-charcoal hover:bg-sand hover:text-terracota transition-colors">
                    <i class="bi bi-wallet2 text-base text-muted" aria-hidden="true"></i>
                    Paquetes
                </a>
            </li>
            {# Horarios: en sidebar solo cuando < md (768px) #}
            <li class="md:hidden">
                <a href="{{ path('reservation_calendar', {'slug': config_first_branch_slug()}) }}" class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium text-charcoal hover:bg-sand hover:text-terracota transition-colors" @click="navOpen = false">
                    <i class="bi bi-calendar-date text-base text-muted" aria-hidden="true"></i>
                    Horarios / Reservar
                </a>
            </li>
            {# Instructores: siempre en sidebar #}
            <li>
                <a href="{{ path('instructors') }}" @click="navOpen = false"
                   class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium text-charcoal hover:bg-sand hover:text-terracota transition-colors">
                    <i class="bi bi-people text-base text-muted" aria-hidden="true"></i>
                    Instructores
                </a>
            </li>
            {# Separador: siempre visible (Instructores siempre está en sidebar) #}
            <li aria-hidden="true"><hr class="border-linen my-1"></li>

            {# === Siempre visibles: páginas secundarias === #}
            <li>
                <a href="{{ path('page', { 'slug': 'quienes-somos' }) }}" @click="navOpen = false"
                   class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium text-muted hover:bg-sand hover:text-charcoal transition-colors">
                    ¿Quiénes somos?
                </a>
            </li>
            <li>
                <a href="{{ path('page', { 'slug': 'terminos-y-condiciones' }) }}" @click="navOpen = false"
                   class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium text-muted hover:bg-sand hover:text-charcoal transition-colors">
                    Términos y condiciones
                </a>
            </li>
            <li>
                <a href="{{ path('page', { 'slug': 'aviso-de-privacidad' }) }}" @click="navOpen = false"
                   class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium text-muted hover:bg-sand hover:text-charcoal transition-colors">
                    Aviso de privacidad
                </a>
            </li>

            {# === Sección de cuenta === #}
            {% if app.user %}
                <li aria-hidden="true"><hr class="border-linen my-1"></li>
                <li>
                    <a href="{{ path('app_logout') }}" @click="navOpen = false"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-semibold text-red-600 hover:bg-red-50 transition-colors">
                        <i class="bi bi-box-arrow-right text-base" aria-hidden="true"></i>
                        Cerrar sesión
                    </a>
                </li>
            {% else %}
                <li class="md:hidden" aria-hidden="true"><hr class="border-linen my-1"></li>
                <li class="md:hidden">
                    <a href="#" data-url="{{ path('register') }}" data-remodal @click="navOpen = false"
                       class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium text-terracota hover:bg-sand transition-colors">
                        Registrarse
                    </a>
                </li>
            {% endif %}

        </ul>
    </nav>

    {# Footer: redes + logout #}
    <div class="px-4 py-3 border-t border-linen">
        <div class="flex items-center gap-4">
            <a href="https://www.facebook.com/pbstudiomx/" target="_blank" rel="noopener noreferrer"
               aria-label="Facebook" class="text-muted hover:text-terracota transition-colors">
                <i class="bi bi-facebook text-xl" aria-hidden="true"></i>
            </a>
            <a href="https://www.instagram.com/pbstudiomx/" target="_blank" rel="noopener noreferrer"
               aria-label="Instagram" class="text-muted hover:text-terracota transition-colors">
                <i class="bi bi-instagram text-xl" aria-hidden="true"></i>
            </a>
            <a href="{{ config_whatsapp_url()|trim }}" target="_blank" rel="noopener noreferrer"
               aria-label="WhatsApp" class="text-muted hover:text-terracota transition-colors">
                <i class="bi bi-whatsapp text-xl" aria-hidden="true"></i>
            </a>
        </div>
    </div>

</div>

</div>{# /x-data #}
