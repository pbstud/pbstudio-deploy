{# ── GALERÍA ───────────────────────────────────────────────────────────────── #}
<style>
  .pbs-gallery-section { background: #f5f0eb; padding: 80px 0; }
  .pbs-gallery-inner   { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
  .pbs-gallery-feature {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 255px 255px;
    gap: 10px;
    height: 520px;
  }
  /* Contenedor con posición relativa + altura forzada → la imagen nunca distorsiona */
  .pbs-gfeat-main {
    grid-row: 1/3;
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    height: 100%;
  }
  .pbs-gfeat-side {
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    height: 100%;
  }
  /* La imagen llena el contenedor por completo y se recorta (nunca se estira) */
  .pbs-gfeat-main img,
  .pbs-gfeat-side  img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: opacity .4s ease, transform .5s ease;
  }
  .pbs-gfeat-main img,
  .pbs-gfeat-side  img { cursor: zoom-in; }
  .pbs-gfeat-main:hover img,
  .pbs-gfeat-side:hover  img { transform: scale(1.04); }

  /* ── Lightbox ── */
  .pbs-lightbox {
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(20,16,14,.92);
    align-items: center; justify-content: center;
    padding: 20px;
  }
  .pbs-lightbox.open { display: flex; }
  .pbs-lightbox img {
    display: block;
    width: auto;
    height: auto;
    max-width: min(92vw, 1100px);
    max-height: 88vh;
    object-fit: unset;
    border-radius: 12px;
    box-shadow: 0 24px 80px rgba(0,0,0,.6);
    animation: pbs-lb-in .25s ease;
  }
  @keyframes pbs-lb-in {
    from { opacity: 0; transform: scale(.94); }
    to   { opacity: 1; transform: scale(1); }
  }
  .pbs-lightbox-close {
    position: absolute; top: 20px; right: 24px;
    background: none; border: none; color: #fff;
    font-size: 32px; line-height: 1; cursor: pointer;
    opacity: .8; transition: opacity .15s;
  }
  .pbs-lightbox-close:hover { opacity: 1; }
  .pbs-gallery-controls { display: flex; justify-content: center; align-items: center; gap: 16px; margin-top: 24px; }
  .pbs-gallery-controls button {
    width: 40px; height: 40px; border-radius: 50%;
    border: 2px solid #2C2C2C; background: transparent; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; color: #2C2C2C; transition: background .2s, color .2s;
  }
  .pbs-gallery-controls button:hover { background: #2C2C2C; color: #fff; }
  .pbs-gdots-wrap { display: flex; gap: 6px; }
  .pbs-gdots-wrap span {
    width: 7px; height: 7px; border-radius: 50%;
    background: rgba(44,44,44,.2); cursor: pointer; transition: background .2s, transform .2s;
  }
  .pbs-gdots-wrap span.active { background: #C17A6A; transform: scale(1.3); }
  .pbs-gfeat-main img.pbs-fade, .pbs-gfeat-side img.pbs-fade { opacity: 0; }
  @media (max-width: 640px) {
    .pbs-gallery-feature {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      height: auto;
      gap: 8px;
    }
    .pbs-gfeat-main { grid-row: auto; }
    /* Opción C: alto natural, imagen completa sin recorte, máximo 340px */
    .pbs-gfeat-main,
    .pbs-gfeat-side {
      position: static;
      width: 100%;
      padding-bottom: 0;
      max-height: 340px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .pbs-gfeat-main img,
    .pbs-gfeat-side  img {
      position: static;
      width: 100%;
      height: auto;
      max-height: 340px;
      object-fit: contain;
      object-position: center;
    }
  }

  /* ── FAQ ── */
  .pbs-faq-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .pbs-faq-card {
    background: #f5f0eb; border: 1px solid rgba(44,44,44,.06);
    border-radius: 16px; padding: 28px;
    transition: transform .2s, box-shadow .2s;
  }
  .pbs-faq-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(44,44,44,.08); }
  .pbs-faq-card .pbs-faq-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .pbs-faq-card .pbs-faq-icon { font-size: 22px; color: #C17A6A; flex-shrink: 0; }
  .pbs-faq-card .pbs-faq-q   { font-size: 14px; font-weight: 700; color: #2C2C2C; line-height: 1.4; margin: 0; }
  .pbs-faq-card .pbs-faq-a   { font-size: 13px; color: #9e8c84; line-height: 1.65; }
  @media (max-width: 768px) {
    .pbs-faq-cards { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .pbs-faq-cards { grid-template-columns: 1fr; }
  }
</style>

<section class="pbs-gallery-section" id="galeria">
    <div class="pbs-gallery-inner">

        <div class="text-center mb-10">
            <p class="text-xs font-medium tracking-widest uppercase text-terracota mb-3">Nuestro estudio</p>
            <h2 class="text-charcoal" style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1.2">Un espacio diseñado para moverte</h2>
        </div>

        {# Lightbox overlay #}
        <div id="pbs-lightbox" class="pbs-lightbox" role="dialog" aria-modal="true" aria-label="Ver imagen">
            <button class="pbs-lightbox-close" id="pbs-lb-close" aria-label="Cerrar">&times;</button>
            <img id="pbs-lb-img" src="" alt="P&amp;B Studio">
        </div>

        {% if galleryImages is defined and galleryImages|length >= 3 %}
        <div class="pbs-gallery-feature">
            <div class="pbs-gfeat-main">
                <img id="pbs-gimg-main" src="{{ galleryImages[0] }}" alt="P&amp;B Studio — espacio de entrenamiento">
            </div>
            <div class="pbs-gfeat-side">
                <img id="pbs-gimg-side1" src="{{ galleryImages[1] }}" alt="P&amp;B Studio — sala de reformer">
            </div>
            <div class="pbs-gfeat-side">
                <img id="pbs-gimg-side2" src="{{ galleryImages[2] }}" alt="P&amp;B Studio — ambiente del estudio">
            </div>
        </div>

        <div class="pbs-gallery-controls">
            <button id="pbs-gprev" aria-label="Anterior"><i class="bi bi-chevron-left" aria-hidden="true"></i></button>
            <div class="pbs-gdots-wrap" id="pbs-gdots"></div>
            <button id="pbs-gnext" aria-label="Siguiente"><i class="bi bi-chevron-right" aria-hidden="true"></i></button>
        </div>

        <script>
        (function(){
            var allUrls = {{ galleryImages|json_encode|raw }};
            var imgMain  = document.getElementById('pbs-gimg-main');
            var imgSide1 = document.getElementById('pbs-gimg-side1');
            var imgSide2 = document.getElementById('pbs-gimg-side2');
            var dotsWrap = document.getElementById('pbs-gdots');
            var current  = 0;
            var autoTimer = null;
            var slides   = [];

            // Precarga todas las imágenes y mide su área natural (px²)
            function preloadAll(urls, cb) {
                var results = [];
                var done = 0;
                urls.forEach(function(url) {
                    var img = new Image();
                    img.onload = img.onerror = function() {
                        var w = img.naturalWidth  || 1;
                        var h = img.naturalHeight || 1;
                        results.push({ url: url, w: w, h: h, area: w * h });
                        if (++done === urls.length) cb(results);
                    };
                    img.src = url;
                });
            }

            // Distribuye imágenes en slides:
            // - Las primeras N = ceil(total/3) van al slot principal de cada slide
            // - El resto son laterales; si no alcanzan exacto, ciclan con módulo
            function buildSlides(urls) {
                var total     = urls.length;
                var numSlides = Math.max(1, Math.ceil(total / 3));
                var mains     = urls.slice(0, numSlides);
                var sides     = urls.slice(numSlides);
                var sideCount = sides.length;
                var pages     = [];
                for (var i = 0; i < numSlides; i++) {
                    var s1 = sideCount > 0 ? sides[(i * 2)     % sideCount] : mains[i];
                    var s2 = sideCount > 0 ? sides[(i * 2 + 1) % sideCount] : mains[i];
                    pages.push([mains[i], s1, s2]);
                }
                return pages;
            }

            function resetTimer() {
                if (autoTimer) clearInterval(autoTimer);
                autoTimer = setInterval(function() {
                    goTo((current + 1) % slides.length);
                }, 4000);
            }

            function goTo(idx) {
                var imgs = [imgMain, imgSide1, imgSide2];
                imgs.forEach(function(img) { img.classList.add('pbs-fade'); });
                setTimeout(function() {
                    imgMain.src  = slides[idx][0];
                    imgSide1.src = slides[idx][1];
                    imgSide2.src = slides[idx][2];
                    imgs.forEach(function(img) { img.classList.remove('pbs-fade'); });
                    fitImage(imgMain,  slides[idx][0]);
                    fitImage(imgSide1, slides[idx][1]);
                    fitImage(imgSide2, slides[idx][2]);
                    dotsWrap.querySelectorAll('span').forEach(function(d, i) {
                        d.classList.toggle('active', i === idx);
                    });
                    current = idx;
                }, 350);
            }

            // Ratio del contenedor (3:2 ≈ 1.5 tanto en mobile como desktop)
            var CONTAINER_RATIO = 3 / 2;
            var CROP_THRESHOLD  = 0.25; // si se recortaría más del 25%, usar contain

            // Mapa url → {w, h} para consultar rápido en goTo
            var imgDims = {};

            // Aplica object-fit correcto según cuánto se recortaría la imagen
            function fitImage(imgEl, url) {
                var d = imgDims[url];
                if (!d) return;
                var imgRatio  = d.w / d.h;
                var cropFrac  = 1 - Math.min(CONTAINER_RATIO, imgRatio) / Math.max(CONTAINER_RATIO, imgRatio);
                if (cropFrac > CROP_THRESHOLD) {
                    imgEl.classList.add('pbs-contain');
                } else {
                    imgEl.classList.remove('pbs-contain');
                }
            }

            // ── Lightbox ──
            var lightbox   = document.getElementById('pbs-lightbox');
            var lbImg      = document.getElementById('pbs-lb-img');
            var lbClose    = document.getElementById('pbs-lb-close');
            var lbOpen     = false;

            function openLightbox(src) {
                lbImg.src = src;
                lightbox.classList.add('open');
                document.body.style.overflow = 'hidden';
                lbOpen = true;
                if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
            }
            function closeLightbox() {
                lightbox.classList.remove('open');
                document.body.style.overflow = '';
                lbOpen = false;
                resetTimer();
            }
            lbClose.addEventListener('click', closeLightbox);
            lightbox.addEventListener('click', function(e) { if (e.target === lightbox) closeLightbox(); });
            document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && lbOpen) closeLightbox(); });

            // Añadir click a las 3 imágenes de la galería
            [imgMain, imgSide1, imgSide2].forEach(function(img) {
                img.addEventListener('click', function() { openLightbox(img.src); });
            });

            preloadAll(allUrls, function(measured) {
                // Guardar dimensiones por URL para fitImage
                measured.forEach(function(m) { imgDims[m.url] = { w: m.w, h: m.h }; });

                // Ordenar desc por área: las imágenes más grandes van a los slots principales
                measured.sort(function(a, b) { return b.area - a.area; });
                var orderedUrls = measured.map(function(m) { return m.url; });
                slides = buildSlides(orderedUrls);

                // Actualizar imágenes iniciales con el orden correcto (más grande en main)
                imgMain.src  = slides[0][0];
                imgSide1.src = slides[0][1];
                imgSide2.src = slides[0][2];
                fitImage(imgMain,  slides[0][0]);
                fitImage(imgSide1, slides[0][1]);
                fitImage(imgSide2, slides[0][2]);

                // Crear dots
                slides.forEach(function(_, i) {
                    var d = document.createElement('span');
                    if (i === 0) d.classList.add('active');
                    d.addEventListener('click', function() { goTo(i); resetTimer(); });
                    dotsWrap.appendChild(d);
                });

                // Botones prev/next → resetean el timer
                document.getElementById('pbs-gprev').addEventListener('click', function() {
                    goTo((current - 1 + slides.length) % slides.length);
                    resetTimer();
                });
                document.getElementById('pbs-gnext').addEventListener('click', function() {
                    goTo((current + 1) % slides.length);
                    resetTimer();
                });

                resetTimer();
            });
        })();
        </script>
        {% endif %}

    </div>
</section>

