{% extends 'layout.html.twig' %}

{% block page_title %}Inicio | {% endblock %}

{% block content %}
    <h1 class="visually-hidden">Inicio</h1>
    <section>
        <div class="row">
            <div class="banner-home">
                <picture>
                    <source media='(min-width: 701px)'
                            srcset='{{ homeContent.bannerDesktop ? '/media/uploads/site/' ~ homeContent.bannerDesktop : asset('images/home/banner-desktop.jpg') }}'/>
                    <source media='(max-width: 700px)'
                            srcset='{{ homeContent.bannerMobile ? '/media/uploads/site/' ~ homeContent.bannerMobile : asset('images/home/banner-mobile.jpg') }}'/>
                    <img src='{{ homeContent.bannerDesktop ? '/media/uploads/site/' ~ homeContent.bannerDesktop : asset('images/home/banner-desktop.jpg') }}'/>
                </picture>
                <a href="{{ path('reservation_calendar') }}" class="btn white reserve-class-toggle">Reservar clase</a>
            </div>
        </div>
    </section>
    <section>
        <div class="box-row">
            <div class="box">
                <img src="{{ homeContent.box1Image ? '/media/uploads/site/' ~ homeContent.box1Image : asset('images/home/pilates.jpg') }}" alt="{{ homeContent.box1Title }}">
                <h4 class="position-center">{{ homeContent.box1Title }}</h4>
                <div class="overlay">
                    <h4>{{ homeContent.box1Title }}</h4>
                    <p>{{ homeContent.box1Description }}</p>
                    <a href="{{ homeContent.box1Url }}" target="_blank" rel="noopener noreferrer" class="btn white">{{ homeContent.box1LinkLabel }}</a>
                </div>
            </div>
            <div class="box">
                <img src="{{ homeContent.box2Image ? '/media/uploads/site/' ~ homeContent.box2Image : asset('images/home/barra.jpg') }}" alt="{{ homeContent.box2Title }}">
                <h4 class="position-center">{{ homeContent.box2Title }}</h4>
                <div class="overlay">
                    <h4>{{ homeContent.box2Title }}</h4>
                    <p>{{ homeContent.box2Description }}</p>
                    <a href="{{ homeContent.box2Url }}" target="_blank" rel="noopener noreferrer" class="btn white">{{ homeContent.box2LinkLabel }}</a>
                </div>
            </div>
        </div>
    </section>
    <section>
        <div class="box-row location">
            <div class="content">
                <div class="col branch-contact-col">
                    <div class="social">
                        <a href="{{ homeContent.contactFacebook }}" target="blank"><i class="bi bi-facebook"></i></a>
                        <a href="{{ homeContent.contactInstagram }}" target="blank"><i class="bi bi-instagram"></i></a>
                        <a href="{{ homeContent.contactWhatsapp }}" target="blank" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                    </div>
                    <div><a href="mailto:{{ homeContent.contactEmail }}">{{ homeContent.contactEmail }}</a></div>
                </div>
                <div class="col branch-office-col">
                    <div class="branch-office-list">
                        {% if branchOffices is defined and branchOffices is not empty %}
                            {% for branchOffice in branchOffices %}
                                <article class="branch-office-home">
                                    <h6 class="branch-office-title">
                                        {{ branchOffice.name }}
                                        {% if branchOffice.plaza %}
                                            <span>· {{ branchOffice.plaza }}</span>
                                        {% endif %}
                                    </h6>
                                    {% if branchOffice.place %}
                                        <p class="branch-office-city">{{ branchOffice.place }}</p>
                                    {% endif %}
                                    {% if branchOffice.zone %}
                                        <p class="branch-office-meta"><b>Zona:</b> {{ branchOffice.zone }}</p>
                                    {% endif %}
                                    {% if branchOffice.address %}
                                        <p class="branch-office-meta">{{ branchOffice.address }}</p>
                                    {% endif %}
                                    {% if branchOffice.phone %}
                                        <p class="branch-office-meta"><b>Tel:</b> {{ branchOffice.phone }}</p>
                                    {% endif %}
                                </article>
                            {% endfor %}
                        {% else %}
                            <p>No hay sucursales publicas configuradas.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {{ config_notice() }}
{% endblock %}
