                                    display:flex; align-items:center; justify-content:center;">
                            <i id="pbs-panel-benefits-wrap-icon" class="bi bi-check-square" style="color:#C17A6A; font-size:.95rem;"></i>
                        </div>
                        <div style="flex:1; min-width:0;">
                            <p id="pbs-panel-benefits-wrap-label" style="font-size:9px; font-weight:700; letter-spacing:0.5px; text-transform:uppercase; color:#2C2C2C; margin:0 0 7px;">Beneficios</p>
                            <ul id="pbs-panel-benefits" style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:5px;"></ul>
                        </div>
                    </div>

                    {# ¿Para quién es? #}
                    <div id="pbs-panel-paraQuienEs-wrap" style="display:none; gap:12px; margin-bottom:20px; align-items:flex-start;">
                        <div style="width:34px; height:34px; flex-shrink:0; border-radius:50%; border:1.5px solid #C17A6A;
                                    display:flex; align-items:center; justify-content:center;">
                            <i id="pbs-panel-paraQuienEs-wrap-icon" class="bi bi-people" style="color:#C17A6A; font-size:.95rem;"></i>
                        </div>
                        <div>
                            <p id="pbs-panel-paraQuienEs-wrap-label" style="font-size:9px; font-weight:700; letter-spacing:0.5px; text-transform:uppercase; color:#2C2C2C; margin:0 0 4px;">¿Para quién es?</p>
                            <p id="pbs-panel-paraQuienEs" style="font-size:12.5px; color:#5C5048; line-height:1.65; margin:0;"></p>
                        </div>
                    </div>

                    {# Duración #}
                    <div id="pbs-panel-duration-wrap" style="display:none; gap:12px; margin-bottom:20px; align-items:flex-start;">
                        <div style="width:34px; height:34px; flex-shrink:0; border-radius:50%; border:1.5px solid #C17A6A;
                                    display:flex; align-items:center; justify-content:center;">
                            <i id="pbs-panel-duration-wrap-icon" class="bi bi-clock" style="color:#C17A6A; font-size:.95rem;"></i>
                        </div>
                        <div>
                            <p id="pbs-panel-duration-wrap-label" style="font-size:9px; font-weight:700; letter-spacing:0.5px; text-transform:uppercase; color:#2C2C2C; margin:0 0 4px;">Duración</p>
                            <p id="pbs-panel-duration" style="font-size:12.5px; color:#5C5048; margin:0;"></p>
                        </div>
                    </div>

                    {# Secciones adicionales — se inyectan dinámicamente desde data.sections #}
                    <div id="pbs-panel-sections-extra"></div>

                </div>{# /pbs-panel-sections #}

                {# Columna derecha: imagen #}
                <div class="pbs-panel-image-col">
                    <div class="pbs-panel-img-wrap">
                        <img id="pbs-panel-img" src="" alt="">
                        <div id="pbs-panel-img-placeholder" class="pbs-panel-img-ph">
                            <i class="bi bi-image" style="color:#D0C8C0; font-size:2rem;"></i>
                        </div>
                    </div>
                </div>

            </div>{# /pbs-panel-body-grid #}

            {# Info boxes dinámicas — debajo de las dos columnas #}
            <div id="pbs-panel-infoboxes" class="pbs-panel-infoboxes"></div>

        </div>{# /body scrollable #}

        {# ── CTA fijo ── #}
        <div style="padding:14px 18px 22px; background:#FAFAF8; border-top:1px solid #E0DAD4; flex-shrink:0;">
            <a id="pbs-class-panel-cta" href="#"
               style="display:flex; align-items:center; justify-content:center; gap:10px; background:#2C2C2C; color:#F5F0EB;
                      padding:14px; border-radius:7px; font-size:10.5px; font-weight:700;
                      letter-spacing:0.5px; text-transform:uppercase; text-decoration:none;">
                <i class="bi bi-calendar-check"></i>
                Ver horarios y reservar
            </a>
            <p style="text-align:center; margin:12px 0 0;">
                <button id="pbs-panel-cerrar-btn"
                        style="background:none; border:none; cursor:pointer; font-size:12px; color:#9e8c84; text-decoration:underline; padding:0;">
                    Cerrar
                </button>
            </p>
        </div>

    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function () {
        var mapFrame  = document.getElementById('pbs-branch-map');
        var noMapDiv  = document.getElementById('pbs-branch-nomap');
        var nameEl    = document.getElementById('pbs-branch-name');
        var addrEl    = document.getElementById('pbs-branch-addr');
        var zoneEl    = document.getElementById('pbs-branch-zone');
        var gmapsEl   = document.getElementById('pbs-branch-gmaps');
        function showMap(src) {
            if (mapFrame.src !== src) { mapFrame.src = src; }
            mapFrame.style.display = '';
            noMapDiv.style.display = 'none';
        }
        function hideMap() {
            mapFrame.style.display = 'none';
            noMapDiv.style.display = '';
        }

        /* Hero branch links → scroll a mapa + activar tab */
        document.querySelectorAll('.pbs-hero-branch-link').forEach(function (link) {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                var idx = link.getAttribute('data-tab-idx');
                var tab = document.getElementById('pbs-tab-' + idx);
                if (tab) { tab.click(); }
                var mapaEl = document.getElementById('mapa');
                if (mapaEl) {
                    mapaEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        /* Cambio de tabs */
        document.querySelectorAll('.pbs-branch-tab').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.pbs-branch-tab').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                if (nameEl)  nameEl.textContent = btn.dataset.name;
                if (addrEl)  addrEl.textContent = btn.dataset.addr;
                if (zoneEl)  zoneEl.textContent = btn.dataset.zone;
                if (gmapsEl && btn.dataset.gmaps) gmapsEl.href = btn.dataset.gmaps;

                if (btn.dataset.hasMap === '1' && btn.dataset.mapSrc) {
                    showMap(btn.dataset.mapSrc);
                } else {
                    hideMap();
                }
            });
        });
    })();
    </script>

    <script>
    // === Panel lateral: datos de disciplinas e info boxes ===
    var PBS_PANEL_DATA       = {{ panelDataMap|json_encode|raw }};
    var PBS_RESERVATION_BASE = {{ path('reservation_calendar', {'slug': firstBranchSlug})|json_encode|raw }};
    var PBS_INFO_BOXES       = {{ panelInfoBoxes|json_encode|raw }};
    </script>
    <script>
    // === Panel lateral: lógica de apertura/cierre y población de datos ===
    (function () {
        var panel     = document.getElementById('pbs-class-panel');
        var inner     = document.getElementById('pbs-class-panel-inner');
        var closeBtn  = document.getElementById('pbs-class-panel-close');
        var cerrarBtn = document.getElementById('pbs-panel-cerrar-btn');
        if (!panel) return;

        function escapeHtml(str) {
            var d = document.createElement('div');
            d.appendChild(document.createTextNode(String(str)));
            return d.innerHTML;
        }

        // Actualiza una sección simple (texto + ícono + label opcionales)
        function setSection(wrapId, textId, value, iconCls, labelText) {
            var wrap = document.getElementById(wrapId);
            var el   = document.getElementById(textId);
            if (!wrap || !el) return;
            if (value) {
                el.textContent = value;
                wrap.style.display = 'flex';
                if (iconCls) {
                    var ico = document.getElementById(wrapId + '-icon');
                    if (ico) { ico.className = 'bi ' + iconCls; }
                }
                if (labelText) {
                    var lbl = document.getElementById(wrapId + '-label');
                    if (lbl) { lbl.textContent = labelText; }
                }
            } else {
                wrap.style.display = 'none';
            }
        }

        // HTML reutilizable para una sección con ícono circular
        function sectionRowHtml(iconCls, labelText, bodyHtml) {
            return '<div style="display:flex;gap:12px;margin-bottom:20px;align-items:flex-start;">'
                + '<div style="width:34px;height:34px;flex-shrink:0;border-radius:50%;border:1.5px solid #C17A6A;'
                +      'display:flex;align-items:center;justify-content:center;">'
                + '<i class="bi ' + escapeHtml(iconCls || 'bi-list') + '" style="color:#C17A6A;font-size:.95rem;"></i></div>'
                + '<div style="flex:1;min-width:0;">'
                + (labelText ? '<p style="font-size:9px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;color:#2C2C2C;margin:0 0 4px;">'
                    + escapeHtml(labelText) + '</p>' : '')
                + bodyHtml
                + '</div></div>';
        }

        function openPanel(slug) {
            var data = PBS_PANEL_DATA[slug] || {};

            // Scroll al top del contenido del panel
            var scrollContainer = inner.querySelector('div[style*="overflow-y:auto"]');
            if (scrollContainer) { scrollContainer.scrollTop = 0; }

            // Nombre + descripción
            var nameEl = document.getElementById('pbs-panel-name');
            var descEl = document.getElementById('pbs-panel-desc');
            if (nameEl) nameEl.textContent = data.name || '';
            if (descEl) descEl.textContent = data.description || '';

            // Imagen
            var img         = document.getElementById('pbs-panel-img');
            var placeholder = document.getElementById('pbs-panel-img-placeholder');
            if (img && placeholder) {
                if (data.image) {
                    img.src             = data.image;
                    img.alt             = data.name || '';
                    img.style.display   = 'block';
                    placeholder.style.display = 'none';
                } else {
                    img.src             = '';
                    img.style.display   = 'none';
                    placeholder.style.display = '';
                }
            }

            // Secciones de texto fijas (con ícono y label dinámicos)
            setSection('pbs-panel-queEs-wrap',       'pbs-panel-queEs',       data.queEs       || '', data.queEsIcon,       data.queEsLabel);
            setSection('pbs-panel-paraQuienEs-wrap', 'pbs-panel-paraQuienEs', data.paraQuienEs || '', data.paraQuienEsIcon, data.paraQuienEsLabel);
            setSection('pbs-panel-duration-wrap',    'pbs-panel-duration',    data.duration    || '', data.durationIcon,    data.durationLabel);

            // Beneficios
            var benefitsWrap = document.getElementById('pbs-panel-benefits-wrap');
            var benefitsList = document.getElementById('pbs-panel-benefits');
            var benefits = Array.isArray(data.benefits) ? data.benefits : [];
            if (benefits.length > 0 && benefitsWrap && benefitsList) {
                benefitsList.innerHTML = benefits.map(function (b) {
                    return '<li style="display:flex;align-items:flex-start;gap:8px;font-size:13px;color:#5C5048;">'
                        + '<i class="bi bi-check2" style="color:#C17A6A;flex-shrink:0;margin-top:2px;"></i>'
                        + '<span>' + escapeHtml(b) + '</span></li>';
                }).join('');
                benefitsWrap.style.display = 'flex';
                // Actualizar ícono y label de beneficios
                var bIco = document.getElementById('pbs-panel-benefits-wrap-icon');
                var bLbl = document.getElementById('pbs-panel-benefits-wrap-label');
                if (bIco && data.benefitsIcon)  { bIco.className  = 'bi ' + data.benefitsIcon; }
                if (bLbl && data.benefitsLabel) { bLbl.textContent = data.benefitsLabel; }
            } else if (benefitsWrap) {
                benefitsWrap.style.display = 'none';
            }

            // Secciones adicionales
            var extraEl  = document.getElementById('pbs-panel-sections-extra');
            var sections = Array.isArray(data.sections) ? data.sections : [];
            if (extraEl) {
                if (sections.length > 0) {
                    extraEl.innerHTML = sections.map(function (sec) {
                        var body = sec.text
                            ? '<p style="font-size:12.5px;color:#5C5048;line-height:1.65;margin:0;">' + escapeHtml(sec.text) + '</p>'
                            : '';
                        return sectionRowHtml(sec.icon || 'bi-list', sec.title || '', body);
                    }).join('');
                } else {
                    extraEl.innerHTML = '';
                }
            }

            // Info boxes (dinámicas, desde PBS_INFO_BOXES)
            var infoBoxesEl = document.getElementById('pbs-panel-infoboxes');
            if (infoBoxesEl && Array.isArray(PBS_INFO_BOXES) && PBS_INFO_BOXES.length > 0) {
                infoBoxesEl.innerHTML = PBS_INFO_BOXES.map(function (box) {
                    return '<div style="background:#F5F0EB; border:1px solid #E0DAD4; border-radius:10px; padding:14px 12px; display:flex; gap:10px; align-items:flex-start;">' +
                        '<i class="bi ' + escapeHtml(box.icon || '') + '" style="color:#C17A6A; font-size:1.1rem; margin-top:2px; flex-shrink:0;"></i>' +
                        '<div>' +
                            '<p style="font-size:8.5px; font-weight:700; letter-spacing:0.5px; text-transform:uppercase; color:#2C2C2C; margin:0 0 4px;">' + escapeHtml(box.title || '') + '</p>' +
                            '<p style="font-size:11px; color:#7C6C64; margin:0; line-height:1.5;">' + escapeHtml(box.text || '') + '</p>' +
                        '</div></div>';
                }).join('');
            }

            // CTA URL
            var ctaEl = document.getElementById('pbs-class-panel-cta');
            if (ctaEl && data.id) {
                ctaEl.href = PBS_RESERVATION_BASE + '?discipline=' + encodeURIComponent(data.id);
            }

            // Mostrar panel
            panel.style.display = 'block';
            document.body.style.overflow = 'hidden';
            requestAnimationFrame(function () {
                requestAnimationFrame(function () {
                    inner.style.transform = 'translateX(0)';
                });
            });
        }

        function closePanel() {
            inner.style.transform = 'translateX(100%)';
            setTimeout(function () {
                panel.style.display = 'none';
                document.body.style.overflow = '';
            }, 320);
        }

        closeBtn.addEventListener('click', closePanel);
        if (cerrarBtn) cerrarBtn.addEventListener('click', closePanel);
        panel.addEventListener('click', function (e) { if (e.target === panel) closePanel(); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closePanel(); });

        document.querySelectorAll('.pbs-class-info-btn').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                openPanel(btn.getAttribute('data-class-slug') || '');
            });
        });
    })();
    </script>

{% endblock %}
