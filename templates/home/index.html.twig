<section class="pbs-cta-section" id="horarios">

    {# Izquierda: próximas clases disponibles (dinámico desde backend) #}
    <div class="pbs-sched-col">
        {% set schedDate = upcomingSessions is not empty ? upcomingSessions[0].session.dateTimeStart : date('now', 'America/Mexico_City') %}
        <div class="pbs-sched-header">
            <p class="pbs-sched-eyebrow">Próximas clases</p>
            <span class="pbs-sched-date">{{ schedDate|format_date(pattern='EEE d MMM', locale='es_MX', timezone='America/Mexico_City') }}</span>
        </div>

        {% if upcomingSessions is defined and upcomingSessions is not empty %}
        <div class="pbs-sched-list">
            {% for item in upcomingSessions %}
            {% set session = item.session %}
            {% set remaining = item.remaining %}
            {% set isFull = session.status == constant('App\\Entity\\Session::STATUS_FULL') or remaining == 0 %}
            <a href="{{ path('reservation_confirm', {'id': session.id}) }}"
               data-remodal
               data-url="{{ path('reservation_confirm', {'id': session.id}) }}"
               class="pbs-sched-item"
               aria-label="Reservar {{ session.discipline.name }} — {{ session.dateTimeStart|date('g:i A', 'America/Mexico_City') }}">
                <div class="pbs-sched-time">
                    <div class="pbs-t">{{ session.dateTimeStart|date('g:i', 'America/Mexico_City') }}</div>
                    <div class="pbs-d">{{ session.dateTimeStart|date('A', 'America/Mexico_City') }}</div>
                </div>
                <div class="pbs-sched-sep"></div>
                <div class="pbs-sched-info">
                    <div class="pbs-sc-name">{{ session.discipline.name }}</div>
                    <div class="pbs-sc-meta">
                        {% if session.instructor.profile %}
                        <span><i class="bi bi-person" aria-hidden="true"></i> {{ session.instructor.profile.firstname }}</span>
                        {% endif %}
                        <span><i class="bi bi-geo-alt" aria-hidden="true"></i> {{ session.exerciseRoom.branchOffice.name }}</span>
                    </div>
                    {% if session.information %}
                    <div class="pbs-sc-tags">
                        <span class="pbs-sc-tag">{{ session.information }}</span>
                    </div>
                    {% endif %}
                </div>
                <div class="pbs-sched-spots">
                    {% if isFull %}
                        <div class="pbs-sp-last">Llena</div>
                    {% elseif remaining <= 2 %}
                        <div class="pbs-sp-num">{{ remaining }}</div>
                        <div class="pbs-sp-last">¡Últimos!</div>
                    {% else %}
                        <div class="pbs-sp-num">{{ remaining }}</div>
                        <div class="pbs-sp-lbl">lugares</div>
                    {% endif %}
                </div>
            </a>
            {% endfor %}
        </div>

        {% if upcomingSessions|length == 1 %}
        <div class="pbs-sched-hint">
            <i class="bi bi-calendar3" aria-hidden="true"></i>
            <div>
                <p class="pbs-sched-hint-title">Esta es la única clase con disponibilidad.</p>
                <p class="pbs-sched-hint-sub">Las demás están llenas. Consulta el calendario para unirte a la lista de espera.</p>
            </div>
        </div>
        {% endif %}

        {% else %}
        <div class="flex flex-col items-center justify-center text-center py-8 px-4 gap-3 flex-1"
             x-data x-init="$el.classList.add('animate__animated','animate__fadeIn')" style="animation-duration:.6s;">
            <i class="bi bi-moon-stars text-5xl text-terracota animate__animated animate__bounce"
               style="animation-duration:1.6s;animation-delay:.4s;animation-iteration-count:2;"
               aria-hidden="true"></i>
            <p class="text-charcoal font-semibold text-sm leading-snug mt-1">
                Aún no hay sesiones próximas en agenda.
            </p>
            <p class="text-muted text-xs leading-relaxed">
                Pronto se abrirán nuevas clases.<br>¡Mantente al pendiente del calendario!
            </p>
            {% if branchOffices is defined and branchOffices is not empty %}
            <a href="{{ path('reservation_calendar', {'slug': branchOffices[0].slug}) }}"
               class="mt-2 inline-flex items-center gap-1.5 text-xs font-semibold border px-4 py-2 rounded-full transition-all duration-200"
               style="color:#C17A6A;border-color:rgba(193,122,106,0.4);" 
               onmouseenter="this.style.background='#C17A6A';this.style.color='#fff';this.style.borderColor='#C17A6A';"
               onmouseleave="this.style.background='';this.style.color='#C17A6A';this.style.borderColor='rgba(193,122,106,0.4)';">
                Explorar el calendario <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </a>
            {% else %}
            <a href="{{ path('reservation_calendar', {'slug': 'santa-fe'}) }}"
               class="mt-2 inline-flex items-center gap-1.5 text-xs font-semibold border px-4 py-2 rounded-full transition-all duration-200"
               style="color:#C17A6A;border-color:rgba(193,122,106,0.4);"
               onmouseenter="this.style.background='#C17A6A';this.style.color='#fff';this.style.borderColor='#C17A6A';"
               onmouseleave="this.style.background='';this.style.color='#C17A6A';this.style.borderColor='rgba(193,122,106,0.4)';">
                Explorar el calendario <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </a>
            {% endif %}
        </div>
        {% endif %}

        {% if upcomingSessions is defined and upcomingSessions is not empty %}
        {% if branchOffices is defined and branchOffices is not empty %}
        <a href="{{ path('reservation_calendar', {'slug': branchOffices[0].slug}) }}" class="pbs-sched-more">
            Ver horario completo <i class="bi bi-arrow-right" aria-hidden="true"></i>
        </a>
        {% else %}
        <a href="#" class="pbs-sched-more">
            Ver horario completo <i class="bi bi-arrow-right" aria-hidden="true"></i>
        </a>
        {% endif %}
        {% endif %}
    </div>

    {# Derecha: selector de sucursales con mapa dinámico #}
    <div class="pbs-branch-col" id="mapa">

        {% if branchOffices is defined and branchOffices is not empty %}

        {% if branchOffices|length > 1 %}
        <p class="pbs-branch-eyebrow">Nuestras sucursales</p>

        <div class="pbs-branch-tabs">
            {% for branchOffice in branchOffices %}
            {% set _c = branchCoords[branchOffice.id] ?? null %}
            {% if _c.embedSrc is defined %}
                {% set _tabSrc = _c.embedSrc %}
            {% elseif _c.lat is defined %}
                {% set _tabSrc = 'https://maps.google.com/maps?q=' ~ _c.lat ~ ',' ~ _c.lng ~ '&z=18&output=embed' %}
            {% elseif branchOffice.address %}
                {% set _tabSrc = 'https://maps.google.com/maps?q=' ~ (branchOffice.address|url_encode) ~ '&z=16&output=embed' %}
            {% else %}
                {% set _tabSrc = '' %}
            {% endif %}
            <button class="pbs-branch-tab{% if loop.first %} active{% endif %}"
                    id="pbs-tab-{{ loop.index0 }}"
                    data-name="{{ branchOffice.name|e('html_attr') }}"
                    data-addr="{{ branchOffice.address|default('')|e('html_attr') }}{% if branchOffice.plaza %} · {{ branchOffice.plaza|e('html_attr') }}{% elseif branchOffice.place %} · {{ branchOffice.place|e('html_attr') }}{% endif %}"
                    data-zone="{{ branchOffice.zone|default('')|e('html_attr') }}"
                    data-map-src="{{ _tabSrc|e('html_attr') }}"
                    data-has-map="{{ _tabSrc is not empty ? '1' : '0' }}"
                    data-gmaps="https://www.google.com/maps/search/?api=1&query={{ (branchOffice.plaza is not empty ? branchOffice.plaza ~ ' ' ~ branchOffice.name ~ ' ' ~ branchOffice.zone : branchOffice.name ~ ' ' ~ branchOffice.address)|url_encode|e('html_attr') }}"
                    type="button">
                <i class="bi bi-geo-alt" aria-hidden="true"></i> {{ branchOffice.name }}
            </button>
            {% endfor %}
        </div>
        {% endif %}

        {% set first = branchOffices[0] %}
        {% set _firstCoords = branchCoords[first.id] ?? null %}
        {% if _firstCoords.embedSrc is defined %}
            {% set _firstSrc = _firstCoords.embedSrc %}
        {% elseif _firstCoords.lat is defined %}
            {% set _firstSrc = 'https://maps.google.com/maps?q=' ~ _firstCoords.lat ~ ',' ~ _firstCoords.lng ~ '&z=18&output=embed' %}
        {% elseif first.address %}
            {% set _firstSrc = 'https://maps.google.com/maps?q=' ~ (first.address|url_encode) ~ '&z=16&output=embed' %}
        {% else %}
            {% set _firstSrc = '' %}
        {% endif %}
        <div class="pbs-map-card{% if branchOffices|length == 1 %} pbs-map-single{% endif %}">
            <iframe id="pbs-branch-map" class="pbs-map-leaflet"
                    src="{{ _firstSrc }}"
                    allowfullscreen
                    referrerpolicy="no-referrer-when-downgrade"
                    {% if not _firstSrc %}style="display:none"{% endif %}>
            </iframe>
            <div id="pbs-branch-nomap" class="pbs-map-leaflet pbs-map-no-addr"{% if _firstSrc %} style="display:none"{% endif %}>
                <i class="bi bi-geo-alt" aria-hidden="true"></i>
                <p>No hay dirección disponible</p>
            </div>
            <div class="pbs-map-body">
                <div class="pbs-map-name">
                    <i class="bi bi-geo-alt-fill" aria-hidden="true"></i>
                    <span id="pbs-branch-name">{{ first.name }}</span>
                </div>
                <div id="pbs-branch-addr" class="pbs-map-addr">
                    {{ first.address }}{% if first.plaza %} · {{ first.plaza }}{% elseif first.place %} · {{ first.place }}{% endif %}
                </div>
                <div class="pbs-map-badges">
                    <span class="pbs-map-badge">
                        <i class="bi bi-signpost-split" aria-hidden="true"></i>
                        <span id="pbs-branch-zone">{{ first.zone|default('') }}</span>
                    </span>
                    <a id="pbs-branch-gmaps"
                       href="https://www.google.com/maps/search/?api=1&query={{ (first.plaza is not empty ? first.plaza ~ ' ' ~ first.name ~ ' ' ~ first.zone : first.name ~ ' ' ~ first.address)|url_encode }}"
                       target="_blank" rel="noopener noreferrer"
                       class="pbs-map-badge pbs-map-gmaps-link">
                        <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i> Ver en Google Maps
                    </a>
                </div>
            </div>
        </div>

        {% endif %}
    </div>

</section>

