{% extends 'layout.html.twig' %}

{% block page_title %}Inicio | {% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block content_offset %}{% endblock %}

{% block content %}
<h1 class="sr-only">P&amp;B Studio — Pilates Reformer en Santa Fe</h1>

{# ── HERO ─────────────────────────────────────────────────────────────────── #}
<section class="relative overflow-hidden" style="min-height: 100vh;">

    {# Imagen de fondo — cubre toda la sección incluido el header #}
    <picture>
        <source media="(max-width: 768px)"
                srcset="{{ homeContent.bannerMobile ? '/media/uploads/site/' ~ homeContent.bannerMobile : asset('images/home/banner-mobile.jpg') }}">
        <img src="{{ homeContent.bannerDesktop ? '/media/uploads/site/' ~ homeContent.bannerDesktop : asset('images/home/banner-desktop.jpg') }}"
             alt="Estudio P&amp;B — Pilates Reformer"
             class="absolute inset-0 w-full h-full object-cover object-center">
    </picture>

    {# Degradado horizontal: arena izquierda → transparente derecha #}
    <div class="absolute inset-0" style="background: linear-gradient(to right, #F5F0EB 22%, rgba(245,240,235,0.9) 32%, rgba(245,240,235,0.65) 45%, rgba(245,240,235,0.32) 57%, rgba(245,240,235,0.08) 70%, transparent 80%);"></div>
    {# Degradado vertical: arena en la franja del header (top 80px) → transparente #}
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(245,240,235,0.92) 0%, rgba(245,240,235,0.55) 8%, transparent 18%);"></div>

    {# Copy — z-10 sobre el degradado, pt-16 para bajar del header sticky #}
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 lg:px-16 flex items-center" style="min-height: 100vh; padding-top: 5rem; padding-bottom: 4rem;">
        <div class="max-w-lg">
            <h2 class="font-display normal-case text-5xl md:text-6xl lg:text-7xl text-charcoal leading-[1.05] tracking-tight mb-5"
                style="text-shadow: 0 1px 8px rgba(245,240,235,0.9), 0 2px 20px rgba(245,240,235,0.7);">
                Transforma tu cuerpo<br>
                sin entrenamientos<br>
                agresivos.
            </h2>
            <p class="text-charcoal/80 text-base leading-relaxed mb-8 max-w-md" style="text-shadow: 0 0 3px rgba(245,240,235,1), 0 0 8px rgba(245,240,235,1), 0 0 16px rgba(245,240,235,1), 0 0 30px rgba(245,240,235,0.9), 0 0 50px rgba(245,240,235,0.7);">
                Clases personalizadas en Reformer, Barra y entrenamiento funcional de bajo impacto
                para mujeres que buscan verse fuertes, definidas y sentirse increíbles.
            </p>
            <div class="flex flex-wrap gap-3 mb-6">
                <a href="{{ path('reservation_calendar', {'slug': config_first_branch_slug()}) }}"
                   class="inline-flex items-center gap-2 px-6 py-3 bg-charcoal text-white text-sm font-semibold rounded-full hover:bg-charcoal/90 transition-colors">
                    Reservar clase
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                </a>
                <a href="{{ path('package_index') }}"
                   class="inline-flex items-center px-6 py-3 border border-charcoal text-charcoal text-sm font-semibold rounded-full hover:bg-charcoal hover:text-white transition-colors"
                   style="background: rgba(245,240,235,0.65);">
                    Ver paquetes
                </a>
            </div>
            {% if branchOffices is defined and branchOffices is not empty %}
            <div class="flex flex-col gap-1">
                {% for branch in branchOffices %}
                <a href="#mapa"
                   class="pbs-hero-branch-link flex items-center gap-1.5 text-sm"
                   style="text-shadow: 0 0 3px rgba(245,240,235,1), 0 0 8px rgba(245,240,235,1), 0 0 16px rgba(245,240,235,1), 0 0 30px rgba(245,240,235,0.9), 0 0 50px rgba(245,240,235,0.7);"
                   data-tab-idx="{{ loop.index0 }}"
                   aria-label="Ver {{ branch.name }} en el mapa">
                    <i class="bi bi-geo-alt text-terracota flex-shrink-0" aria-hidden="true"></i>
                    <span class="text-charcoal font-medium">{{ branch.name }}</span>
                    {% if branch.plaza %}
                        <span class="text-charcoal/70">· {{ branch.plaza }}</span>
                    {% elseif branch.place %}
                        <span class="text-charcoal/70">· {{ branch.place }}</span>
                    {% endif %}
                </a>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>

</section>

{# ── FEATURES ─────────────────────────────────────────────────────────────── #}
{% if featureItems is defined and featureItems is not empty %}
<section class="bg-sand py-14">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-6">
            {% for item in featureItems %}
            <div class="flex flex-col items-center text-center gap-3">
                <i class="bi {{ item.icon }} text-3xl text-terracota" aria-hidden="true"></i>
                <p class="text-xs font-bold tracking-widest uppercase text-charcoal">{{ item.title }}</p>
                <p class="text-xs text-muted leading-relaxed">{{ item.text }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ── NUESTRAS CLASES ──────────────────────────────────────────────────────── #}
<section class="bg-white py-20" id="nuestras-clases">
    <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-12">
            <p class="text-xs font-medium tracking-widest uppercase text-terracota mb-3">Nuestras clases</p>
            <h2 class="font-display normal-case text-3xl md:text-4xl text-charcoal">Elige tu práctica favorita</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-5 md:gap-6">

            {# Tarjetas dinámicas: salones activos de sucursales públicas #}
            {% for room in rooms %}
                {% set disciplineName = room.discipline ? room.discipline.name : '' %}
                {% set isGroup = room.type == 'g' %}
                <div class="block">
                    {% set calendarUrl = path('reservation_calendar', {'slug': room.branchOffice ? room.branchOffice.slug : firstBranchSlug}) ~ '?discipline=' ~ (disciplineName|url_encode) ~ '&type=' ~ room.type %}
                    {% set fallbackIcons = [
                                'bi-person-arms-up',
                                'bi-person-standing',
                                'bi-person-walking',
                                'bi-heart-pulse',
                                'bi-activity',
                                'bi-wind',
                                'bi-flower1',
                                'bi-flower2',
                                'bi-stars',
                                'bi-sun',
                                'bi-moon-stars',
                                'bi-infinity',
                                'bi-feather',
                                'bi-droplet-half',
                                'bi-peace'
                            ] %}
                            {% set iconIdx = (loop.index0 * 3 + random(0, fallbackIcons|length - 1)) % (fallbackIcons|length) %}
                    <a href="{{ calendarUrl }}" class="group peer block no-underline">
                    <div class="aspect-[3/4] overflow-hidden rounded-xl mb-4 bg-linen flex items-center justify-center relative">
                        {% if room.image %}
                            <img src="/media/uploads/exercise_rooms/{{ room.image }}"
                                 alt="{{ room.name }}"
                                 class="pbs-room-img w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                 style="opacity:0; transition: opacity .3s"
                                 onload="clearTimeout(this._t); this.style.opacity='1';"
                                 onerror="clearTimeout(this._t); this.style.display='none'; this.nextElementSibling.style.display='flex';">
                            <span style="display:none" class="w-full h-full absolute inset-0 flex items-center justify-center">
                                <i class="bi {{ fallbackIcons[iconIdx] }} text-5xl text-terracota opacity-40 group-hover:opacity-70 transition-opacity" aria-hidden="true"></i>
                            </span>
                        {% else %}
                            <i class="bi {{ fallbackIcons[iconIdx] }} text-5xl text-terracota opacity-40 group-hover:opacity-70 transition-opacity" aria-hidden="true"></i>
                        {% endif %}
                        <span class="absolute top-2 left-2 flex items-center gap-1 bg-charcoal/70 text-linen text-[9px] font-bold tracking-widest uppercase px-2 py-0.5 rounded-full backdrop-blur-sm">
                            <i class="bi {{ isGroup ? 'bi-people-fill' : 'bi-person-fill' }} text-[8px]" aria-hidden="true"></i>
                            {{ isGroup ? 'Grupal' : 'Individual' }}
                        </span>
                        {# Hover overlay opción C #}
                        <span class="absolute inset-0 flex flex-col items-center justify-center gap-2 bg-charcoal/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
                            <i class="bi bi-calendar-check text-white" style="font-size:2rem;"></i>
                            <span class="text-white text-xs font-bold tracking-widest uppercase">Ver horarios</span>
                        </span>
                    </div>
                    </a>
                    <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1 peer-hover:text-terracota transition-colors">{{ room.name }}</p>
                    {% if room.description %}
                        <p class="text-xs text-muted leading-relaxed">{{ room.description }}</p>
                    {% else %}
                        <p class="text-xs text-muted leading-relaxed">{{ disciplineName }}</p>
                    {% endif %}
                    {% if branchOffices|length > 1 and room.branchOffice %}
                        <p class="text-[10px] text-terracota font-medium mb-3 leading-relaxed">
                            <i class="bi bi-geo-alt-fill text-[9px]" aria-hidden="true"></i> {{ room.branchOffice.name }}
                        </p>
                    {% else %}
                        <div class="mb-3"></div>
                    {% endif %}
                    <a href="#" data-class-slug="{{ disciplineName|lower|replace({' ': '-'}) }}" class="pbs-class-info-btn text-xs font-semibold text-charcoal hover:text-terracota transition-colors no-underline">Más información →</a>
                </div>
            {% endfor %}
            <script>
            (function(){
                var TIMEOUT = 5000;
                document.querySelectorAll('.pbs-room-img').forEach(function(img){
                    if (img.complete && img.naturalWidth > 0) { img.style.opacity = '1'; return; }
                    img._t = setTimeout(function(){
                        if (!img.complete || img.naturalWidth === 0) {
                            img.style.display = 'none';
                            var fb = img.nextElementSibling;
                            if (fb) fb.style.display = 'flex';
                        }
                    }, TIMEOUT);
                });
            })();
            </script>

            {# Box1: programa especial (dinámico desde backend) #}
            {% if homeContent.box1Title %}
            <a href="{{ homeContent.box1Url }}" class="group block no-underline" target="_blank" rel="noopener noreferrer">
                <div class="aspect-[3/4] overflow-hidden rounded-xl mb-4 bg-linen relative overflow-hidden">
                    <img src="{{ homeContent.box1Image ? '/media/uploads/site/' ~ homeContent.box1Image : asset('images/home/pilates.jpg') }}"
                         alt="{{ homeContent.box1Title }}"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    <span class="absolute top-2 left-2 bg-terracota text-white text-[9px] font-bold tracking-widest uppercase px-2 py-0.5 rounded-full">Online</span>
                </div>
                <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1 group-hover:text-terracota transition-colors">{{ homeContent.box1Title }}</p>
                <p class="text-xs text-muted mb-3 leading-relaxed">{{ homeContent.box1Description }}</p>
                <span class="text-xs font-semibold text-charcoal group-hover:text-terracota transition-colors">{{ homeContent.box1LinkLabel }} →</span>
            </a>
            {% endif %}

            {# Box2: programa especial (dinámico desde backend) #}
            {% if homeContent.box2Title %}
            <a href="{{ homeContent.box2Url }}" class="group block no-underline" target="_blank" rel="noopener noreferrer">
                <div class="aspect-[3/4] overflow-hidden rounded-xl mb-4 bg-linen relative overflow-hidden">
                    <img src="{{ homeContent.box2Image ? '/media/uploads/site/' ~ homeContent.box2Image : asset('images/home/barra.jpg') }}"
                         alt="{{ homeContent.box2Title }}"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    <span class="absolute top-2 left-2 bg-terracota text-white text-[9px] font-bold tracking-widest uppercase px-2 py-0.5 rounded-full">Online</span>
                </div>
                <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1 group-hover:text-terracota transition-colors">{{ homeContent.box2Title }}</p>
                <p class="text-xs text-muted mb-3 leading-relaxed">{{ homeContent.box2Description }}</p>
                <span class="text-xs font-semibold text-charcoal group-hover:text-terracota transition-colors">{{ homeContent.box2LinkLabel }} →</span>
            </a>
            {% endif %}

        </div>
    </div>
</section>

{# ── PAQUETES ─────────────────────────────────────────────────────────────── #}
