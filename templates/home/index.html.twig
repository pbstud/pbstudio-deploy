{% extends 'layout.html.twig' %}

{% block page_title %}Inicio | {% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block content_offset %}{% endblock %}

{% block content %}
<h1 class="sr-only">P&amp;B Studio — Pilates Reformer en Santa Fe</h1>

{# ── HERO ─────────────────────────────────────────────────────────────────── #}
<section class="relative overflow-hidden" style="min-height: 100vh;">

    {# Imagen de fondo — cubre toda la sección incluido el header #}
    <picture>
        <source media="(max-width: 768px)"
                srcset="{{ homeContent.bannerMobile ? '/media/uploads/site/' ~ homeContent.bannerMobile : asset('images/home/banner-mobile.jpg') }}">
           <img src="{{ homeContent.bannerDesktop ? '/media/uploads/site/' ~ homeContent.bannerDesktop : asset('images/home/banner-desktop.jpg') }}"
               alt="Estudio P&amp;B — Pilates Reformer"
               class="absolute inset-0 w-full h-full object-cover object-center">
    </picture>

    {# Franja superior sobre la foto para dar contraste al header transparente sin cambiar sus colores #}
    <div class="absolute inset-x-0 top-0 h-32 md:h-36" style="background: linear-gradient(to bottom, rgba(245,240,235,0.86) 0%, rgba(245,240,235,0.72) 34%, rgba(245,240,235,0.40) 62%, rgba(245,240,235,0.00) 100%);"></div>

    {# Overlay horizontal blanco hacia la izquierda, con cambio principal en torno al 35% #}
    <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(255,255,255,0.72) 0%, rgba(255,255,255,0.56) 18%, rgba(255,255,255,0.30) 35%, rgba(255,255,255,0.10) 48%, rgba(255,255,255,0.00) 64%);"></div>

    {# Overlay oscuro desde abajo hacia arriba para sostener el título y texto en la base #}
    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(19,22,27,0.96) 0%, rgba(19,22,27,0.88) 10%, rgba(19,22,27,0.72) 18%, rgba(19,22,27,0.46) 28%, rgba(19,22,27,0.18) 40%, rgba(19,22,27,0.00) 56%);"></div>

    {# Copy — z-10 sobre la foto + overlay, anclado abajo para quedar dentro de la franja oscura #}
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 lg:px-16 flex items-end" style="min-height: 100vh; padding-top: 5rem; padding-bottom: 4rem;">
        <div class="max-w-lg self-end">
            <h2 class="text-white mb-4"
                style="font-size:clamp(2.2rem,6vw,3.75rem);font-weight:700;line-height:1.1;text-shadow: 0 2px 10px rgba(0,0,0,0.45), 0 6px 24px rgba(0,0,0,0.32);">
                {{ homeContent.heroTitle|default('Transforma tu cuerpo sin entrenamientos agresivos.')|nl2br }}
            </h2>
            <p class="text-white/90 text-base leading-relaxed mb-8 max-w-md"
               style="text-shadow: 0 2px 10px rgba(0,0,0,0.38), 0 6px 24px rgba(0,0,0,0.28);">
                {{ homeContent.heroText|default('Clases personalizadas en Reformer, Barra y entrenamiento funcional de bajo impacto para mujeres que buscan verse fuertes, definidas y sentirse increíbles.') }}
            </p>
            <div class="flex flex-wrap gap-3 mb-6">
                <a href="{{ path('reservation_calendar', {'slug': config_first_branch_slug()}) }}"
                   class="inline-flex items-center gap-2 px-6 py-3 bg-charcoal text-white text-sm font-semibold rounded-full hover:bg-charcoal/90 transition-colors">
                    Reservar clase
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                </a>
                <a href="{{ path('package_index') }}"
                   class="inline-flex items-center px-6 py-3 border border-charcoal text-charcoal text-sm font-semibold rounded-full hover:bg-charcoal hover:text-white transition-colors"
                   style="background: rgba(245,240,235,0.65);">
                    Ver paquetes
                </a>
            </div>
            {% if branchOffices is defined and branchOffices is not empty %}
            <div class="flex flex-col gap-1">
                {% for branch in branchOffices %}
                <a href="#mapa"
                   class="pbs-hero-branch-link flex items-center gap-1.5 text-sm"
                   style="text-shadow: 0 2px 8px rgba(0,0,0,0.35);"
                   data-tab-idx="{{ loop.index0 }}"
                   aria-label="Ver {{ branch.name }} en el mapa">
                    <i class="bi bi-geo-alt text-terracota flex-shrink-0" aria-hidden="true"></i>
                    <span class="text-white font-medium">{{ branch.name }}</span>
                    {% if branch.plaza %}
                        <span class="text-white/70">· {{ branch.plaza }}</span>
                    {% elseif branch.place %}
                        <span class="text-white/70">· {{ branch.place }}</span>
                    {% endif %}
                </a>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>

</section>

{# ── FEATURES ─────────────────────────────────────────────────────────────── #}
{% if featureItems is defined and featureItems is not empty %}
<section class="bg-sand py-14">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-6">
            {% for item in featureItems %}
            <div class="flex flex-col items-center text-center gap-3">
                <i class="bi {{ item.icon }} text-3xl text-terracota" aria-hidden="true"></i>
                <p class="text-xs font-bold tracking-widest uppercase text-charcoal">{{ item.title }}</p>
                <p class="text-xs text-muted leading-relaxed">{{ item.text }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ── NUESTRAS CLASES ──────────────────────────────────────────────────────── #}
<section class="bg-white py-20" id="nuestras-clases">
    <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-12">
            <p class="text-xs font-medium tracking-widest uppercase text-terracota mb-3">Nuestras clases</p>
            <h2 class="text-charcoal" style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1.2">Elige tu práctica favorita en nuestras sucursales</h2>
        </div>

        {# ── CLASES PRESENCIALES ── #}
        {% if disciplines is defined and disciplines is not empty %}
        <div class="mb-14">
            <div class="grid gap-5 md:gap-6 justify-center" style="grid-template-columns: repeat(auto-fit, minmax(180px, 220px));">


                {# Tarjetas dinámicas: disciplinas activas #}

                {% set disciplineIcons = {
                    'Reformer':        'bi-person-arms-up',
                    'Barra':           'bi-person-standing',
                    'Pilates':         'bi-activity',
                    'Yoga':            'bi-flower2',
                    'Funcional':       'bi-lightning',
                    'Cardio':          'bi-heart-pulse',
                    'Stretching':      'bi-peace',
                    'Meditación':      'bi-moon-stars',
                    'Pilates Reformer': 'bi-person-arms-up',
                    'Pilates Mat':     'bi-activity',
                    'Barra':           'bi-person-standing',
                    'Dual':            'bi-people',
                    'Strong Mom':      'bi-heart',
                    '_default':        'bi-stars',
                } %}
                {% set fallbackIcons = [
                    'bi-person-arms-up', 'bi-person-standing', 'bi-person-walking',
                    'bi-heart-pulse', 'bi-activity', 'bi-wind',
                    'bi-flower1', 'bi-flower2', 'bi-stars',
                    'bi-sun', 'bi-moon-stars', 'bi-infinity',
                    'bi-feather', 'bi-droplet-half', 'bi-peace'
                ] %}
                {% for discipline in disciplines %}
                    {% set slug = discipline.name|lower|replace({' ': '-', 'ñ': 'n', 'á': 'a', 'é': 'e', 'í': 'i', 'ó': 'o', 'ú': 'u', 'ü': 'u'}) %}
                    {% set iconIdx = (loop.index0 * 3 + random(0, fallbackIcons|length - 1)) % (fallbackIcons|length) %}
                    {% set icon = disciplineIcons[discipline.name]|default(fallbackIcons[iconIdx]) %}
                    <div class="block">
                        <a href="{{ path('reservation_calendar', {'slug': firstBranchSlug}) ~ '?discipline=' ~ discipline.id }}" class="group peer block no-underline">
                        <div class="aspect-[3/4] overflow-hidden rounded-xl mb-4 bg-linen flex items-center justify-center relative">
                            {% if discipline.image %}
                                <img src="/media/uploads/disciplines/{{ discipline.image }}"
                                     alt="{{ discipline.name }}"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                <span style="display:none" class="w-full h-full absolute inset-0 flex items-center justify-center">
                                    <i class="bi {{ icon }} text-5xl text-terracota opacity-40" aria-hidden="true"></i>
                                </span>
                            {% else %}
                                <i class="bi {{ icon }} text-6xl text-terracota opacity-40 group-hover:opacity-70 transition-opacity" aria-hidden="true"></i>
                            {% endif %}
                            <span class="absolute inset-0 flex flex-col items-center justify-center gap-2 bg-charcoal/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
                                <i class="bi bi-calendar-check text-white" style="font-size:2rem;"></i>
                                <span class="text-white text-xs font-bold tracking-widest uppercase">Ver horarios</span>
                            </span>
                        </div>
                        </a>
                        <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1 group-hover:text-terracota transition-colors">{{ discipline.name }}</p>
                        {% if discipline.description %}
                            <p class="text-xs text-muted leading-relaxed">{{ discipline.description }}</p>
                        {% else %}
                            <p class="text-xs text-muted leading-relaxed">{{ discipline.name }}</p>
                        {% endif %}
                        <a href="#" data-class-slug="{{ slug }}" class="pbs-class-info-btn text-xs font-semibold text-charcoal hover:text-terracota transition-colors no-underline">Más información →</a>
                    </div>
                {% endfor %}

            </div>
        </div>
        {% endif %}

        {# ── CLASES ONLINE ── #}
        {% if (homeContent.box1Title) or (homeContent.box2Title) %}
        <div>
            <div class="text-center mb-8">
                <h2 class="text-charcoal" style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1.2">Entrena desde donde estes con nuestras Clases Online</h2>
            </div>

            <div class="grid gap-5 md:gap-6 justify-center" style="grid-template-columns: repeat(auto-fit, minmax(180px, 220px));">



                {# Box1: programa especial (dinámico desde backend) #}
                {% if homeContent.box1Title %}
                <a href="{{ homeContent.box1Url }}" class="group block no-underline" target="_blank" rel="noopener noreferrer">
                    <div class="aspect-[3/4] overflow-hidden rounded-xl mb-4 bg-linen relative overflow-hidden">
                        <img src="{{ homeContent.box1Image ? '/media/uploads/site/' ~ homeContent.box1Image : asset('images/home/pilates.jpg') }}"
                             alt="{{ homeContent.box1Title }}"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <span class="absolute top-2 left-2 bg-terracota text-white text-[9px] font-bold tracking-widest uppercase px-2 py-0.5 rounded-full">Online</span>
                    </div>
                    <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1 group-hover:text-terracota transition-colors">{{ homeContent.box1Title }}</p>
                    <p class="text-xs text-muted mb-3 leading-relaxed">{{ homeContent.box1Description }}</p>
                    <span class="text-xs font-semibold text-charcoal group-hover:text-terracota transition-colors">{{ homeContent.box1LinkLabel }} →</span>
                </a>
                {% endif %}

                {# Box2: programa especial (dinámico desde backend) #}
                {% if homeContent.box2Title %}
                <a href="{{ homeContent.box2Url }}" class="group block no-underline" target="_blank" rel="noopener noreferrer">
                    <div class="aspect-[3/4] overflow-hidden rounded-xl mb-4 bg-linen relative overflow-hidden">
                        <img src="{{ homeContent.box2Image ? '/media/uploads/site/' ~ homeContent.box2Image : asset('images/home/barra.jpg') }}"
                             alt="{{ homeContent.box2Title }}"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <span class="absolute top-2 left-2 bg-terracota text-white text-[9px] font-bold tracking-widest uppercase px-2 py-0.5 rounded-full">Online</span>
                    </div>
                    <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1 group-hover:text-terracota transition-colors">{{ homeContent.box2Title }}</p>
                    <p class="text-xs text-muted mb-3 leading-relaxed">{{ homeContent.box2Description }}</p>
                    <span class="text-xs font-semibold text-charcoal group-hover:text-terracota transition-colors">{{ homeContent.box2LinkLabel }} →</span>
                </a>
                {% endif %}

            </div>
        </div>
        {% endif %}

    </div>
</section>

{# ── PAQUETES ─────────────────────────────────────────────────────────────── #}

<section class="bg-linen py-20" id="paquetes-destacados">
    <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-12">
            <p class="text-xs font-medium tracking-widest uppercase text-terracota mb-3">Paquetes destacados</p>
            <h2 class="text-charcoal" style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1.2">Elige el plan que va contigo</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">

            {# 8 clases #}
            <div class="bg-white rounded-2xl p-8 flex flex-col">
                <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1">8 Clases</p>
                <p class="text-xs text-muted mb-6">1 mes de vigencia</p>
                <p class="font-display normal-case text-4xl text-charcoal mb-1">$2,560</p>
                <p class="text-xs text-muted mb-6">($320 por clase)</p>
                <ul class="space-y-2 mb-8 flex-1">
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Clases en Reformer, Barra o Dual
                    </li>
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Reservación de clases en línea
                    </li>
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Grupos reducidos
                    </li>
                </ul>
                <a href="{{ path('package_index') }}"
                   class="block text-center py-2.5 px-6 rounded-full bg-charcoal text-white text-sm font-semibold hover:bg-charcoal/90 transition-colors">
                    Comprar ahora
                </a>
            </div>

            {# 16 clases — destacado #}
            <div class="bg-white rounded-2xl p-8 ring-2 ring-terracota relative flex flex-col">
                <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-terracota text-white text-xs font-bold px-4 py-1 rounded-full tracking-wide whitespace-nowrap">
                    Más elegido
                </span>
                <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1">16 Clases</p>
                <p class="text-xs text-muted mb-6">2 meses de vigencia</p>
                <p class="font-display normal-case text-4xl text-terracota mb-1">$4,480</p>
                <p class="text-xs text-muted mb-6">($280 por clase)</p>
                <ul class="space-y-2 mb-8 flex-1">
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Clases en Reformer, Barra o Dual
                    </li>
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Reservación de clases en línea
                    </li>
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Grupos reducidos
                    </li>
                </ul>
                <a href="{{ path('package_index') }}"
                   class="block text-center py-2.5 px-6 rounded-full bg-terracota text-white text-sm font-semibold hover:bg-terracota-dark transition-colors">
                    Comprar ahora
                </a>
            </div>

            {# 24 clases #}
            <div class="bg-white rounded-2xl p-8 flex flex-col">
                <p class="text-xs font-bold tracking-widest uppercase text-charcoal mb-1">24 Clases</p>
                <p class="text-xs text-muted mb-6">3 meses de vigencia</p>
                <p class="font-display normal-case text-4xl text-charcoal mb-1">$6,240</p>
                <p class="text-xs text-muted mb-6">($260 por clase)</p>
                <ul class="space-y-2 mb-8 flex-1">
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Clases en Reformer, Barra o Dual
                    </li>
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Reservación de clases en línea
                    </li>
                    <li class="flex items-start gap-2 text-xs text-charcoal">
                        <i class="bi bi-check2 text-terracota mt-0.5 flex-shrink-0" aria-hidden="true"></i>
                        Grupos reducidos
                    </li>
                </ul>
                <a href="{{ path('package_index') }}"
                   class="block text-center py-2.5 px-6 rounded-full bg-charcoal text-white text-sm font-semibold hover:bg-charcoal/90 transition-colors">
                    Comprar ahora
                </a>
            </div>

        </div>

        <p class="text-center mt-8 text-xs text-muted flex items-center justify-center gap-1.5">
            <i class="bi bi-info-circle text-terracota" aria-hidden="true"></i>
            Pregunta por nuestros paquetes para nuevas clientas.
        </p>

    </div>
</section>

{# ── Estilos FAQ (siempre disponibles) ── #}
<style>
  .pbs-faq-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .pbs-faq-card {
    background: #f5f0eb; border: 1px solid rgba(44,44,44,.06);
    border-radius: 16px; padding: 28px;
    transition: transform .2s, box-shadow .2s;
  }
  .pbs-faq-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(44,44,44,.08); }
  .pbs-faq-card .pbs-faq-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .pbs-faq-card .pbs-faq-icon { font-size: 22px; color: #C17A6A; flex-shrink: 0; }
  .pbs-faq-card .pbs-faq-q   { font-size: 14px; font-weight: 700; color: #2C2C2C; line-height: 1.4; margin: 0; }
  .pbs-faq-card .pbs-faq-a   { font-size: 13px; color: #9e8c84; line-height: 1.65; }
  @media (max-width: 768px) {
    .pbs-faq-cards { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .pbs-faq-cards { grid-template-columns: 1fr; }
  }
</style>

{# ── GALERÍA ───────────────────────────────────────────────────────────────── #}
{% if galleryImages is defined and galleryImages is not empty %}
<style>
  .pbs-gallery-section { background: #f5f0eb; padding: 80px 0; }
  .pbs-gallery-inner   { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
  .pbs-gallery-feature {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 255px 255px;
    gap: 10px;
    height: 520px;
  }
  /* Contenedor con posición relativa + altura forzada → la imagen nunca distorsiona */
  .pbs-gfeat-main {
    grid-row: 1/3;
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    height: 100%;
  }
  .pbs-gfeat-side {
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    height: 100%;
  }
  /* La imagen llena el contenedor por completo y se recorta (nunca se estira) */
  .pbs-gfeat-main img,
  .pbs-gfeat-side  img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: opacity .4s ease, transform .5s ease;
  }
  .pbs-gfeat-main img,
  .pbs-gfeat-side  img { cursor: zoom-in; }
  .pbs-gfeat-main:hover img,
  .pbs-gfeat-side:hover  img { transform: scale(1.04); }

  /* ── Lightbox ── */
  .pbs-lightbox {
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(20,16,14,.92);
    align-items: center; justify-content: center;
    padding: 20px;
  }
  .pbs-lightbox.open { display: flex; }
  .pbs-lightbox img {
    display: block;
    width: auto;
    height: auto;
    max-width: min(92vw, 1100px);
    max-height: 88vh;
    object-fit: unset;
    border-radius: 12px;
    box-shadow: 0 24px 80px rgba(0,0,0,.6);
    animation: pbs-lb-in .25s ease;
  }
  @keyframes pbs-lb-in {
    from { opacity: 0; transform: scale(.94); }
    to   { opacity: 1; transform: scale(1); }
  }
  .pbs-lightbox-close {
    position: absolute; top: 20px; right: 24px;
    background: none; border: none; color: #fff;
    font-size: 32px; line-height: 1; cursor: pointer;
    opacity: .8; transition: opacity .15s;
  }
  .pbs-lightbox-close:hover { opacity: 1; }
  .pbs-gallery-controls { display: flex; justify-content: center; align-items: center; gap: 16px; margin-top: 24px; }
  .pbs-gallery-controls button {
    width: 40px; height: 40px; border-radius: 50%;
    border: 2px solid #2C2C2C; background: transparent; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; color: #2C2C2C; transition: background .2s, color .2s;
  }
  .pbs-gallery-controls button:hover { background: #2C2C2C; color: #fff; }
  .pbs-gdots-wrap { display: flex; gap: 6px; }
  .pbs-gdots-wrap span {
    width: 7px; height: 7px; border-radius: 50%;
    background: rgba(44,44,44,.2); cursor: pointer; transition: background .2s, transform .2s;
  }
  .pbs-gdots-wrap span.active { background: #C17A6A; transform: scale(1.3); }
  .pbs-gfeat-main img.pbs-fade, .pbs-gfeat-side img.pbs-fade { opacity: 0; }
  @media (max-width: 640px) {
    .pbs-gallery-feature {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      height: auto;
      gap: 8px;
    }
    .pbs-gfeat-main { grid-row: auto; }
    /* Opción C: alto natural, imagen completa sin recorte, máximo 340px */
    .pbs-gfeat-main,
    .pbs-gfeat-side {
      position: static;
      width: 100%;
      padding-bottom: 0;
      max-height: 340px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .pbs-gfeat-main img,
    .pbs-gfeat-side  img {
      position: static;
      width: 100%;
      height: auto;
      max-height: 340px;
      object-fit: contain;
      object-position: center;
    }
