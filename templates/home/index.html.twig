        {% if branchOffices is defined and branchOffices is not empty %}

        {% if branchOffices|length > 1 %}
        <p class="pbs-branch-eyebrow">Nuestras sucursales</p>

        <div class="pbs-branch-tabs">
            {% for branchOffice in branchOffices %}
            {% set _c = branchCoords[branchOffice.id] ?? null %}
            {% if _c.embedSrc is defined %}
                {% set _tabSrc = _c.embedSrc %}
            {% elseif _c.lat is defined %}
                {% set _tabSrc = 'https://maps.google.com/maps?q=' ~ _c.lat ~ ',' ~ _c.lng ~ '&z=18&output=embed' %}
            {% elseif branchOffice.address %}
                {% set _tabSrc = 'https://maps.google.com/maps?q=' ~ (branchOffice.address|url_encode) ~ '&z=16&output=embed' %}
            {% else %}
                {% set _tabSrc = '' %}
            {% endif %}
            <button class="pbs-branch-tab{% if loop.first %} active{% endif %}"
                    id="pbs-tab-{{ loop.index0 }}"
                    data-name="{{ branchOffice.name|e('html_attr') }}"
                    data-addr="{{ branchOffice.address|default('')|e('html_attr') }}{% if branchOffice.plaza %} · {{ branchOffice.plaza|e('html_attr') }}{% elseif branchOffice.place %} · {{ branchOffice.place|e('html_attr') }}{% endif %}"
                    data-zone="{{ branchOffice.zone|default('')|e('html_attr') }}"
                    data-map-src="{{ _tabSrc|e('html_attr') }}"
                    data-has-map="{{ _tabSrc is not empty ? '1' : '0' }}"
                    data-gmaps="https://www.google.com/maps/search/?api=1&query={{ (branchOffice.plaza is not empty ? branchOffice.plaza ~ ' ' ~ branchOffice.name ~ ' ' ~ branchOffice.zone : branchOffice.name ~ ' ' ~ branchOffice.address)|url_encode|e('html_attr') }}"
                    type="button">
                <i class="bi bi-geo-alt" aria-hidden="true"></i> {{ branchOffice.name }}
            </button>
            {% endfor %}
        </div>
        {% endif %}

        {% set first = branchOffices[0] %}
        {% set _firstCoords = branchCoords[first.id] ?? null %}
        {% if _firstCoords.embedSrc is defined %}
            {% set _firstSrc = _firstCoords.embedSrc %}
        {% elseif _firstCoords.lat is defined %}
            {% set _firstSrc = 'https://maps.google.com/maps?q=' ~ _firstCoords.lat ~ ',' ~ _firstCoords.lng ~ '&z=18&output=embed' %}
        {% elseif first.address %}
            {% set _firstSrc = 'https://maps.google.com/maps?q=' ~ (first.address|url_encode) ~ '&z=16&output=embed' %}
        {% else %}
            {% set _firstSrc = '' %}
        {% endif %}
        <div class="pbs-map-card{% if branchOffices|length == 1 %} pbs-map-single{% endif %}">
            <div class="pbs-map-layout">
                <iframe id="pbs-branch-map" class="pbs-map-leaflet"
                        src="{{ _firstSrc }}"
                        allowfullscreen
                        referrerpolicy="no-referrer-when-downgrade"
                        {% if not _firstSrc %}style="display:none"{% endif %}>
                </iframe>
                <div id="pbs-branch-nomap" class="pbs-map-leaflet pbs-map-no-addr"{% if _firstSrc %} style="display:none"{% endif %}>
                    <i class="bi bi-geo-alt" aria-hidden="true"></i>
                    <p>No hay dirección disponible</p>
                </div>
            </div>
            <div class="pbs-map-side pbs-map-side-below">
                <div class="pbs-map-name">
                    <i class="bi bi-geo-alt-fill" aria-hidden="true"></i>
                    <span id="pbs-branch-name">{{ first.name }}</span>
                </div>
                <div id="pbs-branch-addr" class="pbs-map-addr">
                    {{ first.address }}{% if first.plaza %} · {{ first.plaza }}{% elseif first.place %} · {{ first.place }}{% endif %}
                </div>
                <div class="pbs-map-badges">
                    <span class="pbs-map-badge">
                        <i class="bi bi-signpost-split" aria-hidden="true"></i>
                        <span id="pbs-branch-zone">{{ first.zone|default('') }}</span>
                    </span>
                    <a id="pbs-branch-gmaps"
                       href="https://www.google.com/maps/search/?api=1&query={{ (first.plaza is not empty ? first.plaza ~ ' ' ~ first.name ~ ' ' ~ first.zone : first.name ~ ' ' ~ first.address)|url_encode }}"
                       target="_blank" rel="noopener noreferrer"
                       class="pbs-map-badge pbs-map-gmaps-link">
                        <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i> Ver en Google Maps
                    </a>
                </div>
            </div>
        </div>

        {% endif %}
    </div>

</section>

