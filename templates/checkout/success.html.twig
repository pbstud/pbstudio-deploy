{% extends 'layout.html.twig' %}

{% block page_title %}{% if giftCard is not null %}Tu regalo está listo | {% else %}Gracias por tu compra | {% endif %}{% endblock %}

{% block content %}
    <section class="page checkout-success-page">
        <div class="row">
            <div class="content">
                <div class="checkout-success-shell">
                    <div class="checkout-success-header center">
                        <p class="checkout-success-kicker">
                            {% if giftCard is not null %}
                                <i class="bi bi-gift" aria-hidden="true"></i> Tarjeta de regalo
                            {% else %}
                                Paquetes
                            {% endif %}
                        </p>
                        {% if giftCard is not null %}
                            <h1>¡Tu regalo está listo!</h1>
                            <p class="checkout-success-lead">
                                Compra registrada. Comparte el código con la persona a quien quieres regalar las clases.
                            </p>
                        {% else %}
                            <h1>Gracias por tu compra</h1>
                            <p class="checkout-success-lead">
                                Tu paquete fue activado exitosamente. Ya puedes reservar tus clases.
                            </p>
                        {% endif %}
                    </div>

                    {% if giftCard is not null %}
                        {% set giftShareText = '¡Te regalo clases en P&B Studio! Tu código es: ' ~ giftCard.code ~ ' — Canjéalo en la sección de paquetes en pbstudio.mx' %}
                        <div class="checkout-success-card checkout-success-gift-card center">
                            <p class="checkout-success-gift-label">Código de regalo</p>
                            <div class="checkout-success-gift-code-box">
                                <span id="gift-code-value">{{ giftCard.code }}</span>
                            </div>
                            <div class="checkout-success-gift-copy-wrap">
                                <button type="button"
                                        class="checkout-success-gift-copy-btn"
                                        id="btn-copy-gift-code"
                                        data-code="{{ giftCard.code }}">
                                    <i class="bi bi-clipboard" aria-hidden="true"></i>
                                    <span class="copy-btn-label">Copiar código</span>
                                </button>
                            </div>
                            <p class="checkout-success-gift-hint">
                                Guarda este código. La persona que lo reciba podrá canjearlo desde la sección de paquetes.
                            </p>
                            <div class="checkout-success-gift-share">
                                <p class="checkout-success-gift-share-label">Compartir código</p>
                                <div class="checkout-success-gift-share-btns">
                                    <a href="https://api.whatsapp.com/send?text={{ giftShareText|url_encode }}"
                                       target="_blank"
                                       rel="noopener noreferrer"
                                       class="share-btn share-btn--whatsapp">
                                        <i class="bi bi-whatsapp"></i>
                                        <span>WhatsApp</span>
                                    </a>
                                    <a href="https://www.facebook.com/sharer/sharer.php?u={{ ('https://pbstudio.mx/paquetes')|url_encode }}"
                                       target="_blank"
                                       rel="noopener noreferrer"
                                       class="share-btn share-btn--facebook">
                                        <i class="bi bi-facebook"></i>
                                        <span>Facebook</span>
                                    </a>
                                    <button type="button"
                                            class="share-btn share-btn--instagram"
                                            id="btn-share-instagram"
                                            data-code="{{ giftCard.code }}"
                                            data-share-text="{{ giftShareText }}">
                                        <i class="bi bi-instagram"></i>
                                        <span>Instagram</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    {% endif %}

                    <div class="checkout-success-card center">
                        <div class="checkout-success-summary" aria-label="Resumen de compra">
                            <div class="checkout-success-summary-item">
                                <span class="label">Paquete</span>
                                <strong>{{ packageName }}</strong>
                            </div>
                            <div class="checkout-success-summary-item">
                                <span class="label">Tipo</span>
                                <strong>{{ packageType }}</strong>
                            </div>
                            <div class="checkout-success-summary-item">
                                <span class="label">Clases</span>
                                <strong>{{ transaction.packageIsUnlimited ? 'Ilimitadas' : transaction.packageTotalClasses }}</strong>
                            </div>
                            <div class="checkout-success-summary-item">
                                <span class="label">Vigencia</span>
                                <strong>{{ transaction.packageDaysExpiry }} dias</strong>
                            </div>
                            <div class="checkout-success-summary-item">
                                <span class="label">Total pagado</span>
                                <strong>${{ transaction.total|number_format(2, '.', ',') }}</strong>
                            </div>
                        </div>

                        <div class="checkout-success-actions">
                            <a href="{{ path('reservation_calendar') }}" class="btn">Reservar clase</a>
                            <a href="{{ path('profile') }}" class="btn secondary">Ir a mi cuenta</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {% if giftCard is not null %}
    <script>
        (function () {
            function swapIcon(btn, fromClass, toClass, delayMs) {
                var icon = btn.querySelector('.bi');
                if (icon) {
                    icon.classList.replace(fromClass, toClass);
                    setTimeout(function () { icon.classList.replace(toClass, fromClass); }, delayMs);
                }
            }

            function legacyCopy(text) {
                var textArea = document.createElement('textarea');
                textArea.value = text;
                textArea.setAttribute('readonly', '');
                textArea.style.position = 'fixed';
                textArea.style.top = '-9999px';
                textArea.style.left = '-9999px';
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();

                var copied = false;
                try {
                    copied = document.execCommand('copy');
                } catch (e) {
                    copied = false;
                }

                document.body.removeChild(textArea);

                return copied;
            }

            function copyToClipboard(text) {
                if (navigator.clipboard && window.isSecureContext) {
                    return navigator.clipboard.writeText(text);
                }

                return legacyCopy(text) ? Promise.resolve() : Promise.reject();
            }

            // Copy code button
            var btnCopy = document.getElementById('btn-copy-gift-code');
            if (btnCopy) {
                btnCopy.addEventListener('click', function () {
                    var code = this.dataset.code;
                    var self = this;
                    var label = self.querySelector('.copy-btn-label');
                    copyToClipboard(code).then(function () {
                        swapIcon(self, 'bi-clipboard', 'bi-clipboard-check', 2000);
                        if (label) {
                            var original = label.textContent;
                            label.textContent = '¡Copiado!';
                            setTimeout(function () { label.textContent = original; }, 2000);
                        }
                    }).catch(function () {
                        if (label) {
                            var original = label.textContent;
                            label.textContent = 'Copia manual';
                            setTimeout(function () { label.textContent = original; }, 2000);
                        }
                    });
                });
            }

            // Instagram share button — copies text to clipboard then opens Instagram Direct
            var btnInsta = document.getElementById('btn-share-instagram');
            if (btnInsta) {
                btnInsta.addEventListener('click', function (event) {
                    event.preventDefault();
                    var text = this.dataset.shareText || this.dataset.code;
                    var instagramUrl = 'https://www.instagram.com/direct/inbox/';
                    copyToClipboard(text).then(function () {
                        window.open(instagramUrl, '_blank', 'noopener,noreferrer');
                    }).catch(function () {
                        window.open(instagramUrl, '_blank', 'noopener,noreferrer');
                    });
                });
            }
        })();
    </script>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    $(function () {
        {# Failsafe: muestra el toast de la notificación de compra aunque el mecanismo
           de sessionStorage no haya capturado el delta (p.ej. primer tab, polling tardío).
           La clave por transacción garantiza que solo dispara una vez por pestaña. #}
        var toastKey = 'pb_checkout_toast_{{ transaction.id }}';
        try {
            if (!sessionStorage.getItem(toastKey)) {
                sessionStorage.setItem(toastKey, '1');

                // Captura ANTES de que el AJAX del init retorne: si lastUnreadCount es -1
                // significa que checkout.js seteó el sessionStorage y el init va a detectar
                // el delta correctamente → no necesitamos hacer nada más.
                var nc = window.NotificationCenter;
                var initHadMinusOne = nc && nc.lastUnreadCount === -1;

                setTimeout(function () {
                    nc = window.NotificationCenter;
                    if (!nc || !nc.listUrl) { return; }

                    // Si init tenía -1 Y su AJAX ya retornó (lastUnreadCount >= 0):
                    // el delta fue procesado correctamente, evitar duplicados.
                    if (initHadMinusOne && nc.lastUnreadCount >= 0) { return; }

                    // Fallback: init no cubrió el delta (sessionStorage no era -1, o AJAX falló).
                    // Mostrar solo notificaciones creadas en los últimos 90 segundos
                    // (las de esta compra) para no duplicar toasts de compras anteriores.
                    $.getJSON(nc.listUrl + '?page=1&limit=10')
                        .done(function (response) {
                            var now = Date.now();
                            var fresh = (response.data || []).filter(function (item) {
                                return item.createdAt && (now - new Date(item.createdAt).getTime()) < 10000;
                            });
                            fresh.forEach(function (item, index) {
                                setTimeout(function () {
                                    if ((item.type === 'achievement_unlocked' || item.type === 'achievement_unlocked_special') && item.payload) {
                                        PBNotify.achievementToast(item, nc.markReadUrlTemplate);
                                    } else {
                                        PBNotify.notif(item.id, item.type || null, item.title || 'Notificación nueva', item.body || '', item.targetUrl || null, nc.markReadUrlTemplate || null);
                                    }
                                }, index * 220);
                            });
                        });
                }, 900);
            }
        } catch (e) {}
    });
    </script>
{% endblock %}