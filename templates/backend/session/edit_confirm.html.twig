{% extends 'backend/session/profile.html.twig' %}

{% set page_title = change_type is defined and change_type == 'capacity_change' ? 'Confirmar Reducción de Capacidad' : 'Confirmar Deshabilitación de Asientos' %}
{% set active_tab = 'tab_edit' %}

{% block subcontent %}
    {# ============================================================
       SECCION A: Aviso de impacto
       ============================================================ #}
    <div class="alert alert-danger" role="alert">
        <strong><i class="fa fa-exclamation-triangle" aria-hidden="true"></i> Atención:</strong>
        {% if change_type is defined and change_type == 'capacity_change' %}
            Se detectaron <strong>{{ affected|length }} reservación(es) activa(s)</strong>
            que quedan fuera de la nueva capacidad
            (<strong>anterior: {{ old_capacity }}</strong> &rarr; <strong>nueva: {{ new_capacity }}</strong>).
        {% else %}
            Se detectaron <strong>{{ affected|length }} reservación(es) activa(s)</strong>
            en los asientos que va a deshabilitar
            ({% for place in disabled_places %}<strong>Asiento {{ place }}</strong>{% if not loop.last %}, {% endif %}{% endfor %}).
        {% endif %}
        Estas reservaciones serán <strong>canceladas automáticamente</strong>
        y el crédito correspondiente se devolverá a cada usuario afectado.
    </div>

    {# ============================================================
       SECCION B: Tabla de usuarios afectados
       ============================================================ #}
    <h4>Usuarios afectados ({{ affected|length }})</h4>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th class="text-center" style="width: 80px;">ID</th>
                    <th>Usuario</th>
                    <th>Email</th>
                    <th class="text-center" style="width: 120px;">Asiento</th>
                    <th class="text-center" style="width: 150px;">Acción</th>
                </tr>
            </thead>
            <tbody>
                {% for reservation in affected %}
                    <tr>
                        <td class="text-center">
                            {% if reservation.user and reservation.user.id %}
                                <a href="{{ path('backend_user_show', { 'id': reservation.user.id }) }}" class="link-edit" title="Ver perfil del usuario">
                                    <u>{{ reservation.user.id }}</u>
                                    <i class="fa fa-eye" aria-hidden="true"></i>
                                </a>
                            {% else %}
                                <span class="text-muted">N/A</span>
                            {% endif %}
                        </td>
                        <td><strong>{{ reservation.user.name }} {{ reservation.user.lastname }}</strong></td>
                        <td><a href="mailto:{{ reservation.user.email }}">{{ reservation.user.email }}</a></td>
                        <td class="text-center">{{ reservation.placeNumber }}</td>
                        <td class="text-center"><span class="label label-danger">Se cancela</span></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="ln_solid"></div>

    {# ============================================================
       SECCION C: Formulario — motivo y acciones
       ============================================================ #}
    <form method="POST" action="{{ path('backend_session_edit_confirm', { 'id': session.id }) }}" id="frm-edit-confirm">
        <input type="hidden" name="_token" value="{{ csrf_token('session_edit_confirm') }}">
        <input type="hidden" name="confirmed" value="1">

        <h4>Motivo del cambio <span class="text-danger">*</span></h4>

        <div class="form-group" id="reason-group">
            <div class="col-xs-12">
                <textarea
                    id="disable-reason"
                    name="reason"
                    class="form-control"
                    rows="4"
                    placeholder="Ej: Reducción de aforo por mantenimiento, reconfiguración del salón..."
                    required
                    minlength="10"
                    maxlength="500"
                ></textarea>
                <div style="display: flex; justify-content: space-between; margin-top: 4px;">
                    <small class="text-muted">Mínimo 10 caracteres, máximo 500. Este registro quedará en auditoría.</small>
                    <small class="text-muted" id="reason-counter">0 / 500</small>
                </div>
                <span class="help-block" id="reason-feedback" style="display: none;">Escribe al menos 10 caracteres en el motivo.</span>
            </div>
        </div>

        <div class="ln_solid"></div>

        <h4>Resumen de lo que sucederá</h4>
        <ul>
            <li><strong>Cancelaciones:</strong> {{ affected|length }} reservación(es) serán canceladas.</li>
            <li><strong>Créditos:</strong> Se devolverá 1 cupón/clase a cada usuario afectado (si aplica).</li>
            <li><strong>Auditoría:</strong> Se registrará quién, cuándo, por qué y qué usuarios fueron afectados.</li>
            <li><strong>Aplicación:</strong> Los cambios se ejecutarán de forma inmediata al confirmar.</li>
        </ul>

        <div class="ln_solid"></div>

        <div class="form-group">
            <div class="col-xs-12">
                <div class="pull-right">
                    <a href="{{ path('backend_session_edit', { 'id': session.id }) }}" class="btn btn-default">
                        <i class="fa fa-arrow-left" aria-hidden="true"></i> Volver a edición
                    </a>
                    &nbsp;
                    <button
                        type="submit"
                        class="btn btn-danger"
                        data-confirm-msg="¿Confirma la cancelación de {{ affected|length }} reservación(es) y devolución de crédito?"
                    >
                        <i class="fa fa-check" aria-hidden="true"></i> Confirmar y Procesar
                    </button>
                </div>
                <div class="clearfix"></div>
            </div>
        </div>
    </form>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(function () {
            var $reason   = $('#disable-reason');
            var $counter  = $('#reason-counter');
            var $feedback = $('#reason-feedback');
            var $group    = $('#reason-group');

            function updateReasonState(showError) {
                var value = ($reason.val() || '').trim();
                var length = value.length;
                var isValid = length >= 10 && length <= 500;

                $counter.text(length + ' / 500');

                if (!isValid) {
                    $group.addClass('has-error');
                    if (showError) {
                        $feedback.show();
                    }
                } else {
                    $group.removeClass('has-error');
                    $feedback.hide();
                }

                return isValid;
            }

            $reason.on('input blur', function (e) {
                updateReasonState(e.type === 'blur');
            });

            $('#frm-edit-confirm').on('submit', function (e) {
                if (!updateReasonState(true)) {
                    e.preventDefault();
                    $reason.focus();
                    return false;
                }

                var msg = $('[data-confirm-msg]').data('confirm-msg');
                if (!window.confirm(msg)) {
                    e.preventDefault();
                    return false;
                }
            });

            updateReasonState(false);
        });
    </script>
{% endblock %}
