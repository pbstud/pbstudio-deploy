{% extends 'backend/layout.html.twig' %}

{% set page_section = 'Páginas' %}
{% set page_title   = 'Contenido · Home' %}
{% set return_to    = path('backend_page') %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hc-section-title {
            font-size: 15px;
            font-weight: 600;
            color: #444;
            border-bottom: 2px solid #e8eaf0;
            padding-bottom: 6px;
            margin-bottom: 18px;
            margin-top: 10px;
        }

        .hc-image-preview {
            max-height: 120px;
            max-width: 100%;
            border-radius: 4px;
            border: 1px solid #ddd;
            margin-bottom: 8px;
            display: block;
        }

        .hc-image-placeholder {
            display: inline-block;
            background: #f5f7fa;
            border: 1px dashed #ccc;
            border-radius: 4px;
            padding: 12px 18px;
            color: #aaa;
            font-size: 12px;
            margin-bottom: 8px;
        }

        .hc-clear-label {
            color: #c0392b;
            font-size: 12px;
            margin-top: 4px;
        }
    </style>
{% endblock %}

{% block content %}
    {% embed 'backend/default/embed/form_common.html.twig' with { 'page_section': page_section, 'page_title': page_title } %}
        {% block body %}
            <form action="{{ path('backend_home_content') }}" method="post" enctype="multipart/form-data">

                {# === BANNER === #}
                <h5 class="hc-section-title">Banner principal</h5>
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>Imagen desktop <small class="text-muted">(recomendado ≥ 1440×600 px)</small></label>
                        {% if homeContent and homeContent.bannerDesktop %}
                            <img id="preview-bannerDesktop"
                                 src="{{ vich_uploader_asset(homeContent, 'bannerDesktopFile') }}"
                                 alt="Banner desktop actual" class="hc-image-preview">
                            <div class="checkbox hc-clear-label">
                                <label>
                                    <input type="checkbox" name="clearBannerDesktop" value="1">
                                    Eliminar imagen actual
                                </label>
                            </div>
                        {% else %}
                            <img id="preview-bannerDesktop"
                                 src="{{ asset('images/home/banner-desktop.jpg') }}"
                                 alt="Banner desktop (fallback estático)" class="hc-image-preview"
                                 style="opacity:.6;">
                            <p class="hc-preview-hint text-muted" style="font-size:11px; margin-top:2px;">Imagen actual (estática por defecto) — sube una para reemplazarla</p>
                        {% endif %}
                        <input type="file" name="bannerDesktopFile" class="form-control" accept="image/jpeg,image/png,image/webp"
                               data-preview="preview-bannerDesktop">
                    </div>
                    <div class="col-md-6 form-group">
                        <label>Imagen mobile <small class="text-muted">(recomendado ≤ 700px ancho)</small></label>
                        {% if homeContent and homeContent.bannerMobile %}
                            <img id="preview-bannerMobile"
                                 src="{{ vich_uploader_asset(homeContent, 'bannerMobileFile') }}"
                                 alt="Banner mobile actual" class="hc-image-preview">
                            <div class="checkbox hc-clear-label">
                                <label>
                                    <input type="checkbox" name="clearBannerMobile" value="1">
                                    Eliminar imagen actual
                                </label>
                            </div>
                        {% else %}
                            <img id="preview-bannerMobile"
                                 src="{{ asset('images/home/banner-mobile.jpg') }}"
                                 alt="Banner mobile (fallback estático)" class="hc-image-preview"
                                 style="opacity:.6;">
                            <p class="hc-preview-hint text-muted" style="font-size:11px; margin-top:2px;">Imagen actual (estática por defecto) — sube una para reemplazarla</p>
                        {% endif %}
                        <input type="file" name="bannerMobileFile" class="form-control" accept="image/jpeg,image/png,image/webp"
                               data-preview="preview-bannerMobile">
                    </div>
                </div>

                <div class="ln_solid"></div>

                {# === CAJAS === #}
                <h5 class="hc-section-title">Cajas de contenido</h5>

                {% for n in [1, 2] %}
                    {% set imgField    = 'box' ~ n ~ 'Image' %}
                    {% set imgMethod   = 'box' ~ n ~ 'ImageFile' %}
                    {% set titleField  = 'box' ~ n ~ 'Title' %}
                    {% set descField   = 'box' ~ n ~ 'Description' %}
                    {% set urlField    = 'box' ~ n ~ 'Url' %}
                    {% set labelField  = 'box' ~ n ~ 'LinkLabel' %}

                    {% set currentImg     = homeContent ? attribute(homeContent, 'get' ~ titleField|capitalize|replace({'Box': 'Box', 'T': 'T'}) ~ '') : null %}
                    {# Helpers #}
                    {% set currentTitle   = homeContent ? attribute(homeContent, 'box' ~ n ~ 'Title') : null %}
                    {% set currentDesc    = homeContent ? attribute(homeContent, 'box' ~ n ~ 'Description') : null %}
                    {% set currentUrl     = homeContent ? attribute(homeContent, 'box' ~ n ~ 'Url') : null %}
                    {% set currentLabel   = homeContent ? attribute(homeContent, 'box' ~ n ~ 'LinkLabel') : null %}
                    {% set currentBoxImg  = homeContent ? attribute(homeContent, 'box' ~ n ~ 'Image') : null %}

                    <div class="row" style="margin-bottom: 20px;">
                        <div class="col-md-12">
                            <h6 style="font-weight:600; color:#555;">Caja {{ n }}</h6>
                        </div>
                        {% set boxFallbacks = {1: 'images/home/pilates.jpg', 2: 'images/home/barra.jpg'} %}
                        <div class="col-md-3 form-group">
                            <label>Imagen</label>
                            {% if currentBoxImg %}
                                <img id="preview-box{{ n }}Image"
                                     src="/media/uploads/site/{{ currentBoxImg }}"
                                     alt="Imagen caja {{ n }} actual" class="hc-image-preview">
                                <div class="checkbox hc-clear-label">
                                    <label>
                                        <input type="checkbox" name="clearBox{{ n }}Image" value="1">
                                        Eliminar imagen actual
                                    </label>
                                </div>
                            {% else %}
                                <img id="preview-box{{ n }}Image"
                                     src="{{ asset(boxFallbacks[n]) }}"
                                     alt="Imagen caja {{ n }} (fallback estático)" class="hc-image-preview"
                                     style="opacity:.6;">
                                <p class="hc-preview-hint text-muted" style="font-size:11px; margin-top:2px;">Imagen actual (estática por defecto) — sube una para reemplazarla</p>
                            {% endif %}
                            <input type="file" name="box{{ n }}ImageFile" class="form-control" accept="image/jpeg,image/png,image/webp"
                                   data-preview="preview-box{{ n }}Image">
                        </div>
                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label>Título</label>
                                    <input type="text" name="box{{ n }}Title" class="form-control"
                                           value="{{ currentTitle ?: defaults['box' ~ n ~ 'Title'] }}"
                                           placeholder="{{ defaults['box' ~ n ~ 'Title'] }}" maxlength="150">
                                </div>
                                <div class="col-md-6 form-group">
                                    <label>Texto del botón</label>
                                    <input type="text" name="box{{ n }}LinkLabel" class="form-control"
                                           value="{{ currentLabel ?: defaults['box' ~ n ~ 'LinkLabel'] }}"
                                           placeholder="{{ defaults['box' ~ n ~ 'LinkLabel'] }}" maxlength="120">
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-8 form-group">
                                    <label>Descripción</label>
                                    <input type="text" name="box{{ n }}Description" class="form-control"
                                           value="{{ currentDesc ?: defaults['box' ~ n ~ 'Description'] }}"
                                           placeholder="{{ defaults['box' ~ n ~ 'Description'] }}" maxlength="255">
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>URL del botón</label>
                                    <input type="text" name="box{{ n }}Url" class="form-control"
                                           value="{{ currentUrl ?: defaults['box' ~ n ~ 'Url'] }}"
                                           placeholder="{{ defaults['box' ~ n ~ 'Url'] }}" maxlength="255">
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}

                <div class="ln_solid"></div>

                {# === CONTACTO === #}
                <h5 class="hc-section-title">Contacto y redes sociales</h5>
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>Email de contacto</label>
                        <input type="text" name="contactEmail" class="form-control"
                               value="{{ homeContent and homeContent.contactEmail ? homeContent.contactEmail : defaults.contactEmail }}"
                               placeholder="{{ defaults.contactEmail }}" maxlength="255">
                    </div>
                    <div class="col-md-6 form-group">
                        <label>URL Facebook</label>
                        <input type="text" name="contactFacebook" class="form-control"
                               value="{{ homeContent and homeContent.contactFacebook ? homeContent.contactFacebook : defaults.contactFacebook }}"
                               placeholder="{{ defaults.contactFacebook }}" maxlength="255">
                    </div>
                    <div class="col-md-6 form-group">
                        <label>URL Instagram</label>
                        <input type="text" name="contactInstagram" class="form-control"
                               value="{{ homeContent and homeContent.contactInstagram ? homeContent.contactInstagram : defaults.contactInstagram }}"
                               placeholder="{{ defaults.contactInstagram }}" maxlength="255">
                    </div>
                    <div class="col-md-6 form-group">
                        <label>URL WhatsApp <small class="text-muted">(ej: https://wa.me/521234567890)</small></label>
                        <input type="text" name="contactWhatsapp" class="form-control"
                               value="{{ homeContent and homeContent.contactWhatsapp ? homeContent.contactWhatsapp : defaults.contactWhatsapp }}"
                               placeholder="{{ defaults.contactWhatsapp }}" maxlength="255">
                    </div>
                </div>

                <div class="ln_solid"></div>

                <div class="form-group">
                    <div class="col-xs-12">
                        <div class="pull-right">
                            <a href="{{ path('backend_page') }}" class="btn btn-default" style="margin-right: 8px;">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
        <div class="clearfix"></div>
                    </div>
                </div>
            </form>
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function () {
        document.querySelectorAll('input[type="file"][data-preview]').forEach(function (input) {
            input.addEventListener('change', function () {
                var file = this.files && this.files[0];
                if (!file) return;

                var img = document.getElementById(this.dataset.preview);
                if (!img) return;

                var reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    img.style.opacity = '1';
                    img.style.outline = '2px solid #f0ad4e';

                    // Actualizar o crear la nota de estado
                    var hint = img.nextElementSibling;
                    if (hint && hint.classList.contains('hc-preview-hint')) {
                        hint.textContent = '\u2139\ufe0f Nueva imagen seleccionada \u2014 pendiente de guardar';
                        hint.style.color = '#b7791f';
                        hint.style.fontWeight = '600';
                    } else {
                        var note = document.createElement('p');
                        note.className = 'hc-preview-hint';
                        note.textContent = '\u2139\ufe0f Nueva imagen seleccionada \u2014 pendiente de guardar';
                        note.style.cssText = 'font-size:11px;margin-top:4px;color:#b7791f;font-weight:600;';
                        img.insertAdjacentElement('afterend', note);
                    }
                };
                reader.readAsDataURL(file);
            });
        });
    })();
    </script>
{% endblock %}
