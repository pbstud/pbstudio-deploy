{% extends 'backend/layout.html.twig' %}

{% set page_section = 'Páginas' %}
{% set page_title   = 'Contenido · Home' %}
{% set return_to    = path('backend_page') %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .hc-section-title {
            font-size: 15px;
            font-weight: 600;
            color: #444;
            border-bottom: 2px solid #e8eaf0;
            padding-bottom: 6px;
            margin-bottom: 18px;
            margin-top: 10px;
        }

        .hc-image-preview {
            max-height: 120px;
            max-width: 100%;
            border-radius: 4px;
            border: 1px solid #ddd;
            margin-bottom: 8px;
            display: block;
        }

        .hc-image-placeholder {
            display: inline-block;
            background: #f5f7fa;
            border: 1px dashed #ccc;
            border-radius: 4px;
            padding: 12px 18px;
            color: #aaa;
            font-size: 12px;
            margin-bottom: 8px;
        }

        .hc-gallery-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 16px;
        }
        .hc-gallery-item {
            position: relative;
            width: 110px;
        }
        .hc-gallery-item img {
            width: 110px;
            height: 80px;
            object-fit: cover;
            border-radius: 4px;
            border: 1px solid #ddd;
            display: block;
        }
        .hc-gallery-item label {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            color: #c0392b;
            margin-top: 3px;
            cursor: pointer;
        }
        .hc-gallery-item input[type=checkbox] {
            margin: 0;
        }
        .hc-gallery-new-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
        }
        .hc-gallery-new-preview img {
            width: 90px;
            height: 65px;
            object-fit: cover;
            border-radius: 4px;
            border: 2px solid #f0ad4e;
        }
    </style>
{% endblock %}

{% block content %}
    {% embed 'backend/default/embed/form_common.html.twig' with { 'page_section': page_section, 'page_title': page_title } %}
        {% block body %}
            <form action="{{ path('backend_home_content') }}" method="post" enctype="multipart/form-data">

                {# === BANNER === #}
                <h5 class="hc-section-title">Banner principal</h5 >
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>Imagen desktop <small class="text-muted">(recomendado 1920×1080 px, mínimo 1600×900)</small></label>
                        {% if homeContent and homeContent.bannerDesktop %}
                            <img id="preview-bannerDesktop"
                                 src="{{ vich_uploader_asset(homeContent, 'bannerDesktopFile') }}"
                                 alt="Banner desktop actual" class="hc-image-preview">
                            <div class="checkbox hc-clear-label">
                                <label>
                                    <input type="checkbox" name="clearBannerDesktop" value="1">
                                    Eliminar imagen actual
                                </label>
                            </div>
                        {% else %}
                            <img id="preview-bannerDesktop"
                                 src="{{ asset('images/home/banner-desktop.jpg') }}"
                                 alt="Banner desktop (fallback estático)" class="hc-image-preview"
                                 style="opacity:.6;">
                            <p class="hc-preview-hint text-muted" style="font-size:11px; margin-top:2px;">Imagen actual (estática por defecto) — sube una para reemplazarla</p>
                        {% endif %}
                        <input type="file" name="bannerDesktopFile" class="form-control" accept="image/jpeg,image/png,image/webp"
                               data-preview="preview-bannerDesktop">
                    </div>
                    <div class="col-md-6 form-group">
                        <label>Imagen mobile <small class="text-muted">(recomendado 800×400 px, formato horizontal)</small></label>
                        {% if homeContent and homeContent.bannerMobile %}
                            <img id="preview-bannerMobile"
                                 src="{{ vich_uploader_asset(homeContent, 'bannerMobileFile') }}"
                                 alt="Banner mobile actual" class="hc-image-preview">
                            <div class="checkbox hc-clear-label">
                                <label>
                                    <input type="checkbox" name="clearBannerMobile" value="1">
                                    Eliminar imagen actual
                                </label>
                            </div>
                        {% else %}
                            <img id="preview-bannerMobile"
                                 src="{{ asset('images/home/banner-mobile.jpg') }}"
                                 alt="Banner mobile (fallback estático)" class="hc-image-preview"
                                 style="opacity:.6;">
                            <p class="hc-preview-hint text-muted" style="font-size:11px; margin-top:2px;">Imagen actual (estática por defecto) — sube una para reemplazarla</p>
                        {% endif %}
                        <input type="file" name="bannerMobileFile" class="form-control" accept="image/jpeg,image/png,image/webp"
                               data-preview="preview-bannerMobile">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Título del hero <small class="text-muted">(aparece sobre la foto/degradado)</small></label>
                        <input type="text" name="heroTitle" class="form-control"
                               value="{{ heroConfig.heroTitle ?: defaults.heroTitle }}"
                               placeholder="{{ defaults.heroTitle }}" maxlength="190">
                    </div>
                    <div class="col-md-12 form-group">
                        <label>Texto del hero <small class="text-muted">(párrafo debajo del título)</small></label>
                        <textarea name="heroText" class="form-control" rows="3" style="resize:vertical;"
                                  placeholder="{{ defaults.heroText }}" maxlength="600">{{ heroConfig.heroText ?: defaults.heroText }}</textarea>
                    </div>
                </div>

                <div class="ln_solid"></div>

                {# === INFO BOXES (debajo del hero) === #}
                <h5 class="hc-section-title">Destacados del estudio <small class="text-muted">(iconos bajo el hero)</small></h5>
                <p class="text-muted" style="font-size:12px;margin-bottom:14px;">
                    Cada fila es una tarjeta de característica en la franja que aparece justo debajo del banner principal.
                    Se muestran en grid de 4 columnas. Las filas en blanco se omiten.
                </p>

                <div id="hc-feat-rows">
                    {% for item in featureItems %}
                    <div class="hc-feat-row row" style="margin-bottom:10px;align-items:flex-start;">
                        <div class="col-md-1 form-group" style="padding-right:6px;">
                            <label style="font-size:11px;">Ícono</label>
                            <input type="hidden" name="featureIcon[]" class="hc-feat-icon-val" value="{{ item.icon }}">
                            <div class="hc-feat-icon-btn" title="Cambiar ícono">
                                <i class="bi {{ item.icon }}" style="font-size:22px;color:#C17A6A;"></i>
                            </div>
                            <div class="hc-feat-icon-picker" style="display:none;"></div>
                        </div>
                        <div class="col-md-4 form-group" style="padding-right:6px;">
                            <label style="font-size:11px;">Título</label>
                            <input type="text" name="featureTitle[]" class="form-control" style="font-size:12px;"
                                   value="{{ item.title }}" placeholder="Atención personalizada" maxlength="80">
                        </div>
                        <div class="col-md-6 form-group" style="padding-right:6px;">
                            <label style="font-size:11px;">Descripción</label>
                            <textarea name="featureText[]" class="form-control hc-feat-text" style="font-size:12px;resize:none;overflow:hidden;" rows="2"
                                      placeholder="Grupos reducidos para corregir y potenciar tu progreso." maxlength="200">{{ item.text }}</textarea>
                        </div>
                        <div class="col-md-1 form-group" style="padding-top:22px;">
                            <button type="button" class="btn btn-danger btn-xs hc-feat-remove" title="Eliminar fila">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    {% endfor %}
                </div>

                <button type="button" id="hc-feat-add" class="btn btn-default btn-sm" style="margin-bottom:10px;">
                    <i class="fa fa-plus"></i> Agregar destacado
                </button>

                <div class="ln_solid"></div>

                {# === CAJAS === #}
                <h5 class="hc-section-title">Cajas de contenido</h5>

                {% for n in [1, 2] %}
                    {% set imgField    = 'box' ~ n ~ 'Image' %}
                    {% set imgMethod   = 'box' ~ n ~ 'ImageFile' %}
                    {% set titleField  = 'box' ~ n ~ 'Title' %}
                    {% set descField   = 'box' ~ n ~ 'Description' %}
                    {% set urlField    = 'box' ~ n ~ 'Url' %}
                    {% set labelField  = 'box' ~ n ~ 'LinkLabel' %}

                    {% set currentImg     = homeContent ? attribute(homeContent, 'get' ~ titleField|capitalize|replace({'Box': 'Box', 'T': 'T'}) ~ '') : null %}
                    {# Helpers #}
                    {% set currentTitle   = homeContent ? attribute(homeContent, 'box' ~ n ~ 'Title') : null %}
                    {% set currentDesc    = homeContent ? attribute(homeContent, 'box' ~ n ~ 'Description') : null %}
                    {% set currentUrl     = homeContent ? attribute(homeContent, 'box' ~ n ~ 'Url') : null %}
                    {% set currentLabel   = homeContent ? attribute(homeContent, 'box' ~ n ~ 'LinkLabel') : null %}
                    {% set currentBoxImg  = homeContent ? attribute(homeContent, 'box' ~ n ~ 'Image') : null %}

                    <div class="row" style="margin-bottom: 20px;">
                        <div class="col-md-12">
                            <h6 style="font-weight:600; color:#555;">Caja {{ n }}</h6>
                        </div>
                        {% set boxFallbacks = {1: 'images/home/pilates.jpg', 2: 'images/home/barra.jpg'} %}
                        <div class="col-md-3 form-group">
                            <label>Imagen</label>
                            {% if currentBoxImg %}
                                <img id="preview-box{{ n }}Image"
                                     src="/media/uploads/site/{{ currentBoxImg }}"
                                     alt="Imagen caja {{ n }} actual" class="hc-image-preview">
                                <div class="checkbox hc-clear-label">
                                    <label>
                                        <input type="checkbox" name="clearBox{{ n }}Image" value="1">
                                        Eliminar imagen actual
                                    </label>
                                </div>
                            {% else %}
                                <img id="preview-box{{ n }}Image"
                                     src="{{ asset(boxFallbacks[n]) }}"
                                     alt="Imagen caja {{ n }} (fallback estático)" class="hc-image-preview"
                                     style="opacity:.6;">
                                <p class="hc-preview-hint text-muted" style="font-size:11px; margin-top:2px;">Imagen actual (estática por defecto) — sube una para reemplazarla</p>
                            {% endif %}
                            <input type="file" name="box{{ n }}ImageFile" class="form-control" accept="image/jpeg,image/png,image/webp"
                                   data-preview="preview-box{{ n }}Image">
                        </div>
                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label>Título</label>
                                    <input type="text" name="box{{ n }}Title" class="form-control"
                                           value="{{ currentTitle ?: defaults['box' ~ n ~ 'Title'] }}"
                                           placeholder="{{ defaults['box' ~ n ~ 'Title'] }}" maxlength="150">
                                </div>
                                <div class="col-md-6 form-group">
                                    <label>Texto del botón</label>
                                    <input type="text" name="box{{ n }}LinkLabel" class="form-control"
                                           value="{{ currentLabel ?: defaults['box' ~ n ~ 'LinkLabel'] }}"
                                           placeholder="{{ defaults['box' ~ n ~ 'LinkLabel'] }}" maxlength="120">
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-8 form-group">
                                    <label>Descripción</label>
                                    <input type="text" name="box{{ n }}Description" class="form-control"
                                           value="{{ currentDesc ?: defaults['box' ~ n ~ 'Description'] }}"
                                           placeholder="{{ defaults['box' ~ n ~ 'Description'] }}" maxlength="255">
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>URL del botón</label>
                                    <input type="text" name="box{{ n }}Url" class="form-control"
                                           value="{{ currentUrl ?: defaults['box' ~ n ~ 'Url'] }}"
                                           placeholder="{{ defaults['box' ~ n ~ 'Url'] }}" maxlength="255">
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}

                <div class="ln_solid"></div>

                {# === GALERÍA === #}
                <h5 class="hc-section-title">Galería de instalaciones</h5>
                <p class="text-muted" style="font-size:12px; margin-bottom:14px;">
                    Las imágenes se muestran en el slider de la sección galería del home.
                    Se ordenan automáticamente por tamaño (las más grandes al slot principal).
                    Formatos aceptados: JPG, PNG, WEBP.
                </p>

                {# Imágenes actuales #}
                {% if galleryImages is not empty %}
                    <div class="hc-gallery-grid" id="hc-gallery-current">
                        {% for filename in galleryImages %}
                            <div class="hc-gallery-item">
                                <img src="/media/uploads/gallery/{{ filename }}" alt="{{ filename }}"
                                     onerror="this.style.opacity='.3'">
                                <label>
                                    <input type="checkbox" name="deleteGallery[]" value="{{ filename }}">
                                    Eliminar
                                </label>
                            </div>
                        {% endfor %}
                    </div>
                    <p class="text-muted" style="font-size:11px; margin-top:-6px; margin-bottom:14px;">
                        Marca "Eliminar" en las fotos que quieras quitar y guarda el formulario.
                    </p>
                {% else %}
                    <div class="alert alert-info" style="font-size:12px; padding:8px 14px;">
                        <i class="fa fa-info-circle"></i> No hay imágenes en la galería todavía.
                    </div>
                {% endif %}

                {# Subir nuevas #}
                <div class="row">
                    <div class="col-md-8 form-group">
                        <label>Subir imágenes nuevas <small class="text-muted">(puedes seleccionar varias a la vez)</small></label>
                        <input type="file" name="galleryFiles[]" id="galleryFilesInput"
                               class="form-control" accept="image/jpeg,image/png,image/webp"
                               multiple>
                        <div class="hc-gallery-new-preview" id="hc-gallery-new-preview"></div>
                    </div>
                </div>

                <div class="ln_solid"></div>

                {# === PREGUNTAS FRECUENTES === #}
                <h5 class="hc-section-title">Preguntas frecuentes (FAQ)</h5>
                <p class="text-muted" style="font-size:12px;margin-bottom:14px;">
                    Cada fila es una tarjeta en la sección de FAQ del home. Puedes agregar o quitar cuantas quieras.
                    Las filas en blanco se omiten al guardar.
                </p>

                <div id="hc-faq-rows">
                    {% for item in faqItems %}
                    <div class="hc-faq-row row" style="margin-bottom:10px;align-items:flex-start;">
                        <div class="col-md-1 form-group" style="padding-right:6px;">
                            <label style="font-size:11px;">Ícono</label>
                            <input type="hidden" name="faqIcon[]" class="hc-faq-icon-val" value="{{ item.icon }}">
                            <div class="hc-faq-icon-btn" title="Cambiar ícono">
                                <i class="bi {{ item.icon }}" style="font-size:22px;color:#C17A6A;"></i>
                            </div>
                            <div class="hc-faq-icon-picker" style="display:none;"></div>
                        </div>
                        <div class="col-md-5 form-group" style="padding-right:6px;">
                            <label style="font-size:11px;">Pregunta</label>
                            <input type="text" name="faqQuestion[]" class="form-control" style="font-size:12px;"
                                   value="{{ item.question }}" placeholder="¿Necesito experiencia previa?" maxlength="120">
                        </div>
                        <div class="col-md-5 form-group" style="padding-right:6px;">
                            <label style="font-size:11px;">Respuesta</label>
                            <textarea name="faqAnswer[]" class="form-control hc-faq-answer" style="font-size:12px;resize:none;overflow:hidden;" rows="3"
                                      placeholder="Escribe la respuesta…" maxlength="400">{{ item.answer }}</textarea>
                        </div>
                        <div class="col-md-1 form-group" style="padding-top:22px;">
                            <button type="button" class="btn btn-danger btn-xs hc-faq-remove" title="Eliminar fila">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    {% endfor %}
                </div>

                <button type="button" id="hc-faq-add" class="btn btn-default btn-sm" style="margin-bottom:10px;">
                    <i class="fa fa-plus"></i> Agregar pregunta
                </button>

                <div class="ln_solid"></div>

                {# === CONTACTO === #}
                <h5 class="hc-section-title">Contacto y redes sociales</h5>
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>Email de contacto</label>
                        <input type="text" name="contactEmail" class="form-control"
                               value="{{ homeContent and homeContent.contactEmail ? homeContent.contactEmail : defaults.contactEmail }}"
                               placeholder="{{ defaults.contactEmail }}" maxlength="255">
                    </div>
                    <div class="col-md-6 form-group">
                        <label>URL Facebook</label>
                        <input type="text" name="contactFacebook" class="form-control"
                               value="{{ homeContent and homeContent.contactFacebook ? homeContent.contactFacebook : defaults.contactFacebook }}"
                               placeholder="{{ defaults.contactFacebook }}" maxlength="255">
                    </div>
                    <div class="col-md-6 form-group">
                        <label>URL Instagram</label>
                        <input type="text" name="contactInstagram" class="form-control"
                               value="{{ homeContent and homeContent.contactInstagram ? homeContent.contactInstagram : defaults.contactInstagram }}"
                               placeholder="{{ defaults.contactInstagram }}" maxlength="255">
                    </div>
                    <div class="col-md-6 form-group">
                        <label>URL WhatsApp <small class="text-muted">(ej: https://wa.me/521234567890)</small></label>
                        <input type="text" name="contactWhatsapp" class="form-control"
                               value="{{ homeContent and homeContent.contactWhatsapp ? homeContent.contactWhatsapp : defaults.contactWhatsapp }}"
                               placeholder="{{ defaults.contactWhatsapp }}" maxlength="255">
                    </div>
                </div>

                <div class="ln_solid"></div>

                <div class="form-group">
                    <div class="col-xs-12">
                        <div class="pull-right">
                            <a href="{{ path('backend_page') }}" class="btn btn-default" style="margin-right: 8px;">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
        <div class="clearfix"></div>
                    </div>
                </div>
            </form>
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function () {
        document.querySelectorAll('input[type="file"][data-preview]').forEach(function (input) {
            input.addEventListener('change', function () {
                var file = this.files && this.files[0];
                if (!file) return;

                var img = document.getElementById(this.dataset.preview);
                if (!img) return;

                var reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    img.style.opacity = '1';
                    img.style.outline = '2px solid #f0ad4e';

                    // Actualizar o crear la nota de estado
                    var hint = img.nextElementSibling;
                    if (hint && hint.classList.contains('hc-preview-hint')) {
                        hint.textContent = '\u2139\ufe0f Nueva imagen seleccionada \u2014 pendiente de guardar';
                        hint.style.color = '#b7791f';
                        hint.style.fontWeight = '600';
                    } else {
                        var note = document.createElement('p');
                        note.className = 'hc-preview-hint';
                        note.textContent = '\u2139\ufe0f Nueva imagen seleccionada \u2014 pendiente de guardar';
                        note.style.cssText = 'font-size:11px;margin-top:4px;color:#b7791f;font-weight:600;';
                        img.insertAdjacentElement('afterend', note);
                    }
                };
                reader.readAsDataURL(file);
            });
        });
        // Preview galería nueva (multi-file)
        var galleryInput = document.getElementById('galleryFilesInput');
        var galleryPreview = document.getElementById('hc-gallery-new-preview');
        if (galleryInput && galleryPreview) {
            galleryInput.addEventListener('change', function () {
                galleryPreview.innerHTML = '';
                Array.from(this.files).forEach(function (file) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        var img = document.createElement('img');
                        img.src = e.target.result;
                        galleryPreview.appendChild(img);
                    };
                    reader.readAsDataURL(file);
                });
            });
        }
    })();
    </script>

    <script>
    // === FAQ dinámica ===
    (function () {
        var faqIconsMap = {{ faqIcons|json_encode|raw }};
        var faqIconKeys = Object.keys(faqIconsMap);

        /* ---- Picker grid ---- */
        function buildPickerGrid(currentVal) {
            var html = '<div style="display:flex;flex-wrap:wrap;gap:4px;padding:8px;background:#fff;border:1px solid #ddd;border-radius:4px;width:260px;max-height:220px;overflow-y:auto;position:absolute;z-index:9999;box-shadow:0 4px 12px rgba(0,0,0,.15);">';
            faqIconKeys.forEach(function (cls) {
                var active = cls === currentVal ? 'background:#f5ece9;border-color:#C17A6A;' : 'background:#fff;border-color:#eee;';
                html += '<span class="hc-faq-pick-item" data-icon="' + cls + '" title="' + faqIconsMap[cls] + '" '
                    + 'style="cursor:pointer;padding:5px;border:1px solid #eee;border-radius:4px;display:inline-flex;align-items:center;justify-content:center;' + active + '">' 
                    + '<i class="bi ' + cls + '" style="font-size:18px;color:#C17A6A;"></i></span>';
            });
            html += '</div>';
            return html;
        }

        /* ---- HTML de una fila nueva ---- */
        function newRowHtml(iconVal) {
            iconVal = iconVal || 'bi-question-circle';
            return '<div class="hc-faq-row row" style="margin-bottom:10px;align-items:flex-start;">'
                + '<div class="col-md-1 form-group" style="padding-right:6px;">'
                + '<label style="font-size:11px;">Ícono</label>'
                + '<input type="hidden" name="faqIcon[]" class="hc-faq-icon-val" value="' + iconVal + '">'
                + '<div class="hc-faq-icon-btn" title="Cambiar ícono" style="cursor:pointer;"><i class="bi ' + iconVal + '" style="font-size:22px;color:#C17A6A;"></i></div>'
                + '<div class="hc-faq-icon-picker" style="display:none;position:relative;"></div>'
                + '</div>'
                + '<div class="col-md-5 form-group" style="padding-right:6px;">'
                + '<label style="font-size:11px;">Pregunta</label>'
                + '<input type="text" name="faqQuestion[]" class="form-control" style="font-size:12px;" placeholder="¿Necesito experiencia previa?" maxlength="120">'
                + '</div>'
                + '<div class="col-md-5 form-group" style="padding-right:6px;">'
                + '<label style="font-size:11px;">Respuesta</label>'
                + '<textarea name="faqAnswer[]" class="form-control hc-faq-answer" style="font-size:12px;resize:none;overflow:hidden;" rows="3" placeholder="Escribe la respuesta…" maxlength="400"></textarea>'
                + '</div>'
                + '<div class="col-md-1 form-group" style="padding-top:22px;">'
                + '<button type="button" class="btn btn-danger btn-xs hc-faq-remove" title="Eliminar fila"><i class="fa fa-trash"></i></button>'
                + '</div>'
                + '</div>';
        }

        /* ---- Auto-resize textarea ---- */
        function autoResize(ta) {
            ta.style.height = 'auto';
            ta.style.height = ta.scrollHeight + 'px';
        }

        /* ---- Cablear fila ---- */
        function wireRow(row) {
            // Picker
            var btn     = row.querySelector('.hc-faq-icon-btn');
            var picker  = row.querySelector('.hc-faq-icon-picker');
            var hidden  = row.querySelector('.hc-faq-icon-val');

            if (btn && picker && hidden) {
                btn.style.cursor = 'pointer';
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var isOpen = picker.style.display !== 'none';
                    // Cerrar todos los otros pickers abiertos
                    document.querySelectorAll('.hc-faq-icon-picker').forEach(function (p) {
                        p.style.display = 'none'; p.innerHTML = '';
                    });
                    if (!isOpen) {
                        picker.innerHTML = buildPickerGrid(hidden.value);
                        picker.style.display = 'block';
                        picker.querySelectorAll('.hc-faq-pick-item').forEach(function (item) {
                            item.addEventListener('click', function (e) {
                                e.stopPropagation();
                                var cls = item.dataset.icon;
                                hidden.value = cls;
                                btn.innerHTML = '<i class="bi ' + cls + '" style="font-size:22px;color:#C17A6A;"></i>';
                                picker.style.display = 'none';
                                picker.innerHTML = '';
                            });
                        });
                    }
                });
            }

            // Auto-resize textareas existentes
            var ta = row.querySelector('.hc-faq-answer');
            if (ta) {
                autoResize(ta);
                ta.addEventListener('input', function () { autoResize(this); });
            }

            // Eliminar fila
            var removeBtn = row.querySelector('.hc-faq-remove');
            if (removeBtn) {
                removeBtn.addEventListener('click', function () { row.remove(); });
            }
        }

        // Cerrar picker al click fuera
        document.addEventListener('click', function () {
            document.querySelectorAll('.hc-faq-icon-picker').forEach(function (p) {
                p.style.display = 'none'; p.innerHTML = '';
            });
        });

        // Cablear filas existentes
        document.querySelectorAll('.hc-faq-row').forEach(wireRow);

        // Agregar nueva fila
        var addBtn = document.getElementById('hc-faq-add');
        if (addBtn) {
            addBtn.addEventListener('click', function () {
                var tmp = document.createElement('div');
                tmp.innerHTML = newRowHtml('bi-question-circle');
                var row = tmp.firstElementChild;
                document.getElementById('hc-faq-rows').appendChild(row);
                wireRow(row);
            });
        }
    })();
    </script>

    <script>
    // === Features dinámicas ===
    (function () {
        var featIconsMap = {{ faqIcons|json_encode|raw }};
        var featIconKeys = Object.keys(featIconsMap);

        function buildFeatPickerGrid(currentVal) {
            var html = '<div style="display:flex;flex-wrap:wrap;gap:4px;padding:8px;background:#fff;border:1px solid #ddd;border-radius:4px;width:260px;max-height:220px;overflow-y:auto;position:absolute;z-index:9999;box-shadow:0 4px 12px rgba(0,0,0,.15);">';
            featIconKeys.forEach(function (cls) {
                var active = cls === currentVal ? 'background:#f5ece9;border-color:#C17A6A;' : 'background:#fff;border-color:#eee;';
                html += '<span class="hc-feat-pick-item" data-icon="' + cls + '" title="' + featIconsMap[cls] + '" '
                    + 'style="cursor:pointer;padding:5px;border:1px solid #eee;border-radius:4px;display:inline-flex;align-items:center;justify-content:center;' + active + '">'
                    + '<i class="bi ' + cls + '" style="font-size:18px;color:#C17A6A;"></i></span>';
            });
            html += '</div>';
            return html;
        }

        function newFeatRowHtml(iconVal) {
            iconVal = iconVal || 'bi-check-circle';
            return '<div class="hc-feat-row row" style="margin-bottom:10px;align-items:flex-start;">'
                + '<div class="col-md-1 form-group" style="padding-right:6px;">'
                + '<label style="font-size:11px;">Ícono</label>'
                + '<input type="hidden" name="featureIcon[]" class="hc-feat-icon-val" value="' + iconVal + '">'
                + '<div class="hc-feat-icon-btn" title="Cambiar ícono" style="cursor:pointer;"><i class="bi ' + iconVal + '" style="font-size:22px;color:#C17A6A;"></i></div>'
                + '<div class="hc-feat-icon-picker" style="display:none;position:relative;"></div>'
                + '</div>'
                + '<div class="col-md-4 form-group" style="padding-right:6px;">'
                + '<label style="font-size:11px;">Título</label>'
                + '<input type="text" name="featureTitle[]" class="form-control" style="font-size:12px;" placeholder="Atención personalizada" maxlength="80">'
                + '</div>'
                + '<div class="col-md-6 form-group" style="padding-right:6px;">'
                + '<label style="font-size:11px;">Descripción</label>'
                + '<textarea name="featureText[]" class="form-control hc-feat-text" style="font-size:12px;resize:none;overflow:hidden;" rows="2" placeholder="Grupos reducidos para corregir y potenciar tu progreso." maxlength="200"></textarea>'
                + '</div>'
                + '<div class="col-md-1 form-group" style="padding-top:22px;">'
                + '<button type="button" class="btn btn-danger btn-xs hc-feat-remove" title="Eliminar fila"><i class="fa fa-trash"></i></button>'
                + '</div>'
                + '</div>';
        }

        function autoResizeFeat(ta) {
            ta.style.height = 'auto';
            ta.style.height = ta.scrollHeight + 'px';
        }

        function wireFeatRow(row) {
            var btn    = row.querySelector('.hc-feat-icon-btn');
            var picker = row.querySelector('.hc-feat-icon-picker');
            var hidden = row.querySelector('.hc-feat-icon-val');

            if (btn && picker && hidden) {
                btn.style.cursor = 'pointer';
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var isOpen = picker.style.display !== 'none';
                    document.querySelectorAll('.hc-feat-icon-picker,.hc-faq-icon-picker').forEach(function (p) {
                        p.style.display = 'none'; p.innerHTML = '';
                    });
                    if (!isOpen) {
                        picker.innerHTML = buildFeatPickerGrid(hidden.value);
                        picker.style.display = 'block';
                        picker.querySelectorAll('.hc-feat-pick-item').forEach(function (item) {
                            item.addEventListener('click', function (e) {
                                e.stopPropagation();
                                var cls = item.dataset.icon;
                                hidden.value = cls;
                                btn.innerHTML = '<i class="bi ' + cls + '" style="font-size:22px;color:#C17A6A;"></i>';
                                picker.style.display = 'none';
                                picker.innerHTML = '';
                            });
                        });
                    }
                });
            }

            var ta = row.querySelector('.hc-feat-text');
            if (ta) {
                autoResizeFeat(ta);
                ta.addEventListener('input', function () { autoResizeFeat(this); });
            }

            var removeBtn = row.querySelector('.hc-feat-remove');
            if (removeBtn) {
                removeBtn.addEventListener('click', function () { row.remove(); });
            }
        }

        document.querySelectorAll('.hc-feat-row').forEach(wireFeatRow);

        var addBtn = document.getElementById('hc-feat-add');
        if (addBtn) {
            addBtn.addEventListener('click', function () {
                var tmp = document.createElement('div');
                tmp.innerHTML = newFeatRowHtml('bi-check-circle');
                var row = tmp.firstElementChild;
                document.getElementById('hc-feat-rows').appendChild(row);
                wireFeatRow(row);
            });
        }
    })();
    </script>
{% endblock %}
