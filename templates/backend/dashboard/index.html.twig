                        <h4 class="dash-section-title">{{ studio.name }}</h4>
                        <div style="display:flex; flex-wrap:wrap; gap:6px; align-items:flex-start;">
                            {% for periodKey, periodLabel in {'year': 'Año', 'monthly': 'Mes', 'weekly': 'Semana', 'daily': 'Día'} %}
                                {% set dateStartParam = periodKey == 'year' ? providerData.currentYear|date('d/m/Y') : (periodKey == 'monthly' ? providerData.currentMonth|date('d/m/Y') : (periodKey == 'weekly' ? providerData.currentWeek|date('d/m/Y') : providerData.currentDay|date('d/m/Y'))) %}
                                {% set dateEndParam   = periodKey == 'year' ? providerData.currentYearEnd|date('d/m/Y') : (periodKey == 'monthly' ? providerData.currentMonthEnd|date('d/m/Y') : (periodKey == 'weekly' ? providerData.currentWeekEnd|date('d/m/Y') : providerData.currentDay|date('d/m/Y'))) %}
                                <div class="dash-period dash-period--{{ periodKey }}" style="flex:1 1 160px; min-width:130px; padding:4px 6px;">
                                    <h4 class="dash-period-header">{{ periodLabel }}</h4>
                                    {% set periodData = attribute(studio, periodKey) %}
                                    <div style="display:flex; flex-wrap:wrap; gap:2px; justify-content:center;">
                                        <a href="{{ path('backend_user_show', {
                                            'id': providerData.fitpassUserId,
                                            'tab': 'reservations',
                                            'filter_status': 1,
                                            'filter_branch_office': branchOfficeId,
                                            'filter_session_date_start': dateStartParam,
                                            'filter_session_date_end': dateEndParam
                                        }) }}" style="flex:1 1 50px; min-width:45px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                            <div style="font-size:10px; color:#888; text-transform:uppercase; white-space:nowrap;">Reservadas</div>
                                            <div style="font-size:16px; font-weight:700; line-height:1.2; {% if periodData.reserved == 0 %}color:#ccc;{% endif %}">{{ periodData.reserved }}</div>
                                        </a>
                                        <a href="{{ path('backend_user_show', {
                                            'id': providerData.fitpassUserId,
                                            'tab': 'reservations',
                                            'filter_status': 1,
                                            'filter_attended': 1,
                                            'filter_branch_office': branchOfficeId,
                                            'filter_session_date_start': dateStartParam,
                                            'filter_session_date_end': dateEndParam
                                        }) }}" style="flex:1 1 50px; min-width:45px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                            <div style="font-size:10px; color:#888; text-transform:uppercase; white-space:nowrap;">Asistidas</div>
                                            <div style="font-size:16px; font-weight:700; line-height:1.2; {% if periodData.attended == 0 %}color:#ccc;{% endif %}">{{ periodData.attended }}</div>
                                        </a>
                                        <a href="{{ path('backend_user_show', {
                                            'id': providerData.fitpassUserId,
                                            'tab': 'reservations',
                                            'filter_status': 1,
                                            'filter_attended': 0,
                                            'filter_branch_office': branchOfficeId,
                                            'filter_session_date_start': dateStartParam,
                                            'filter_session_date_end': dateEndParam
                                        }) }}" style="flex:1 1 50px; min-width:45px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                            <div style="font-size:10px; color:#888; text-transform:uppercase; white-space:nowrap;">No asistidas</div>
                                            <div style="font-size:16px; font-weight:700; line-height:1.2; {% if periodData.notAttended == 0 %}color:#ccc;{% endif %}">{{ periodData.notAttended }}</div>
                                        </a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endmacro %}

        <div class="row">
