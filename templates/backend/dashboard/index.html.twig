{% extends 'backend/layout.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block content %}
    <style>
        .dashboard-kpi-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 15px;
        }

        .dashboard-kpi-tile {
            flex: 0 0 auto;
            min-width: 220px;
            width: auto;
            text-align: center;
        }

        .dashboard-kpi-link {
            display: block;
            color: inherit;
            text-decoration: none;
        }

        .dashboard-kpi-link:hover,
        .dashboard-kpi-link:focus {
            color: inherit;
            text-decoration: none;
        }

        .dashboard-kpi-link .count {
            font-size: 28px;
            line-height: 1.15;
            white-space: nowrap;
            word-break: normal;
            overflow: visible;
        }

        .tile_count .tile_stats_count {
            min-height: 120px;
        }

        /* ── Dashboard: sistema tipográfico unificado ── */
        .dash-section-sep    { margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid #f0f0f0; }
        .dash-section-title  { margin: 0 0 8px; text-align: center; font-weight: 700; font-size: 15px; color: #1a2340; }
        .dash-period-header  { margin: 0 0 6px; text-align: center; font-weight: 700; font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: .4px; }
        .dash-provider-sep   { margin: 0 0 12px; padding-bottom: 7px; border-bottom: 2px solid #e8eaf0; font-size: 15px; font-weight: 700; color: #1a2340; text-align: center; }
        .dash-provider-name  { margin: 6px 0 14px; padding-bottom: 7px; border-bottom: 1px solid #dde2f0; text-align: center; font-weight: 700; font-size: 17px; color: #1a2340; }
        .dash-person-row     { display: flex; align-items: center; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #f0f0f0; }
        .dash-person-link    { text-decoration: none; color: inherit; font-size: 14px; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .dash-person-link:hover, .dash-person-link:focus { color: inherit; text-decoration: none; }
        .dash-person-meta    { font-size: 12px; color: #888; margin-left: 8px; white-space: nowrap; }
        .dash-empty-msg      { text-align: center; color: #aaa; margin: 8px 0 0; font-size: 13px; }
        /* Normalización de tamaños de fuente en tiles de estadísticas */
        div[style*="font-size:16px; font-weight:700; line-height:1.2"],
        div[style*="font-size:20px; font-weight:700; line-height:1.2"] { font-size: 18px !important; }
        div[style*="font-size:10px; color:#888; text-transform"],
        div[style*="font-size:12px; color:#888; white-space:nowrap"] { font-size: 11px !important; color: #888; }
        /* ── Retención nuevo usuario ── */
        .nu-retention-cols  { display: flex; flex-wrap: wrap; gap: 0; }
        .nu-retention-col   { flex: 1 1 300px; min-width: 0; padding: 0 12px 16px; box-sizing: border-box; }
        .nu-retention-col--left  { border-right: 1px solid #eee; }
        .nu-retention-col h4     { margin: 0 0 10px; font-weight: 700; }
        .nu-retention-col table  { width: 100%; table-layout: auto; }
        .nu-retention-col table th,
        .nu-retention-col table td { padding: 6px 8px; vertical-align: middle; word-break: break-word; }
        .nu-retention-col table td.nu-email { max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #888; }
        .nu-retention-col table td.nu-date  { white-space: nowrap; text-align: center; }
        .nu-retention-col table td.nu-badge { text-align: center; }
        @media (max-width: 767px) {
            .nu-retention-col--left { border-right: none; border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 12px; }
            .nu-retention-col { flex: 1 1 100%; padding: 0 0 16px; }
            .nu-retention-col table th,
            .nu-retention-col table td { padding: 5px 6px; font-size: 12px; }
            .nu-retention-col table td.nu-email { max-width: 110px; }
        }
    </style>

    {% if billing is defined %}
        <div class="dashboard-kpi-grid tile_count">
            <div class="dashboard-kpi-tile tile_stats_count">
                <a href="{{ path('backend_transaction') }}" class="dashboard-kpi-link">
                    <span class="count_top"><i class="fa fa-dollar"></i> Total histórico</span>
                    <div class="count">${{ billing.amountProcessed|number_format(2, '.', ',') }}</div>
                </a>
            </div>
            <div class="dashboard-kpi-tile tile_stats_count">
                <a href="{{ path('backend_transaction', {
                    filter_date_start: billing.currentYear|date('d/m/Y'),
                    filter_date_end: billing.currentYear|date_modify('+1 year -1 day')|date('d/m/Y'),
                    filter_status: constant('App\\Entity\\Transaction::STATUS_PAID')
                }) }}" class="dashboard-kpi-link">
                    <span class="count_top"><i class="fa fa-calendar"></i> Total anual</span>
                    <div class="count">${{ billing.amountAnnually|number_format(2, '.', ',') }}</div>
                </a>
            </div>
            <div class="dashboard-kpi-tile tile_stats_count">
                <a href="{{ path('backend_transaction', {
                    filter_date_start: billing.currentMonth|date('d/m/Y'),
                    filter_status: constant('App\\Entity\\Transaction::STATUS_PAID')
                }) }}" class="dashboard-kpi-link">
                    <span class="count_top"><i class="fa fa-calendar-o"></i> Total mensual</span>
                    <div class="count">${{ billing.amountMonthly|number_format(2, '.', ',') }}</div>
                </a>
            </div>
            <div class="dashboard-kpi-tile tile_stats_count">
                <a href="{{ path('backend_transaction', {
                    filter_date_start: billing.currentWeek|date('d/m/Y'),
                    filter_date_end: billing.currentWeek|date_modify('+6 days')|date('d/m/Y'),
                    filter_status: constant('App\\Entity\\Transaction::STATUS_PAID')
                }) }}" class="dashboard-kpi-link">
                    <span class="count_top"><i class="fa fa-calendar-check-o"></i> Total semanal</span>
                    <div class="count">${{ billing.amountWeekly|number_format(2, '.', ',') }}</div>
                </a>
            </div>
            <div class="dashboard-kpi-tile tile_stats_count">
                <a href="{{ path('backend_transaction', {
                    filter_date_start: 'now'|date('d/m/Y'),
                    filter_date_end: 'now'|date('d/m/Y'),
                    filter_status: constant('App\\Entity\\Transaction::STATUS_PAID')
                }) }}" class="dashboard-kpi-link">
                    <span class="count_top"><i class="fa fa-clock-o"></i> Total del día</span>
                    <div class="count">${{ billing.amountDaily|number_format(2, '.', ',') }}</div>
                </a>
            </div>
        </div>
    {% endif %}

    {% if lastTransactions is defined %}
        <div class="row">
            <div class="col-xs-12">
                <div class="x_panel">
                    <div class="x_title x_title--collapsible" style="text-align:center; cursor:pointer;" data-panel-id="last-transactions">
                        <h2 style="width:100%; text-align:center;"><i class="fa fa-exchange" aria-hidden="true"></i> Últimas transacciones <i class="fa fa-chevron-down dash-panel-chevron" aria-hidden="true"></i></h2>
                        <div class="clearfix"></div>
                    </div>
                    <div class="x_content">
                        {% if lastTransactions %}
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="thead-dark">
                                    <tr>
                                        <th>#</th>
                                        <th>Usuario</th>
                                        <th>Email</th>
                                        <th>Paquete</th>
                                        <th>Modalidad</th>
                                        <th class="text-right">Monto</th>
                                        <th>M. de pago</th>
                                        <th class="text-center">F. registro</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for entity in lastTransactions %}
                                        {# entity \App\Entity\Transaction #}
                                        <tr>
                                            <th scope="row">{{ entity.id }}</th>
                                            <td>{{ entity.user }}</td>
                                            <td>{{ entity.user.email }}</td>
                                            <td>{{ entity.packageTotalClasses }} clase(s)</td>
                                            <td>{{ entity.packageType|PackageSessionType }}</td>
                                            <td class="text-right">${{ entity.total|number_format(2) }}</td>
                                            <td>{{ entity.chargeMethod|ChargeMethodDescription }}</td>
                                            <td class="text-center">{{ entity.createdAt|date('Y-m-d H:i') }}</td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            {{ include('backend/default/partials/not_records.html.twig') }}
                        {% endif %}
                    </div>

                    <div class="clearfix"></div>

                    {% if lastTransactions %}
                        <div class="x_footer text-center">
                            <a href="{{ path('backend_transaction') }}" class="btn btn-default btn-sm">Ver todas</a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-xs-12">
                <div class="x_panel">
                    <div class="x_title x_title--collapsible" style="text-align:center; cursor:pointer;" data-panel-id="discounts">
                        <h2 style="width:100%; text-align:center;"><i class="fa fa-money" aria-hidden="true"></i> Transacciones <i class="fa fa-chevron-down dash-panel-chevron" aria-hidden="true"></i></h2>
                        <div class="clearfix"></div>
                    </div>
                    <div class="x_content">
                        {% if discounts is defined and discounts.data is not empty %}
                            {% for branchOfficeId, branch in discounts.data %}
                                {% if branch.annually.without_discount > 0 or branch.annually.percentage_discount > 0 or branch.annually.special_price > 0 or branch.monthly.without_discount > 0 or branch.monthly.percentage_discount > 0 or branch.monthly.special_price > 0 %}
                                <div class="dash-section-sep">
                                    <h4 class="dash-section-title">{{ branch.name }}</h4>
                                    <div style="display:flex; flex-wrap:wrap; gap:6px; align-items:flex-start;">
                                        {% for periodKey, periodLabel in {'annually': 'Año', 'monthly': 'Mes'} %}
                                            {% set dateStartParam = periodKey == 'annually' ? discounts.currentYear|date('d/m/Y') : discounts.currentMonth|date('d/m/Y') %}
                                            {% set dateEndParam = 'now'|date('d/m/Y') %}
                                            {% set periodData = attribute(branch, periodKey) %}
                                            <div style="flex:1 1 220px; min-width:180px; padding:4px 6px;">
                                                <h4 class="dash-period-header">{{ periodLabel }}</h4>
                                                <div style="display:flex; flex-wrap:wrap; gap:2px; justify-content:center;">
                                                    <a href="{{ path('backend_transaction', {
                                                        filter_date_start: dateStartParam,
                                                        filter_date_end: dateEndParam,
                                                        filter_status: constant('App\\Entity\\Transaction::STATUS_PAID'),
                                                        filter_branchOffice: branchOfficeId,
                                                        filter_discount: constant('App\\Entity\\Transaction::WITHOUT_DISCOUNT')
                                                    }) }}" style="flex:1 1 90px; min-width:85px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                                        <div style="font-size:10px; color:#888; text-transform:uppercase; white-space:nowrap;">Sin descuento</div>
                                                        <div style="font-size:16px; font-weight:700; line-height:1.2; {% if periodData.without_discount == 0 %}color:#ccc;{% endif %}">${{ periodData.without_discount|number_format(2, '.', ',') }}</div>
                                                    </a>
                                                    {% set combinedDiscount = periodData.percentage_discount + periodData.special_price %}
                                                    <a href="{{ path('backend_transaction', {
                                                        filter_date_start: dateStartParam,
                                                        filter_date_end: dateEndParam,
                                                        filter_status: constant('App\\Entity\\Transaction::STATUS_PAID'),
                                                        filter_branchOffice: branchOfficeId
                                                    }) }}" style="flex:1 1 90px; min-width:85px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                                        <div style="font-size:10px; color:#888; text-transform:uppercase; white-space:nowrap;">Con descuento</div>
                                                        <div style="font-size:16px; font-weight:700; line-height:1.2; {% if combinedDiscount == 0 %}color:#ccc;{% endif %}">${{ combinedDiscount|number_format(2, '.', ',') }}</div>
                                                    </a>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                        {% else %}
                            {{ include('backend/default/partials/not_records.html.twig') }}
                        {% endif %}
                    </div>
                    <div class="clearfix"></div>
                    <div class="x_footer text-center">
                        <a href="{{ path('backend_transaction') }}" class="btn btn-default btn-sm">Ver todas</a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    {% if payments is defined and payments.data is not empty %}
        <div class="row">
            <div class="col-xs-12">
                <div class="x_panel">
                    <div class="x_title x_title--collapsible" style="text-align:center; cursor:pointer;" data-panel-id="payments">
                        <h2 style="width:100%; text-align:center;"><i class="fa fa-credit-card" aria-hidden="true"></i> M&eacute;todos de pago <i class="fa fa-chevron-down dash-panel-chevron" aria-hidden="true"></i></h2>
                        <div class="clearfix"></div>
                    </div>
                    <div class="x_content">
                        {% for branchOfficeId, branch in payments.data %}
                            {% if branch.annually.cash > 0 or branch.annually.card > 0 or branch.annually.pos > 0 or branch.monthly.cash > 0 or branch.monthly.card > 0 or branch.monthly.pos > 0 %}
                            <div class="dash-section-sep">
                                <h4 class="dash-section-title">{{ branch.name }}</h4>
                                <div style="display:flex; flex-wrap:wrap; gap:6px; align-items:flex-start;">
                                    {% for periodKey, periodLabel in {'annually': 'Año', 'monthly': 'Mes'} %}
                                        {% set dateStartParam = periodKey == 'annually' ? payments.currentYear|date('d/m/Y') : payments.currentMonth|date('d/m/Y') %}
                                        {% set dateEndParam = 'now'|date('d/m/Y') %}
                                        {% set periodData = attribute(branch, periodKey) %}
                                        <div class="dash-period dash-period--{{ periodKey }}" style="flex:1 1 220px; min-width:180px; padding:4px 6px;">
                                            <h4 class="dash-period-header">{{ periodLabel }}</h4>
                                            <div style="display:flex; flex-wrap:wrap; gap:2px; justify-content:center;">
                                                {% set methods = {
                                                    'cash': {'label': 'Efectivo',  'const': constant('App\\Entity\\Transaction::CHARGE_METHOD_CASH')},
                                                    'card': {'label': 'Tarjeta',   'const': constant('App\\Entity\\Transaction::CHARGE_METHOD_CARD')},
                                                    'pos':  {'label': 'Terminal',  'const': constant('App\\Entity\\Transaction::CHARGE_METHOD_POS')}
                                                } %}
                                                {% for key, method in methods %}
                                                    {% set amount = attribute(periodData, key) %}
                                                    <a href="{{ path('backend_transaction', {
                                                        filter_date_start: dateStartParam,
                                                        filter_date_end: dateEndParam,
                                                        filter_status: constant('App\\Entity\\Transaction::STATUS_PAID'),
                                                        filter_branchOffice: branchOfficeId,
                                                        filter_charge_method: method.const
                                                    }) }}" style="flex:1 1 80px; min-width:72px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                                        <div style="font-size:10px; color:#888; text-transform:uppercase; white-space:nowrap;">{{ method.label }}</div>
                                                        <div style="font-size:16px; font-weight:700; line-height:1.2; {% if amount == 0 %}color:#ccc;{% endif %}">${{ amount|number_format(2, '.', ',') }}</div>
                                                    </a>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div class="clearfix"></div>
                    <div class="x_footer text-center">
                        <a href="{{ path('backend_transaction') }}" class="btn btn-default btn-sm">Ver todas</a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    {% if classes is defined %}
        <div class="row">
            <div class="col-xs-12">
                <div class="x_panel">
                    <div class="x_title x_title--collapsible" style="text-align:center; cursor:pointer;" data-panel-id="classes">
                        <h2 style="width:100%; text-align:center;"><i class="fa fa-calendar-check-o" aria-hidden="true"></i> Clases <i class="fa fa-chevron-down dash-panel-chevron" aria-hidden="true"></i></h2>
                        <div class="clearfix"></div>
                    </div>
                    <div class="x_content">
                        {% for branchOfficeId, studio in classes.data %}
                            <div class="dash-section-sep">
                                <h4 class="dash-section-title">{{ studio.name }}</h4>
                                <div style="display:flex; flex-wrap:wrap; gap:6px; align-items:flex-start;">
                                    {% for periodKey, periodLabel in {'monthly': 'Mes', 'weekly': 'Semana', 'daily': 'Día'} %}
                                        {% set dateParam    = periodKey == 'monthly' ? classes.currentMonth|date('d/m/Y')    : (periodKey == 'weekly' ? classes.currentWeek|date('d/m/Y')    : classes.currentDay|date('d/m/Y')) %}
                                        {% set dateEndParam = periodKey == 'monthly' ? classes.currentMonthEnd|date('d/m/Y') : (periodKey == 'weekly' ? classes.currentWeekEnd|date('d/m/Y') : classes.currentDay|date('d/m/Y')) %}
                                        <div class="dash-period dash-period--{{ periodKey }}" style="flex:1 1 160px; min-width:130px; padding:4px 6px;">
                                            <h4 class="dash-period-header">{{ periodLabel }}</h4>
                                            <div style="display:flex; flex-wrap:wrap; gap:2px; justify-content:center;">
                                                {% for disciplineId, discipline in studio.disciplines %}
                                                    {% set count = attribute(discipline, periodKey) %}
                                                    <a href="{{ path('backend_session', {
                                                        'filters[status]': constant('App\\Entity\\Session::STATUS_CLOSED'),
                                                        'filters[hasTakenReservations]': 1,
                                                        'filters[branchOffice]': branchOfficeId,
                                                        'filters[discipline]': disciplineId,
                                                        'filters[type]': constant('App\\Util\\PackageSessionType::TYPE_GROUP'),
                                                        'filters[date_start]': dateParam,
                                                        'filters[date_end]': dateEndParam
                                                    }) }}" style="flex:1 1 70px; min-width:62px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                                        <div style="font-size:12px; color:#888; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="{{ discipline.name }}">{{ discipline.name }}</div>
                                                        <div style="font-size:20px; font-weight:700; line-height:1.2; {% if count == 0 %}color:#ccc;{% endif %}">{{ count }}</div>
                                                    </a>
                                                {% endfor %}
                                                {% set privateCount = attribute(studio.private, periodKey) %}
                                                <a href="{{ path('backend_session', {
                                                    'filters[status]': constant('App\\Entity\\Session::STATUS_CLOSED'),
                                                    'filters[hasTakenReservations]': 1,
                                                    'filters[branchOffice]': branchOfficeId,
                                                    'filters[type]': constant('App\\Util\\PackageSessionType::TYPE_INDIVIDUAL'),
                                                    'filters[date_start]': dateParam,
                                                    'filters[date_end]': dateEndParam
                                                }) }}" style="flex:1 1 70px; min-width:62px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                                    <div style="font-size:12px; color:#888; white-space:nowrap;">Privada</div>
                                                    <div style="font-size:20px; font-weight:700; line-height:1.2; {% if privateCount == 0 %}color:#ccc;{% endif %}">{{ privateCount }}</div>
                                                </a>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="clearfix"></div>
                    <div class="x_footer text-center">
                        <a href="{{ path('backend_session') }}" class="btn btn-default btn-sm">Ver todas</a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    {% if instructors is defined %}
        <div class="row">
            <div class="col-xs-12">
                <div class="x_panel">
                    <div class="x_title x_title--collapsible" style="text-align:center; cursor:pointer;" data-panel-id="instructors">
                        <h2 style="width:100%; text-align:center;"><i class="fa fa-futbol-o" aria-hidden="true"></i> Asistencias <i class="fa fa-chevron-down dash-panel-chevron" aria-hidden="true"></i></h2>
                        <div class="clearfix"></div>
                    </div>
                    <div class="x_content">
                        {% if not instructors.hasStartDate %}
                            <div class="alert alert-warning" style="margin-bottom:0;">
                                No hay fecha de inicio de catorcena configurada en Ajustes &rarr; Stats.
                            </div>
                        {% elseif instructors.data is empty %}
                            {{ include('backend/default/partials/not_records.html.twig') }}
                        {% else %}
                            {% for branchOfficeId, studio in instructors.data %}
                                {% if studio.instructors is not empty %}
                                <div class="dash-section-sep">
                                    <h4 class="dash-section-title">{{ studio.name }}</h4>
                                    <div style="display:flex; flex-wrap:wrap; gap:6px; align-items:flex-start;">
                                        {% for periodKey, periodLabel in {'monthly': 'Mes', 'catorcena': 'Catorcena'} %}
                                            {% set dateStartParam = periodKey == 'monthly' ? instructors.startMonth|date('d/m/Y') : instructors.startCatorcena|date('d/m/Y') %}
                                            {% set dateEndParam = periodKey == 'monthly' ? instructors.endMonth|date('d/m/Y') : instructors.endCatorcena|date('d/m/Y') %}
                                            <div class="dash-period dash-period--{{ periodKey }}" style="flex:1 1 220px; min-width:180px; padding:4px 6px;">
                                                <h4 class="dash-period-header">
                                                    {% if periodKey == 'catorcena' %}
                                                        {{ periodLabel }} (inicio: {{ instructors.startCatorcena|date('d/m/Y') }})
                                                    {% else %}
                                                        {{ periodLabel }}
                                                    {% endif %}
                                                </h4>
                                                <div style="display:flex; flex-wrap:wrap; gap:2px; justify-content:center;">
                                                    {% for instructorId, instructor in studio.instructors %}
                                                        {% set count = attribute(instructor, periodKey) %}
                                                        <a href="{{ path('backend_session', {
                                                            'filters[status]': constant('App\\Entity\\Session::STATUS_CLOSED'),
                                                            'filters[hasTakenReservations]': 1,
                                                            'filters[branchOffice]': branchOfficeId,
                                                            'filters[instructor]': instructorId,
                                                            'filters[date_start]': dateStartParam,
                                                            'filters[date_end]': dateEndParam
                                                        }) }}" style="flex:1 1 130px; min-width:120px; text-align:center; text-decoration:none; color:inherit; padding:2px 4px; display:block;">
                                                            <div style="font-size:12px; color:#888; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="{{ instructor.firstname }} {{ instructor.paternalSurname }} {{ instructor.maternalSurname|default('') }}">
                                                                {{ instructor.firstname }} {{ instructor.paternalSurname }} {{ instructor.maternalSurname|default('') }}
                                                            </div>
                                                            <div style="font-size:20px; font-weight:700; line-height:1.2; {% if count == 0 %}color:#ccc;{% endif %}">{{ count }}</div>
                                                        </a>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </div>
                    <div class="clearfix"></div>
                    <div class="x_footer text-center">
                        <a href="{{ path('backend_session') }}" class="btn btn-default btn-sm">Ver todas</a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    {% if fitpass is defined or wellhub is defined or totalpass is defined %}
        {# ── Macro: stats por sucursal para un proveedor ──────────────────── #}
        {% macro provider_stats(providerData) %}
            {% if not providerData.hasFitpassUser %}
                <div class="alert alert-info" style="margin:0 0 4px;">
                    <i class="fa fa-info-circle" aria-hidden="true"></i>
                    No hay ningún usuario asignado a este proveedor. Ve a <strong>Configuración &rarr; Clases</strong> e introduce el ID del usuario correspondiente para que aparezcan las estadísticas aquí.
                </div>
            {% else %}
                {% for branchOfficeId, studio in providerData.data %}
                    {% if studio.year.reserved > 0 or studio.monthly.reserved > 0 or studio.weekly.reserved > 0 or studio.daily.reserved > 0 %}
