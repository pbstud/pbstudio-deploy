{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            var STORAGE_KEY    = 'pbstudio_dashboard_panels';
            var DEFAULT_CLOSED = ['birthdays', 'anniversaries', 'new-user-retention'];

            // Detecta si es recarga (F5) o navegación nueva
            var isReload = false;
            try {
                var navEntries = performance.getEntriesByType('navigation');
                if (navEntries.length > 0) {
                    isReload = (navEntries[0].type === 'reload');
                } else {
                    isReload = (performance.navigation.type === 1);
                }
            } catch (e) {}

            // Detecta si venimos de un submit de filtro en esta misma página
            var hasFilterParams = /[?&](nu_date_start|nu_date_end|rating_date_start|rating_date_end)=/.test(window.location.search);

            // Guardar estado antes de cualquier submit de formulario
            $(document).on('submit', 'form', function () {
                saveState();
            });

            function getSavedState() {
                try { return JSON.parse(localStorage.getItem(STORAGE_KEY)); } catch (e) { return null; }
            }

            function saveState() {
                var state = {};
                $('.x_title--collapsible').each(function () {
                    var id = $(this).data('panel-id');
                    if (id) {
                        var $content = $(this).closest('.x_panel').find('.x_content').first();
                        state[id] = $content.is(':visible') ? 'open' : 'closed';
                    }
                });
                try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch (e) {}
            }

            function applyState($title, open) {
                var $panel   = $title.closest('.x_panel');
                var $content = $panel.find('.x_content, .x_footer');
                var $chevron = $title.find('.dash-panel-chevron');
                if (open) {
                    $content.show();
                    $chevron.css('transform', 'rotate(180deg)');
                } else {
                    $content.hide();
                    $chevron.css('transform', 'rotate(0deg)');
                }
            }

            // Si es navegación nueva sin filtros, limpiar estado guardado y usar defaults
            var savedState = null;
            if (isReload || hasFilterParams) {
                savedState = getSavedState();
            } else {
                try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
            }

            // Inicializa cada panel
            $('.x_title--collapsible').each(function () {
                var id = $(this).data('panel-id');
                var open;
                if (savedState && savedState.hasOwnProperty(id)) {
                    open = (savedState[id] === 'open');
                } else {
                    open = (DEFAULT_CLOSED.indexOf(id) === -1);
                }
                applyState($(this), open);
            });

            // Recalcular altura tras colapso inicial
            $(window).trigger('resize');

            // Toggle con animación + guardar estado + recalcular altura de right_col
            $('.x_title--collapsible').on('click', function () {
                var $panel   = $(this).closest('.x_panel');
                var $content = $panel.find('.x_content, .x_footer');
                var $chevron = $(this).find('.dash-panel-chevron');
                if ($content.is(':hidden')) {
                    $content.slideDown(200).promise().done(function () { saveState(); $(window).trigger('resize'); });
                    $chevron.css('transform', 'rotate(180deg)');
                } else {
                    $content.slideUp(200).promise().done(function () { saveState(); $(window).trigger('resize'); });
                    $chevron.css('transform', 'rotate(0deg)');
                }
            });
        });
    </script>
{% endblock %}
