}

function renderPeriods() {
  const grid = document.getElementById('period-grid');

  // Para weekly_frequency: el período de evaluación es la ventana de semanas del paso 3.
  // Se muestra como resumen fijo para evitar que el grid del paso 4 sobreescriba ese valor.
  if (state.cond === 'weekly_frequency') {
    const weeks = state.weeklyMinWeeks || state.periodWeeks;
    const customFields = document.getElementById('period-custom-fields');
    if (customFields) customFields.innerHTML = '';
    grid.innerHTML = weeks
      ? `<div style="padding:10px 14px;background:#f0f4ff;border:1px solid #c7d4f7;border-radius:8px;font-size:12px;color:#1a2340;">
           <span style="font-size:14px;">&#x23F1;</span>
           Ventana deslizante: <strong>${weeks} semana${weeks !== 1 ? 's' : ''}</strong>
           <span style="color:#8a93aa;"> — configurada en el paso anterior</span>
         </div>`
      : `<div style="padding:10px 14px;background:#fff8f0;border:1px solid #fed7aa;border-radius:8px;font-size:12px;color:#92400e;">
           ⚠️ Vuelve al paso anterior y completa las semanas de evaluación.
         </div>`;
    return;
  }

  const timeBound = isTimeBoundCondition();

  const allPeriods = [
    { key: 'sin-limite',   label: 'Sin límite',       desc: 'Sin vencimiento' },
    { key: '1-dia',        label: '1 día',            desc: '24 horas' },
    { key: '7-dias',       label: '1 semana',         desc: '7 días' },
    { key: '30-dias',      label: '1 mes',            desc: '30 días' },
    { key: 'custom-dias',    label: 'N días',           desc: 'Personalizado' },
    { key: 'custom-semanas', label: 'N semanas',        desc: 'Ventana deslizante' },
    { key: 'fecha-limite',   label: 'Antes de fecha',   desc: 'Fecha fija' },
    { key: 'ventana-fija', label: 'Ventana fija',     desc: 'Inicio – Cierre' }
  ];

  // Para condiciones con tiempo inherente solo aplican sin-limite, fecha-limite y ventana-fija
  const periods = timeBound
    ? allPeriods.filter(p => ['sin-limite', 'fecha-limite', 'ventana-fija'].includes(p.key))
    : allPeriods;

  // Si el período guardado ya no está disponible, resetear
  const availableKeys = periods.map(p => p.key);
  if (state.period && !availableKeys.includes(state.period)) {
    state.period = null;
    state.periodDays = null;
    state.periodDeadline = null;
    state.periodWindowStart = null;
    document.getElementById('period-custom-fields').innerHTML = '';
  }

  let info = '';
  if (timeBound) {
    info = `<div style="margin-bottom: 10px; padding: 8px 12px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 6px; font-size: 11px; color: #92400e;">⚠️ Esta condición ya define su propio período de tiempo. Solo puedes establecer si el logro <strong>no vence</strong> o si debe completarse <strong>antes de una fecha límite</strong>.</div>`;
  }

  let html = info;
  periods.forEach(p => {
    const isSelected = state.period === p.key;
    html += `<div class="period-card" data-period="${p.key}" style="border: 2px solid ${isSelected ? '#2a5bd7' : '#dde4f0'}; background: ${isSelected ? '#eef2ff' : 'white'}; border-radius: 10px; padding: 12px 10px; text-align: center; cursor: pointer; transition: all 0.15s;" onclick="selectPeriod(this)">
              <div style="font-size: 13px; font-weight: 700; color: #1a2340;">${p.label}</div>
              <div style="font-size: 10px; color: #8a93aa; margin-top: 3px;">${p.desc}</div>
            </div>`;
  });

  grid.innerHTML = html;
}

function selectPeriod(el) {
  document.querySelectorAll('.period-card').forEach(c => {
    c.classList.remove('selected');
    c.style.borderColor = '#dde4f0';
    c.style.background = 'white';
  });
  el.classList.add('selected');
  el.style.borderColor = '#2a5bd7';
  el.style.background = '#eef2ff';
  state.period = el.dataset.period;
  
  const customFields = document.getElementById('period-custom-fields');
  let customHtml = '';
  
  if (state.period === 'custom-dias') {
    customHtml = `<div style="margin-bottom: 12px;">
                    <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Cantidad de días</label>
                    <input type="text" id="period-days-input" placeholder="ej. 15" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px;" oninput="setPeriodDays(this.value)">
                  </div>`;
  } else if (state.period === 'custom-semanas') {
    customHtml = `<div style="margin-bottom: 12px;">
                    <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Semanas de evaluación</label>
                    <input type="text" id="period-weeks-input" placeholder="ej. 4" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px;" oninput="setPeriodWeeks(this.value)">
                    <div style="font-size: 10px; color: #8a93aa; margin-top: 4px;">Ventana deslizante: se evalúan las últimas N semanas desde hoy</div>
                  </div>`;
  } else if (state.period === 'fecha-limite') {
    customHtml = `<div style="margin-bottom: 12px;">
                    <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Fecha límite</label>
                    <input type="date" id="period-deadline-input" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto; outline: none;" oninput="setPeriodDeadline(this.value)">
                  </div>`;
  } else if (state.period === 'ventana-fija') {
    customHtml = `<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
                    <div>
                      <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Fecha de inicio</label>
                      <input type="date" id="period-window-start-input" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto; outline: none;" oninput="setPeriodWindowStart(this.value)">
                    </div>
                    <div>
                      <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Fecha de cierre</label>
                      <input type="date" id="period-deadline-input" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto; outline: none;" oninput="setPeriodDeadline(this.value)">
                    </div>
                  </div>`;
  }
  
  customFields.innerHTML = customHtml;
  updatePreview();
  checkStep4();
}

function setPeriodDays(val) {
  state.periodDays = /^\d+$/.test(val) ? parseInt(val, 10) : null;
  updatePreview();
  checkStep4();
}

function setPeriodWeeks(val) {
  state.periodWeeks = /^\d+$/.test(val) && parseInt(val, 10) > 0 ? parseInt(val, 10) : null;
  updatePreview();
  checkStep4();
}

function setWeeklyMinWeeks(val) {
  state.weeklyMinWeeks = /^\d+$/.test(val) && parseInt(val, 10) > 0 ? parseInt(val, 10) : null;
  state.periodWeeks    = state.weeklyMinWeeks;
  state.period         = state.weeklyMinWeeks ? 'custom-semanas' : null;
  updatePreview();
  checkStep3();
}

function setPeriodDeadline(val) {
  state.periodDeadline = (val || '').trim() || null;
  updatePreview();
  checkStep4();
}

function setPeriodWindowStart(val) {
  state.periodWindowStart = (val || '').trim() || null;
  updatePreview();
  checkStep4();
}

function getActiveOptionLabels() {
  const defs = [
    { key: 'notif', icon: '🔔', label: 'Notificación in-app' },
    { key: 'visible', icon: '👁', label: 'Visible en perfil' },
    { key: 'celebrar', icon: '🎉', label: 'Toast llamativo' },
    { key: 'progreso', icon: '📊', label: 'Mostrar progreso' },
    { key: 'retroactivo', icon: '📅', label: 'Contar desde creación' }
  ];

  return defs.filter(d => !!state.opts[d.key]);
}

function checkStep4() {
  const name = (document.getElementById('name-input')?.value || '').trim();
  const periodOk = !!state.period
    && (state.period !== 'custom-dias'    || !!state.periodDays)
    && (state.period !== 'custom-semanas' || !!state.periodWeeks)
    && (state.period !== 'fecha-limite'   || !!state.periodDeadline)
    && (state.period !== 'ventana-fija'   || (!!state.periodWindowStart && !!state.periodDeadline));
  const hasBtn4 = document.getElementById('btn4next');
  if (hasBtn4) {
    if (state.badge && name && periodOk) {
      hasBtn4.disabled = false;
      hasBtn4.style.opacity = '1';
      hasBtn4.style.cursor = 'pointer';
    } else {
      hasBtn4.disabled = true;
      hasBtn4.style.opacity = '0.5';
      hasBtn4.style.cursor = 'not-allowed';
    }
  }
}

function updatePreview() {
  state.name = (document.getElementById('name-input')?.value || '').trim();
  state.desc = (document.getElementById('desc-input')?.value || '').trim();
  
  const panel = document.getElementById('preview-panel');
  if (!state.cat) {
    panel.innerHTML = '<div style="font-size: 12px; color: #aab; text-align: center; padding: 24px 0;">Selecciona opciones</div>';
    updateProgressList();
    return;
  }
  
  const badgeIcon = (state.customIcon || '').trim() || badgeIcons[state.badge] || '🏆';
  const effectivePts = state.ptsManual ? (parseInt(state.customPts, 10) || 0) : (badgePts[state.badge] ?? 0);
  const condIcon = state.cond ? getConditionIcon(state.cond) : '🎯';
  const activeOptions = getActiveOptionLabels();
  const name = state.name || '(sin nombre)';
  const desc = state.desc || 'Descripción del logro';
  
  let html = `<div style="background: linear-gradient(135deg, #eef2ff 0, #f4f7ff 100%); border: 1.5px solid #c0d0f8; border-radius: 12px; padding: 16px; margin-bottom: 12px;">
              <div style="font-size: 36px; text-align: center; margin-bottom: 8px;">${badgeIcon}</div>
              <div style="font-size: 14px; font-weight: 700; color: #1a2340; text-align: center; margin-bottom: 4px;">${name}</div>
              <div style="font-size: 11px; color: #556; text-align: center; line-height: 1.4;">${desc}</div>`;
  
  if (state.badge) {
    html += `<div style="text-align: center; margin-top: 8px;"><span style="display: inline-block; background: #2a5bd7; color: white; border-radius: 12px; padding: 2px 10px; font-size: 10px; font-weight: 700;">${effectivePts} pts</span></div>`;
  }
  
  html += `</div><div>`;
  if (state.cond) html += `<div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;"><span style="color: #8a93aa;">Condición</span><span style="font-weight: 700;">${condIcon} ${condLabels[state.cond] || state.cond}</span></div>`;
  if (isDisciplineConditionActive()) {
    const scopeNames = getSelectedDisciplineNames();
    html += `<div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;"><span style="color: #8a93aa;">Disciplina${isMultiDisciplineCondition() ? 's' : ''}</span><span style="font-weight: 700;">${scopeNames.length ? scopeNames.join(', ') : '—'}</span></div>`;
    if (state.cond === 'multi_discipline_count' && state.disciplineAttendances !== null) {
      const scopeLabel = state.disciplineAttendancesScope === 'each' ? 'por disciplina' : 'en total';
      html += `<div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;"><span style="color: #8a93aa;">Clases req.</span><span style="font-weight: 700;">${state.disciplineAttendances} clase${state.disciplineAttendances !== 1 ? 's' : ''} <span style="font-weight: 400; color: #8a93aa;">(${scopeLabel})</span></span></div>`;
    }
  }
  if (isInstructorScopeCondition()) {
    const instrNames = getSelectedInstructorNames();
    html += `<div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;"><span style="color: #8a93aa;">Instructor${state.instructorIds.length !== 1 ? 'es' : ''}</span><span style="font-weight: 700;">${instrNames.length ? instrNames.join(', ') : '—'}</span></div>`;
  }
  if (isTimeSlotCondition()) {
    const slotLabels = getSelectedTimeSlotLabels();
    html += `<div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;"><span style="color: #8a93aa;">Horario${state.timeSlotIds.length !== 1 ? 's' : ''}</span><span style="font-weight: 700;">${slotLabels.length ? slotLabels.join(', ') : '—'}</span></div>`;
  }
  if (isPackageConditionActive()) {
    const pkgNames = getSelectedPackageNames();
    const pkgScopeLabel = state.packagePurchasesScope === 'each' ? 'por paquete' : 'en total';
    html += `<div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;"><span style="color: #8a93aa;">Paquete${state.packageIds.length !== 1 ? 's' : ''}</span><span style="font-weight: 700; max-width: 60%; text-align: right;">${pkgNames.length ? pkgNames.join(', ') : '<span style=\'color:#e54\'>Sin seleccionar</span>'}${state.threshold ? ' <span style="font-weight:400;color:#8a93aa;font-size:10px;">(${pkgScopeLabel})</span>' : ''}</span></div>`;
  }
  if (state.threshold) html += `<div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;"><span style="color: #8a93aa;">Umbral</span><span style="font-weight: 700;">${state.threshold}</span></div>`;
  if (state.period) {
    let periodLabel = state.period;
    if (state.period === 'custom-dias' && state.periodDays) {
      periodLabel = state.periodDays + ' días';
    } else if (state.period === 'custom-semanas' && state.periodWeeks) {
      periodLabel = state.periodWeeks + (state.periodWeeks === 1 ? ' semana' : ' semanas');
    } else if (state.period === 'fecha-limite' && state.periodDeadline) {
      periodLabel = 'Antes de ' + state.periodDeadline;
    } else if (state.period === 'ventana-fija') {
      periodLabel = (state.periodWindowStart || '—') + ' → ' + (state.periodDeadline || '—');
    }
    html += `<div style="display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px;"><span style="color: #8a93aa;">Período</span><span style="font-weight: 700;">${periodLabel}</span></div>`;
  }
  if (state.opts.celebrar) { const toastMsg = (state.desc || '').trim(); html += `<div style="font-size: 10px; color: #2d3b66; margin: 8px 0 0; padding: 6px 8px; border: 1px solid #b8cbff; border-radius: 8px; background: #eef4ff;"><strong style="font-size: 10px; color: #2a5bd7;">Toast:</strong> ¡Logro desbloqueado! ${state.name || '(nombre)'}${toastMsg ? ' · <em>' + toastMsg + '</em>' : ''}</div>`; }
  if (state.opts.progreso) html += `<div style="margin-top: 8px;"><div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 4px;"><span style="font-size: 10px; color: #6b7280; font-weight:600; letter-spacing:.3px;">TU PROGRESO</span><span style="font-size: 10px; color: #2a5bd7; font-weight:700;">35 / 100</span></div><div style="height: 7px; border-radius: 999px; background: #e8edfc; overflow:hidden;"><div style="width: 35%; height: 7px; border-radius: 999px; background: linear-gradient(90deg,#4a7de8,#2a5bd7);"></div></div><div style="font-size: 10px; color: #9ca3af; margin-top: 4px;">35% completado</div></div>`;
  html += `<div style="margin-top: 8px;"><div style="font-size: 10px; font-weight: 700; color: #8a93aa; margin-bottom: 4px;">Opciones activas</div><div style="display: flex; flex-wrap: wrap; gap: 6px;">${activeOptions.length ? activeOptions.map(o => `<span style=\"font-size: 10px; border: 1px solid #d5deef; background: #f7f9ff; color: #2d3b66; border-radius: 999px; padding: 2px 8px;\">${o.icon} ${o.label}</span>`).join('') : '<span style=\"font-size: 10px; color: #aab;\">—</span>'}</div></div>`;
  html += `</div>`;
  
  panel.innerHTML = html;
  updateProgressList();
}

function updateProgressList() {
  const items = [
    { key: state.cat, label: `Categoría: ${state.cat ? categoryMeta[state.cat].label : '—'}` },
    { key: state.cond, label: `Condición: ${state.cond ? condLabels[state.cond] : '—'}` },
    ...(isPackageConditionActive() ? [{ key: state.packageIds.length ? 'ok' : '', label: `Paquetes: ${state.packageIds.length ? getSelectedPackageNames().join(', ') : '—'}` }] : []),
    { key: state.threshold, label: `Umbral: ${state.threshold ? state.threshold : '—'}` },
    { key: state.badge, label: `Nivel: ${state.badge ? badgeLabels[state.badge] : '—'}` },
    { key: state.period, label: `Período: ${state.period ? state.period : '—'}` },
    { key: state.name, label: `Nombre: ${state.name ? state.name : '—'}` }
  ];
  
  document.getElementById('progress-list').innerHTML = items.map(i => 
    `<div style="${i.key ? 'color: #22a66a;' : ''}">${i.key ? '✓' : '○'} ${i.label}</div>`
  ).join('');
}

function buildReview() {
  const finalName = state.name || '(Sin nombre)';
  const finalDesc = state.desc || 'Descripción del logro';
  const icon = (state.customIcon || '').trim() || badgeIcons[state.badge] || '🏆';
  const effectivePts = state.ptsManual ? (parseInt(state.customPts, 10) || 0) : (badgePts[state.badge] ?? 0);
  const condIcon = state.cond ? getConditionIcon(state.cond) : '🎯';
  const activeOptions = getActiveOptionLabels();
  const scopeNames = getSelectedDisciplineNames();
  const diffLabels = { easy: '🟢 Fácil', medium: '🟡 Media', hard: '🟠 Difícil', expert: '🔴 Experto' };
  
  let html = `<div style="display: flex; gap: 12px; align-items: flex-start; flex-wrap: wrap; margin-bottom: 20px;">
              <div style="font-size: 48px; line-height: 1;">${icon}</div>
              <div style="flex: 1; min-width: 200px;">
                <div style="font-size: 16px; font-weight: 700; margin-bottom: 4px;">${finalName}</div>
                <div style="font-size: 12px; color: #556; margin-bottom: 8px;">${finalDesc}</div>
              </div>
            </div>
            <table style="width: 100%; margin-top: 16px; font-size: 12px; border-collapse: collapse;">
              <tr style="border-bottom: 1px solid #eef;">
                <td style="padding: 6px 0; color: #8a93aa;">Categoría</td>
                <td style="padding: 6px 0; font-weight: 700;">${state.cat ? categoryMeta[state.cat].label : '—'}</td>
              </tr>
              <tr style="border-bottom: 1px solid #eef;">
                <td style="padding: 6px 0; color: #8a93aa;">Condición</td>
                <td style="padding: 6px 0; font-weight: 700;">${state.cond ? (condIcon + ' ' + condLabels[state.cond]) : '—'}</td>
              </tr>
              <tr style="border-bottom: 1px solid #eef;">
                <td style="padding: 6px 0; color: #8a93aa;">Umbral</td>
                <td style="padding: 6px 0; font-weight: 700;">${state.threshold || '—'}</td>
              </tr>
              ${isDisciplineConditionActive() ? `<tr style="border-bottom: 1px solid #eef;"><td style="padding: 6px 0; color: #8a93aa;">Disciplina${isMultiDisciplineCondition() ? 's' : ''}</td><td style="padding: 6px 0; font-weight: 700;">${scopeNames.length ? scopeNames.join(', ') : '—'}</td></tr>` : ''}
              ${state.cond === 'multi_discipline_count' && state.disciplineAttendances !== null ? `<tr style="border-bottom: 1px solid #eef;"><td style="padding: 6px 0; color: #8a93aa;">Clases req.</td><td style="padding: 6px 0; font-weight: 700;">${state.disciplineAttendances} clase${state.disciplineAttendances !== 1 ? 's' : ''} <span style="font-weight: 400; color: #8a93aa;">(${state.disciplineAttendancesScope === 'each' ? 'por disciplina' : 'en total'})</span></td></tr>` : ''}
              ${isInstructorScopeCondition() ? `<tr style="border-bottom: 1px solid #eef;"><td style="padding: 6px 0; color: #8a93aa;">Instructor${state.instructorIds.length !== 1 ? 'es' : ''}</td><td style="padding: 6px 0; font-weight: 700;">${getSelectedInstructorNames().join(', ') || '—'}</td></tr>` : ''}
              ${isTimeSlotCondition() ? `<tr style="border-bottom: 1px solid #eef;"><td style="padding: 6px 0; color: #8a93aa;">Horario${state.timeSlotIds.length !== 1 ? 's' : ''}</td><td style="padding: 6px 0; font-weight: 700;">${getSelectedTimeSlotLabels().join(', ') || '—'}</td></tr>` : ''}
              ${isPackageConditionActive() ? `<tr style="border-bottom: 1px solid #eef;"><td style="padding: 6px 0; color: #8a93aa;">Paquete${state.packageIds.length !== 1 ? 's' : ''}</td><td style="padding: 6px 0; font-weight: 700;">${getSelectedPackageNames().join(', ') || '—'} <span style="font-weight: 400; color: #8a93aa;">(${state.packagePurchasesScope === 'each' ? 'por paquete' : 'en total'})</span></td></tr>` : ''}
              <tr style="border-bottom: 1px solid #eef;">
                <td style="padding: 6px 0; color: #8a93aa;">Período</td>
                <td style="padding: 6px 0; font-weight: 700;">${(() => {
                  if (!state.period) return '—';
                  if (state.period === 'custom-dias' && state.periodDays) return state.periodDays + ' días';
                  if (state.period === 'custom-semanas' && state.periodWeeks) return state.periodWeeks + (state.periodWeeks === 1 ? ' semana' : ' semanas');
                  if (state.period === 'fecha-limite' && state.periodDeadline) return 'Antes de ' + state.periodDeadline;
                  return state.period;
                })()}</td>
              </tr>
              <tr style="border-bottom: 1px solid #eef;">
                <td style="padding: 6px 0; color: #8a93aa;">Nivel / Puntos</td>
                <td style="padding: 6px 0; font-weight: 700;">${(state.customIcon||badgeIcons[state.badge]||'')} ${state.customLabel || (badgeLabels[state.badge]||'').replace(/^\S+\s/,'') || '—'} &mdash; ${effectivePts} pts</td>
              </tr>
              <tr style="border-bottom: 1px solid #eef;">
                <td style="padding: 6px 0; color: #8a93aa;">Opciones activas</td>
                <td style="padding: 6px 0; font-weight: 700;">${activeOptions.length ? activeOptions.map(o => o.icon + ' ' + o.label).join(' · ') : '—'}</td>
              </tr>
              ${state.difficulty ? `<tr style="border-bottom: 1px solid #eef;"><td style="padding: 6px 0; color: #8a93aa;">${state.cond === 'challenges_completed' ? 'Filtro dificultad' : 'Reto — Dificultad'}</td><td style="padding: 6px 0; font-weight: 700;">${diffLabels[state.difficulty] || state.difficulty}</td></tr>` : ''}
              <tr>
                <td style="padding: 6px 0; color: #8a93aa;">Estado</td>
                <td style="padding: 6px 0; font-weight: 700;">${state.active ? '🟢 Activo' : '⚫ Inactivo'}</td>
              </tr>
            </table>`;
  
  document.getElementById('review-content').innerHTML = html;
}

function renderStep5Flags() {
  const btnA = document.getElementById('btn-flag-active');
  if (btnA) {
    btnA.textContent = state.active ? '🟢 Activo' : '⚫ Inactivo';
    btnA.style.background = state.active ? '#e8faf2' : '#f5f5f5';
    btnA.style.color = state.active ? '#22a66a' : '#888';
    btnA.style.borderColor = state.active ? '#22a66a' : '#ccc';
  }
}

function toggleStep5Flag(key) {
  if (key === 'active') {
    state.active = !state.active;
  }
  renderStep5Flags();
  buildReview();
}

function saveLogro() {
  // --- Badge level: string key directamente desde state.badge ---
  document.getElementById('hidden-badge').value = state.badge || '';
  const effectiveIcon = (state.customIcon || '').trim() || badgeIcons[state.badge] || '';
  document.getElementById('hidden-badge-icon').value = effectiveIcon;
  const effectiveLabel = (state.customLabel || '').trim() || (badgeLabels[state.badge] || '').replace(/^\S+\s/, '') || '';
  document.getElementById('hidden-badge-label').value = effectiveLabel;
  const effectivePts = state.ptsManual ? (parseInt(state.customPts, 10) || 0) : (badgePts[state.badge] ?? 0);
  document.getElementById('hidden-badge-pts').value = String(effectivePts);
  document.getElementById('hidden-badge-color').value = '';

  // --- Categoría y condición ---
  document.getElementById('hidden-cat').value = state.cat;
  document.getElementById('hidden-cond').value = state.cond;

  // --- thresholdType desde catálogo ---
  const condData = (conditionsByCategory[state.cat] || []).find(c => c.conditionKey === state.cond);
  document.getElementById('hidden-threshold-type').value = condData ? condData.thresholdType : 'count';
  document.getElementById('hidden-threshold').value = state.threshold;

  // --- Contexto (disciplinas / instructores / horarios / paquetes) ---
  const contextPayload = isDisciplineConditionActive() && state.disciplineIds.length
    ? {
        disciplineIds: state.disciplineIds,
        includeIndividual: state.disciplineIds.includes(INDIVIDUAL_DISCIPLINE_ID),
        ...(state.cond === 'multi_discipline_count' && state.disciplineAttendances !== null
          ? { attendancesRequired: state.disciplineAttendances, attendancesScope: state.disciplineAttendancesScope }
          : {})
      }
    : isInstructorScopeCondition() && state.instructorIds.length
      ? { instructorIds: state.instructorIds }
      : isTimeSlotCondition() && state.timeSlotIds.length
        ? { timeSlotIds: state.timeSlotIds }
        : isPackageConditionActive() && state.packageIds.length
          ? { packageIds: state.packageIds, packagePurchasesScope: state.packagePurchasesScope }
          : null;
  document.getElementById('hidden-condition-context').value = contextPayload ? JSON.stringify(contextPayload) : '';

  // --- Nombre y descripción ---
  document.getElementById('hidden-name').value = state.name;
  document.getElementById('hidden-desc').value = state.desc;
  // --- Dificultad (reto) ---
  document.getElementById('hidden-difficulty').value = state.difficulty || '';

  // --- Período: mapear claves del wizard a valores de la entidad ---
  let periodType = 'none', periodDays = '', periodDeadline = '';
  if (state.period === '1-dia')              { periodType = 'days'; periodDays = '1'; }
  else if (state.period === '7-dias')        { periodType = 'days'; periodDays = '7'; }
  else if (state.period === '30-dias')       { periodType = 'days'; periodDays = '30'; }
  else if (state.period === 'custom-dias')   { periodType = 'days'; periodDays = String(state.periodDays || ''); }
  else if (state.period === 'custom-semanas') { periodType = 'days'; periodDays = String((state.periodWeeks || 0) * 7); }
  else if (state.period === 'fecha-limite') {
    periodType = 'deadline';
    if (state.periodDeadline) {
      // HTML5 date input entrega YYYY-MM-DD; el form espera dd/MM/yyyy
      const [y, m, d] = state.periodDeadline.split('-');
      periodDeadline = `${d}/${m}/${y}`;
    }
  } else if (state.period === 'ventana-fija') {
    periodType = 'window';
    if (state.periodDeadline) {
      const [y, m, d] = state.periodDeadline.split('-');
      periodDeadline = `${d}/${m}/${y}`;
    }
  }
  let periodWindowStart = '';
  if (state.period === 'ventana-fija' && state.periodWindowStart) {
    const [y, m, d] = state.periodWindowStart.split('-');
    periodWindowStart = `${d}/${m}/${y}`;
  }
  // 'sin-limite' y null → 'none' (ya inicializado arriba)
  document.getElementById('hidden-period').value = periodType;
  document.getElementById('hidden-period-days').value = periodDays;
  document.getElementById('hidden-period-deadline').value = periodDeadline;
  document.getElementById('hidden-period-window-start').value = periodWindowStart;

  // --- Booleanos: deshabilitar el input cuando es false (ausencia = false en CheckboxType) ---
  document.getElementById('hidden-opts-notif').disabled   = !state.opts.notif;
  document.getElementById('hidden-opts-visible').disabled = !state.opts.visible;
  document.getElementById('hidden-opts-celebrar').disabled = !state.opts.celebrar;
  document.getElementById('hidden-opts-progreso').disabled = !state.opts.progreso;
  document.getElementById('hidden-opts-retroactivo').disabled = !state.opts.retroactivo;
  // Active: se envía siempre como valor 1 o 0
  document.getElementById('hidden-active').value = state.active ? '1' : '0';

  // Submitear el formulario
  document.getElementById('achievementForm').submit();
}

document.addEventListener('DOMContentLoaded', function() {
  // Attach category card click handlers
  document.querySelectorAll('.cat-card').forEach(card => {
    card.addEventListener('mouseenter', function() {
      if (!this.classList.contains('selected')) {
        this.style.borderColor = '#7fa4f5';
        this.style.background = '#f4f7ff';
      }
    });
    card.addEventListener('mouseleave', function() {
      if (!this.classList.contains('selected')) {
        this.style.borderColor = '#dde4f0';
        this.style.background = 'white';
      }
    });
    card.addEventListener('click', function() { selectCat(this); });
  });

  // Hover effects for other cards
  document.addEventListener('mouseenter', function(e) {
    const cl = e.target?.classList;
    if (cl && (cl.contains('threshold-card') || cl.contains('cond-chip') || cl.contains('period-card')) && !cl.contains('selected')) {
      e.target.style.borderColor = '#7fa4f5';
      e.target.style.background = '#f4f7ff';
    }
  }, true);

  document.addEventListener('mouseleave', function(e) {
    const cl = e.target?.classList;
    if (cl && (cl.contains('threshold-card') || cl.contains('cond-chip') || cl.contains('period-card')) && !cl.contains('selected')) {
      e.target.style.borderColor = '#dde4f0';
      e.target.style.background = 'white';
    }
  }, true);

  renderBadges();
  renderOptions();
  document.querySelectorAll('.opt-chip').forEach(el => {
    const key = el.dataset.opt;
    setOptChipVisual(el, !!state.opts[key]);
  });
  renderPeriods();
  updatePreview();

{% if isEditMode is defined and isEditMode %}
  // ── MODO EDICIÓN: pre-cargar estado del logro existente ──────────────────
  (function initEditMode() {
    const init = {{ preloadData|json_encode|raw }};

    // Aplicar estado al objeto state
    state.cat           = init.cat;
    state.cond          = init.cond;
    state.threshold     = init.threshold;
    state.badge         = init.badge;
    // Icono, nombre y puntos: solo marcar como "manual" si difieren del default del nivel
    // (saveLogro siempre guarda el valor efectivo, incluyendo defaults, así que no se puede
    // asumir que todo valor guardado fue editado manualmente por el usuario)
    const _defaultIcon  = badgeIcons[init.badge] || '';
    const _defaultLabel = (badgeLabels[init.badge] || '').replace(/^\S+\s/, '');
    const _defaultPts   = badgePts[init.badge] ?? 0;

    if (init.customIcon && init.customIcon !== _defaultIcon) {
      state.customIcon = init.customIcon;
      state.iconManual = true;
      const iconInput = document.getElementById('badge-icon-input');
      if (iconInput) iconInput.value = init.customIcon;
    }
    if (init.customLabel && init.customLabel !== _defaultLabel) {
      state.customLabel = init.customLabel;
      state.labelManual = true;
      const labelInput = document.getElementById('badge-label-input');
      if (labelInput) labelInput.value = init.customLabel;
    }
    if (init.customPts !== '' && Number(init.customPts) !== _defaultPts) {
      state.customPts = String(init.customPts);
      state.ptsManual = true;
      const ptsInput = document.getElementById('badge-pts-input');
      if (ptsInput) ptsInput.value = init.customPts;
    }
    state.name          = init.name || '';
    state.desc          = init.desc || '';
    state.period          = init.period;
    state.periodDays      = init.period === 'custom-semanas' ? null : init.periodDays;
    state.periodWeeks     = init.period === 'custom-semanas' ? init.periodDays : null;
    state.weeklyMinWeeks  = (init.period === 'custom-semanas' && init.cond === 'weekly_frequency') ? init.periodDays : null;
    state.periodDeadline  = init.periodDeadline;
    state.periodWindowStart = init.periodWindowStart || null;
    state.disciplineIds = init.disciplineIds || [];
    state.disciplineAttendances = init.disciplineAttendances ?? null;
    state.disciplineAttendancesScope = init.disciplineAttendancesScope || 'total';
    state.instructorIds = init.instructorIds || [];
    state.timeSlotIds   = init.timeSlotIds || [];
    // Reconstruir customTimeSlots: valores guardados que no son horarios predefinidos
    const _predefinedSlotValues = new Set(timeSlots.map(s => s.value));
    state.customTimeSlots = (init.timeSlotIds || [])
      .filter(v => !_predefinedSlotValues.has(v))
      .map(v => ({ value: v }));
    state.packageIds    = init.packageIds || [];
    state.packagePurchasesScope = init.packagePurchasesScope || 'total';
    state.difficulty    = init.difficulty || null;
    state.active        = init.active !== undefined ? !!init.active : true;
    state.opts = Object.assign(state.opts, init.opts || {});

    // Seleccionar visualmente la tarjeta de categoría (ya está en el DOM)
    const catCard = document.querySelector(`.cat-card[data-cat="${init.cat}"]`);
    if (catCard) {
      catCard.classList.add('selected');
      catCard.style.borderColor = '#2a5bd7';
      catCard.style.background = '#eef2ff';
    }

    // Renderizar condiciones para la categoría y seleccionar la correcta
    renderConditions();
    const condChip = document.querySelector(`.cond-chip[data-cond="${init.cond}"]`);
    if (condChip) {
      condChip.classList.add('selected');
      condChip.style.borderColor = '#2a5bd7';
      condChip.style.background = '#eef2ff';
      condChip.style.color = '#1a2340';
    }

    // Si es disciplina (no multi) renderizar el picker de disciplinas en paso 2
    if (init.cat === 'disciplina' && init.cond && init.cond !== 'multi_discipline_count') {
      renderDisciplineInStep2();
    }
    // Si es paquete específico renderizar el picker de paquetes en paso 2
    if (init.cat === 'compras' && init.cond === 'specific_package_count') {
      renderPackageInStep2();
    }

    // Renderizar umbrales (incluye pickers de disciplinas/instructores/horarios si aplica)
    renderThresholds();

    // Seleccionar visualmente la tarjeta de umbral
    const threshCard = document.querySelector(`.threshold-card[data-val="${init.threshold}"]`);
    if (threshCard) {
      threshCard.classList.add('selected');
      threshCard.style.borderColor = '#2a5bd7';
      threshCard.style.background = '#eef2ff';
    }

    // Restaurar campo de semanas mínimas para weekly_frequency
    if (init.cond === 'weekly_frequency' && state.weeklyMinWeeks) {
      const extraFields = document.getElementById('threshold-extra-fields');
      if (extraFields) {
        extraFields.innerHTML = `<div style="margin-top:12px;padding:10px 12px;background:#f6f8ff;border:1px solid #dde4f0;border-radius:8px;">
          <label style="font-size:11px;font-weight:700;color:#2a5bd7;margin-bottom:4px;display:block;">Semanas de evaluación</label>
          <p style="font-size:10px;color:#8a93aa;margin:0 0 6px;">Mínimo de semanas que debe mantener este promedio semanal</p>
          <input type="number" id="weekly-min-weeks-input" placeholder="ej. 4" min="1" max="52"
            style="width:100%;border:1.5px solid #dde4f0;border-radius:6px;padding:8px 10px;font-size:13px;outline:none;"
            oninput="setWeeklyMinWeeks(this.value)">
        </div>`;
        const inp = document.getElementById('weekly-min-weeks-input');
        if (inp) inp.value = state.weeklyMinWeeks;
      }
    }

    // Rellenar nombre y descripción
    const nameInput = document.getElementById('name-input');
    const descInput = document.getElementById('desc-input');
    if (nameInput) nameInput.value = init.name || '';
    if (descInput) descInput.value = init.desc || '';

    // Seleccionar visualmente el badge (renderBadges ya fue llamado arriba)
    const badgeCard = document.querySelector(`.badge-card[data-badge="${init.badge}"]`);
    if (badgeCard) selectBadge(badgeCard);

    // Aplicar visual de opciones (renderOptions ya fue llamado arriba)
    document.querySelectorAll('.opt-chip').forEach(el => {
      const key = el.dataset.opt;
      setOptChipVisual(el, !!state.opts[key]);
    });

    // Renderizar períodos con estado pre-cargado (renderPeriods usa state.period para el selected)
    renderPeriods();

    // Si hay campos personalizados de período, rellenarlos
    _restoreCustomPeriodFields();

    // Habilitar botones de "Siguiente" para cada paso (en modo edición el estado ya está completo)
    checkStep2();
    checkStep3();
    // checkStep4 ya es llamado por selectBadge arriba

    // Ir directamente a la revisión (paso 5)
    goStep(5);
  })();

  // Sobreescribir goStep para restaurar campos personalizados de período al volver al paso 4
  const _origGoStep = goStep;
  goStep = function(n) {
    _origGoStep(n);
    if (n === 4) _restoreCustomPeriodFields();
  };

  function _restoreCustomPeriodFields() {
    if (!state.period) return;
    const customFields = document.getElementById('period-custom-fields');
    if (!customFields) return;

    if (state.period === 'custom-dias' && state.periodDays) {
      if (!document.getElementById('period-days-input')) {
        customFields.innerHTML = `<div style="margin-bottom:12px;"><label style="font-size:11px;font-weight:700;color:#556;margin-bottom:4px;display:block;">Cantidad de días</label><input type="text" id="period-days-input" placeholder="ej. 15" style="width:100%;border:1.5px solid #dde4f0;border-radius:6px;padding:8px 10px;font-size:13px;" oninput="setPeriodDays(this.value)"></div>`;
      }
      const inp = document.getElementById('period-days-input');
      if (inp) inp.value = state.periodDays;
    } else if (state.period === 'custom-semanas' && state.periodWeeks) {
      if (!document.getElementById('period-weeks-input')) {
        customFields.innerHTML = `<div style="margin-bottom:12px;"><label style="font-size:11px;font-weight:700;color:#556;margin-bottom:4px;display:block;">Semanas de evaluación</label><input type="text" id="period-weeks-input" placeholder="ej. 4" style="width:100%;border:1.5px solid #dde4f0;border-radius:6px;padding:8px 10px;font-size:13px;" oninput="setPeriodWeeks(this.value)"><div style="font-size:10px;color:#8a93aa;margin-top:4px;">Ventana deslizante: se evalúan las últimas N semanas desde hoy</div></div>`;
      }
      const inp = document.getElementById('period-weeks-input');
      if (inp) inp.value = state.periodWeeks;
    } else if (state.period === 'fecha-limite' && state.periodDeadline) {
      if (!document.getElementById('period-deadline-input')) {
        customFields.innerHTML = `<div style="margin-bottom:12px;"><label style="font-size:11px;font-weight:700;color:#556;margin-bottom:4px;display:block;">Fecha límite</label><input type="date" id="period-deadline-input" style="width:100%;border:1.5px solid #dde4f0;border-radius:6px;padding:8px 10px;font-size:13px;" oninput="setPeriodDeadline(this.value)"></div>`;
      }
      const inp = document.getElementById('period-deadline-input');
      if (inp) inp.value = state.periodDeadline; // YYYY-MM-DD
    } else if (state.period === 'ventana-fija') {
      if (!document.getElementById('period-window-start-input')) {
        customFields.innerHTML = `<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
          <div>
            <label style="font-size:11px;font-weight:700;color:#556;margin-bottom:4px;display:block;">Fecha de inicio</label>
            <input type="date" id="period-window-start-input" style="width:100%;border:1.5px solid #dde4f0;border-radius:6px;padding:8px 10px;font-size:13px;" oninput="setPeriodWindowStart(this.value)">
          </div>
          <div>
            <label style="font-size:11px;font-weight:700;color:#556;margin-bottom:4px;display:block;">Fecha de cierre</label>
            <input type="date" id="period-deadline-input" style="width:100%;border:1.5px solid #dde4f0;border-radius:6px;padding:8px 10px;font-size:13px;" oninput="setPeriodDeadline(this.value)">
          </div>
        </div>`;
      }
      const startInp = document.getElementById('period-window-start-input');
      if (startInp && state.periodWindowStart) startInp.value = state.periodWindowStart; // YYYY-MM-DD
      const endInp = document.getElementById('period-deadline-input');
      if (endInp && state.periodDeadline) endInp.value = state.periodDeadline; // YYYY-MM-DD
    }
  }
{% endif %}
});
</script>

