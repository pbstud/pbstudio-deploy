{% extends 'backend/layout.html.twig' %}

{% block title %}{% if isEditMode is defined and isEditMode %}Editar Logro{% else %}Crear Logro - Wizard{% endif %}{% endblock %}

{% block section %}
<div class="row">
  <div class="col-md-12">
    <div class="x_panel">
      <div class="x_title">
        <h2>{% if isEditMode is defined and isEditMode %}Editar Logro{% else %}Nuevo Logro{% endif %}</h2>
        {% if isEditMode is defined and isEditMode %}
        <ul class="nav navbar-right panel_toolbox">
          <li>
            <form method="post" action="{{ path('backend_achievement_delete', {'id': achievement.id}) }}"
              onsubmit="return confirm('Esta acción eliminará el logro de forma permanente. ¿Deseas continuar?');">
              <input type="hidden" name="_token" value="{{ csrf_token('delete_achievement_' ~ achievement.id) }}">
              <button type="submit" class="btn btn-danger btn-sm" style="margin-top:2px;">
                <i class="fa fa-trash-o" aria-hidden="true"></i> Eliminar logro
              </button>
            </form>
          </li>
        </ul>
        {% endif %}
        <div class="clearfix"></div>
      </div>

      <div class="x_content">
        <div class="wizard-layout-row row" style="margin: 0 -15px; background: #f0f2f7; padding: 24px 0;">
          <div class="col-lg-8 col-md-7 wizard-main-col" style="padding-left: 24px; padding-right: 12px;">
            <div class="wizard-main-card" style="background: white; border-radius: 10px; padding: 24px;">
              <!-- HEADER -->
              <p style="font-size: 12px; color: #8a93aa; margin: 0 0 20px;">Configura las condiciones y recompensas del logro paso a paso</p>

              <!-- STEPPER -->
              <div style="display: flex; align-items: center; margin-bottom: 24px; flex-wrap: wrap;">
                {% for i in 1..5 %}
                  <div style="display: flex; align-items: center;">
                    <div class="step-circle" id="sc{{ i }}" style="width: 28px; height: 28px; border-radius: 50%; border: 2px solid #c8d0e0; background: white; color: #aab; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; {% if i == 1 %}border-color: #2a5bd7; background: #2a5bd7; color: white;{% endif %}">{{ i }}</div>
                    <span class="step-label" style="font-size: 10px; margin-left: 6px; white-space: nowrap; {% if i == 1 %}color: #2a5bd7; font-weight: 700;{% else %}color: #9aa;{% endif %}" id="sl{{ i }}">
                      {% if i == 1 %}Categoría{% elseif i == 2 %}Condición{% elseif i == 3 %}Umbral{% elseif i == 4 %}Recompensa{% else %}Revisar{% endif %}
                    </span>
                  </div>
                  {% if i < 5 %}<div class="step-line" id="line{{ i }}" style="flex: 1; min-width: 10px; height: 2px; background: #dde4f0; margin: 0 8px;"></div>{% endif %}
                {% endfor %}
              </div>

              <!-- PASO 1: CATEGORÍA -->
              <div class="step-section visible" id="step1">
                <div style="background: white; border: 1px solid #dde4f0; border-radius: 10px; padding: 14px 16px; margin-bottom: 14px;">
                  <div style="font-size: 13px; font-weight: 700; color: #1a2340; margin: 0 0 12px; border-bottom: 1px solid #eef; padding-bottom: 8px;">¿Qué tipo de logro quieres crear?</div>
                  <p style="font-size: 11px; color: #8a93aa; margin: 0 0 10px;">La categoría define sobre qué actividad se mide el logro</p>
                  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(148px, 1fr)); gap: 10px; margin-bottom: 16px;">
                    {% set categoryMeta = {
                      'asistencia': {'emoji': '🏋️', 'label': 'Asistencia', 'desc': 'Clases asistidas en el studio'},
                      'compras': {'emoji': '💳', 'label': 'Compras', 'desc': 'Transacciones o monto gastado'},
                      'antiguedad': {'emoji': '📅', 'label': 'Antigüedad', 'desc': 'Tiempo siendo cliente activo'},
                      'racha': {'emoji': '🔥', 'label': 'Racha', 'desc': 'Semanas o meses sin faltar'},
                      'disciplina': {'emoji': '⭐', 'label': 'Por Disciplina', 'desc': 'Clases de un tipo específico'},
                      'calificacion': {'emoji': '🌟', 'label': 'Calificación', 'desc': 'Promedio o cantidad de 5★'},
                      'instructor': {'emoji': '🤵', 'label': 'Instructor', 'desc': 'Relación y fidelidad con los instructores'},
                      'comunidad': {'emoji': '🤝', 'label': 'Comunidad', 'desc': 'Referidos y participación en retos'},
                      'habitos': {'emoji': '⏰', 'label': 'Hábitos', 'desc': 'Rutinas de asistencia específicas'}
                    } %}
                    {% for catKey, meta in categoryMeta %}
                      <div class="cat-card" data-cat="{{ catKey }}" style="border: 2px solid #dde4f0; background: white; border-radius: 10px; padding: 14px 12px; text-align: center; cursor: pointer; transition: all 0.15s;">
                        <span style="font-size: 26px; margin-bottom: 6px; display: block;">{{ meta.emoji }}</span>
                        <div style="font-size: 12px; font-weight: 700; color: #1a2340;">{{ meta.label }}</div>
                        <div style="font-size: 10px; color: #8a93aa; margin-top: 3px; line-height: 1.3;">{{ meta.desc }}</div>
                      </div>
                    {% endfor %}
                  </div>
                </div>
              </div>

              <!-- PASO 2: CONDICIÓN -->
              <div class="step-section" id="step2">
                <div style="background: white; border: 1px solid #dde4f0; border-radius: 10px; padding: 14px 16px; margin-bottom: 14px;">
                  <div style="font-size: 13px; font-weight: 700; color: #1a2340; margin: 0 0 12px; border-bottom: 1px solid #eef; padding-bottom: 8px;">Elige la condición</div>
                  <div id="cond-container"></div>
                  <div id="discipline-picker-step2"></div>
                  <div id="package-picker-step2"></div>
                </div>
                <div style="display: flex; justify-content: space-between; margin-top: 8px;">
                  <button class="btn-back" style="background: #f0f2f7; color: #556; padding: 9px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; border: none;" onclick="goStep(1)">← Atrás</button>
                  <button id="btn2next" style="display:none; background: #2a5bd7; color: white; padding: 9px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; border: none; opacity: 0.5; cursor: not-allowed;" disabled onclick="advanceFromStep2()">Siguiente →</button>
                </div>
              </div>

              <!-- PASO 3: UMBRAL -->
              <div class="step-section" id="step3">
                <div style="background: white; border: 1px solid #dde4f0; border-radius: 10px; padding: 14px 16px; margin-bottom: 14px;">
                  <div style="font-size: 13px; font-weight: 700; color: #1a2340; margin: 0 0 12px; border-bottom: 1px solid #eef; padding-bottom: 8px;">Define el umbral</div>
                  <p style="font-size: 11px; color: #8a93aa; margin: 0 0 10px;">Selecciona el valor objetivo que el usuario debe alcanzar</p>
                  <div id="threshold-container"></div>
                  <div id="threshold-extra-fields"></div>
                </div>
                <div style="display: flex; justify-content: space-between; margin-top: 8px;"><button class="btn-back" style="background: #f0f2f7; color: #556; padding: 9px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; border: none;" onclick="backToStep2()">← Atrás</button><button class="btn-next" id="btn3next" style="background: #2a5bd7; color: white; padding: 9px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; opacity: 0.5; cursor: not-allowed;" disabled onclick="goStep(4)">Siguiente →</button></div>
              </div>

              <!-- PASO 4: RECOMPENSA -->
              <div class="step-section" id="step4">
                <div style="background: white; border: 1px solid #dde4f0; border-radius: 10px; padding: 14px 16px; margin-bottom: 14px;">
                  <div style="font-size: 13px; font-weight: 700; color: #1a2340; margin: 0 0 12px; border-bottom: 1px solid #eef; padding-bottom: 8px;">Configura la recompensa</div>
                  
                  <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin: 0 0 8px;">Nivel del logro</p>
                  <div id="badge-grid" style="display: block; margin-bottom: 12px;"></div>

                  <div style="display: flex; gap: 10px; margin-bottom: 16px;">
                    <div style="flex: 0 0 80px;">
                      <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Icono</label>
                      <input type="text" id="badge-icon-input" placeholder="🏆" maxlength="8" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 6px; font-size: 20px; text-align: center; outline: none;" oninput="onCustomIconInput()">
                    </div>
                    <div style="flex: 1;">
                      <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Nombre del nivel <span style="font-weight: 400; color: #aab;">(opcional)</span></label>
                      <input type="text" id="badge-label-input" placeholder="ej. Platino" maxlength="32" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px; outline: none;" oninput="onCustomLabelInput()">
                    </div>
                    <div style="flex: 0 0 110px;">
                      <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Puntos <span style="font-weight: 400; color: #aab;">(ó vacío)</span></label>
                      <input type="number" id="badge-pts-input" placeholder="500" min="0" step="1" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px; outline: none;" oninput="onCustomPtsInput()">
                    </div>
                  </div>

                  <div style="margin-bottom: 12px;">
                    <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Nombre del logro</label>
                    <input type="text" id="name-input" placeholder="ej. Guerrero del Studio" style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px; outline: none;" oninput="updatePreview(); checkStep4();">
                  </div>

                  <div style="margin-bottom: 12px;">
                    <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 4px; display: block;">Mensaje al desbloquear <span style="font-weight: 400; color: #aab;">(opcional)</span></label>
                    <textarea id="desc-input" placeholder="ej. ¡Has asistido a 50 clases! Tu dedicación es inspiradora." style="width: 100%; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px; outline: none; resize: vertical; min-height: 56px;" oninput="updatePreview()"></textarea>
                  </div>

                  <div id="difficulty-filter-panel" style="margin-bottom: 16px;"></div>

                  <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin: 0 0 8px;">Opciones</p>
                  <div id="options-grid" style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px;"></div>

                  <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin: 0 0 8px;">Período de cumplimiento</p>
                  <p style="font-size: 11px; color: #8a93aa; margin: -4px 0 10px;">Define en cuánto tiempo debe cumplirse el logro</p>
                  <div id="period-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; margin-bottom: 16px;"></div>

                  <div id="period-custom-fields"></div>
                </div>
                <div style="display: flex; justify-content: space-between; margin-top: 8px;"><button class="btn-back" style="background: #f0f2f7; color: #556; padding: 9px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; border: none;" onclick="goStep(3)">← Atrás</button><button class="btn-next" id="btn4next" style="background: #2a5bd7; color: white; padding: 9px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; opacity: 0.5; cursor: not-allowed;" disabled onclick="goStep(5)">Revisar →</button></div>
              </div>

              <!-- PASO 5: REVISAR -->
              <div class="step-section" id="step5">
                <div style="display:flex; gap:10px; margin-bottom:12px; flex-wrap:wrap;">
                  <button id="btn-flag-active" onclick="toggleStep5Flag('active')" style="font-size:12px; font-weight:700; padding:7px 16px; border-radius:20px; border:2px solid #22a66a; background:#e8faf2; color:#22a66a; cursor:pointer;">🟢 Activo</button>
                </div>
                <div style="background: white; border: 1px solid #dde4f0; border-radius: 10px; padding: 14px 16px; margin-bottom: 14px;">
                  <div style="font-size: 13px; font-weight: 700; color: #1a2340; margin: 0 0 12px; border-bottom: 1px solid #eef; padding-bottom: 8px;">Resumen del logro</div>
                  <div id="review-content"></div>
                </div>
                <div style="display: flex; justify-content: space-between; margin-top: 8px;"><button class="btn-back" style="background: #f0f2f7; color: #556; padding: 9px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; border: none;" onclick="goStep(4)">← Editar</button><button class="btn-save" style="background: #22a66a; color: white; padding: 9px 22px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; border: none;" onclick="saveLogro()">{% if isEditMode is defined and isEditMode %}✓ Guardar Cambios{% else %}✓ Guardar Logro{% endif %}</button></div>
              </div>
            </div>
          </div>

          <div class="col-lg-4 col-md-5 wizard-preview-col" style="padding-left: 12px; padding-right: 24px;">
            <div class="wizard-preview-card" style="background: white; border: 1px solid #dde4f0; border-radius: 10px; padding: 20px 16px; position: sticky; top: 10px; max-height: calc(100vh - 20px); overflow: auto;">
              <div style="font-size: 13px; font-weight: 700; color: #1a2340; margin: 0 0 12px; padding-bottom: 8px; border-bottom: 1px solid #eef;">Vista previa</div>
              <div id="preview-panel">
                <div style="font-size: 12px; color: #aab; text-align: center; padding: 24px 0;">Selecciona opciones para ver la vista previa del logro</div>
              </div>
              <div style="margin-top: 20px; border-top: 1px solid #eef; padding-top: 14px;">
                <div style="font-size: 11px; font-weight: 700; color: #8a93aa; margin-bottom: 8px;">PROGRESO DE CONSTRUCCIÓN</div>
                <div id="progress-list" style="font-size: 11px; color: #8a93aa; line-height: 2;"></div>
              </div>
            </div>
          </div>
        </div>

        {% if isEditMode is defined and isEditMode %}
        {{ form_start(form, {'action': path('backend_achievement_edit', {'id': achievement.id}), 'method': 'POST', 'attr': {'id': 'achievementForm'}}) }}
        {% else %}
        {{ form_start(form, {'attr': {'id': 'achievementForm'}}) }}
        {% endif %}
          <!-- Hidden inputs para los datos del wizard -->
          <input type="hidden" name="achievement[categoryKey]" id="hidden-cat" value="">
          <input type="hidden" name="achievement[conditionKey]" id="hidden-cond" value="">
          <input type="hidden" name="achievement[conditionContext]" id="hidden-condition-context" value="">
          <input type="hidden" name="achievement[thresholdType]" id="hidden-threshold-type" value="">
          <input type="hidden" name="achievement[targetValue]" id="hidden-threshold" value="">
          <input type="hidden" name="achievement[comparisonOperator]" id="hidden-comparison-op" value="gte">
          <input type="hidden" name="achievement[rewardType]" id="hidden-reward-type" value="badge">
          <input type="hidden" name="achievement[badgeLevel]" id="hidden-badge" value="">
          <input type="hidden" name="achievement[badgeIcon]" id="hidden-badge-icon" value="">
          <input type="hidden" name="achievement[badgeLabel]" id="hidden-badge-label" value="">
          <input type="hidden" name="achievement[badgeColor]" id="hidden-badge-color" value="">
          <input type="hidden" name="achievement[rewardValue]" id="hidden-badge-pts" value="">
          <input type="hidden" name="achievement[name]" id="hidden-name" value="">
          <input type="hidden" name="achievement[description]" id="hidden-desc" value="">
          <input type="hidden" name="achievement[periodType]" id="hidden-period" value="none">
          <input type="hidden" name="achievement[periodDays]" id="hidden-period-days" value="">
          <input type="hidden" name="achievement[periodDeadline]" id="hidden-period-deadline" value="">
          <input type="hidden" name="achievement[periodWindowStart]" id="hidden-period-window-start" value="">
          <input type="hidden" name="achievement[sortOrder]" id="hidden-sort-order" value="100">
          <input type="hidden" name="achievement[difficulty]" id="hidden-difficulty" value="">
          <!-- Booleanos: se deshabilitan cuando son false para que no se envîen (ausencia = false en CheckboxType) -->
          <input type="hidden" name="achievement[notifyInApp]" id="hidden-opts-notif" value="1">
          <input type="hidden" name="achievement[visibleProfile]" id="hidden-opts-visible" value="1">
          <input type="hidden" name="achievement[notifySpecial]" id="hidden-opts-celebrar" value="1">
          <input type="hidden" name="achievement[showProgress]" id="hidden-opts-progreso" value="1">
          <input type="hidden" name="achievement[includeHistoricalData]" id="hidden-opts-retroactivo" value="1">
          <input type="hidden" name="achievement[active]" id="hidden-active" value="{{ (isEditMode is defined and isEditMode and achievement.active is defined) ? (achievement.active ? '1' : '0') : '1' }}">
          {% if form._token is defined %}
            {{ form_widget(form._token) }}
          {% endif %}
        {{ form_end(form, {'render_rest': false}) }}

<script>
const categoryMeta = {
  'asistencia': { emoji: '🏋️', label: 'Asistencia' },
  'compras': { emoji: '💳', label: 'Compras' },
  'antiguedad': { emoji: '📅', label: 'Antigüedad' },
  'racha': { emoji: '🔥', label: 'Racha' },
  'disciplina': { emoji: '⭐', label: 'Por Disciplina' },
  'calificacion': { emoji: '🌟', label: 'Calificación' },
  'instructor': { emoji: '🤵', label: 'Instructor' },
  'comunidad': { emoji: '🤝', label: 'Comunidad' },
  'habitos': { emoji: '⏰', label: 'Hábitos' }
};

const badgeLabels = {{ badgesData.labels|json_encode|raw }};
const badgePts    = {{ badgesData.pts|json_encode|raw }};
const badgeIcons  = {{ badgesData.icons|json_encode|raw }};

const conditionsByCategory = {{ conditionsByCategory|json_encode|raw }};
const activeDisciplines = {{ activeDisciplines|default([])|json_encode|raw }};
const activeInstructors = {{ activeInstructors|default([])|json_encode|raw }};
const activePackages    = {{ activePackages|default([])|json_encode|raw }};

// Slots de hora fija: 06:00 – 21:
const timeSlots = (function() {
  const slots = [];
  for (let h = 6; h <= 21; h++) {
    const label = h < 12 ? `${h}:00 am` : h === 12 ? '12:00 pm' : `${h - 12}:00 pm`;
    slots.push({ value: `${String(h).padStart(2,'0')}:00`, label });
  }
  return slots;
})();
const condLabels = {};
Object.keys(conditionsByCategory).forEach(cat => {
  (conditionsByCategory[cat] || []).forEach(cond => {
    condLabels[cond.conditionKey] = cond.conditionLabel;
  });
});

const conditionMeta = {
  attended_classes: { icon: '🏋️' },
  unique_days_attended: { icon: '🗓️' },
  weekly_frequency: { icon: '📆' },
  total_amount: { icon: '💰' },
  total_transactions: { icon: '🧾' },
  consecutive_paid_months: { icon: '💳' },
  gift_cards_count: { icon: '🎁' },
  specific_package_count: { icon: '📦' },
  active_months: { icon: '📅' },
  active_years: { icon: '🕰️' },
  consolidated_client: { icon: '🧱' },
  consecutive_days: { icon: '🔥' },
  consecutive_weeks: { icon: '📈' },
  no_show_free_days: { icon: '✅' },
  discipline_classes: { icon: '🥋' },
  multi_discipline_count: { icon: '🧩' },
  discipline_mastery_days: { icon: '🎯' },
  avg_rating: { icon: '🌟' },
  five_star_count: { icon: '⭐' },
  rating_votes_min: { icon: '🗳️' },
  churn_risk_recovered: { icon: '🛡️' },
  months_without_pause: { icon: '📌' },
  top_instructor_classes: { icon: '🤝' },
  unique_instructors_count: { icon: '👥' },
  instructor_consistency: { icon: '🔁' },
  months_without_pause: { icon: '📌' },
  referrals_count: { icon: '🤝' },
  challenges_completed: { icon: '🏁' },
  social_shares_count: { icon: '📲' },
  event_attendance_count: { icon: '🎪' },
  friend_joint_classes: { icon: '👫' },
  checkin_morning_count: { icon: '🌅' },
  weekend_attendance: { icon: '📍' },
  checkin_evening_count: { icon: '🌆' },
  consecutive_same_time_slot: { icon: '⏰' }
};

function getConditionIcon(conditionKey) {
  return (conditionMeta[conditionKey] && conditionMeta[conditionKey].icon)
    || (state.cat && categoryMeta[state.cat] ? categoryMeta[state.cat].emoji : null)
    || '🎯';
}

let state = {
  cat: null,
  cond: null,
  disciplineIds: [],
  disciplineAttendances: null,
  disciplineAttendancesScope: 'total',
  instructorIds: [],
  timeSlotIds: [],
  customTimeSlots: [],
  packageIds: [],
  packagePurchasesScope: 'total',
  threshold: null,
  badge: null,
  customIcon: '',
  customLabel: '',
  customPts: '',
  iconManual: false,
  labelManual: false,
  ptsManual: false,
  name: '',
  desc: '',
  period: null,
  periodDays: null,
  periodWeeks: null,
  weeklyMinWeeks: null,
  periodDeadline: null,
  periodWindowStart: null,
  opts: { notif: true, visible: true, celebrar: true, progreso: false, retroactivo: false },
  difficulty: null,
  active: true
};

let currentStep = 1;

function goStep(n) {
  window.scrollTo({ top: 0, behavior: 'smooth' });
  document.getElementById('step' + currentStep).classList.remove('visible');
  currentStep = n;
  document.getElementById('step' + n).classList.add('visible');
  updateStepBar();
  if (n === 2) { renderConditions(); checkStep2(); }
  if (n === 3) { renderThresholds(); checkStep3(); }
  if (n === 4) {
    if (state.cond !== 'challenges_completed') { renderDifficultyFilter(); }
    else { const p = document.getElementById('difficulty-filter-panel'); if (p) p.innerHTML = ''; }
    renderPeriods();
    checkStep4();
  }
  if (n === 5) { buildReview(); renderStep5Flags(); }
  updatePreview();
  // Forzar recalculo del layout para que el scroll area no quede más grande que el contenido.
  requestAnimationFrame(() => {
    const rightCol = document.querySelector('.right_col');
    if (rightCol) { rightCol.style.minHeight = 'auto'; }
    window.dispatchEvent(new Event('resize'));
    window.scrollTo({ top: 0, behavior: 'instant' });
  });
}

function updateStepBar() {
  for (let i = 1; i <= 5; i++) {
    const c = document.getElementById('sc' + i);
    const l = document.getElementById('sl' + i);
    c.style.borderColor = '#c8d0e0';
    c.style.background = 'white';
    c.style.color = '#aab';
    l.style.color = '#9aa';
    l.style.fontWeight = '400';
    c.textContent = String(i);
    
    if (i < currentStep) {
      c.style.borderColor = '#22a66a';
      c.style.background = '#22a66a';
      c.style.color = 'white';
      l.style.color = '#22a66a';
      c.textContent = '✓';
      if (document.getElementById('line' + i)) {
        document.getElementById('line' + i).style.background = '#22a66a';
      }
    } else if (i === currentStep) {
      c.style.borderColor = '#2a5bd7';
      c.style.background = '#2a5bd7';
      c.style.color = 'white';
      l.style.color = '#2a5bd7';
      l.style.fontWeight = '700';
    }
  }
}

function selectCat(el) {
  document.querySelectorAll('.cat-card').forEach(c => {
    c.classList.remove('selected');
    c.style.borderColor = '#dde4f0';
    c.style.background = 'white';
  });
  el.classList.add('selected');
  el.style.borderColor = '#2a5bd7';
  el.style.background = '#eef2ff';
  state.cat = el.dataset.cat;
  state.cond = null;
  state.disciplineIds = [];
  state.instructorIds = [];
  state.timeSlotIds = [];
  state.customTimeSlots = [];
  state.packageIds = [];
  state.packagePurchasesScope = 'total';
  state.threshold = null;
  // Limpiar picker de disciplinas y botón siguiente al cambiar categoría
  const dp = document.getElementById('discipline-picker-step2');
  if (dp) dp.innerHTML = '';
  const pp = document.getElementById('package-picker-step2');
  if (pp) pp.innerHTML = '';
  const btn2 = document.getElementById('btn2next');
  if (btn2) btn2.style.display = 'none';
  renderConditions();
  updatePreview();
  setTimeout(() => goStep(2), 300);
}

function renderConditions() {
  const container = document.getElementById('cond-container');
  const conds = conditionsByCategory[state.cat] || [];
  let html = '';
  
  if (conds.length === 0) {
    container.innerHTML = '<p style="color: #aab;">Sin condiciones disponibles</p>';
    return;
  }

  conds.forEach(cond => {
    const condIcon = getConditionIcon(cond.conditionKey);
    html += `<div class="cond-chip" data-cond="${cond.conditionKey}" style="border: 2px solid #dde4f0; background: white; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600; color: #444; cursor: pointer; transition: all 0.15s;" onclick="selectCond(this)"><span style="margin-right: 6px;">${condIcon}</span>${cond.conditionLabel}</div>`;
  });
  
  container.innerHTML = `<p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin: 0 0 8px;">Tipo de ${state.cat}</p><div style="display: flex; flex-wrap: wrap; gap: 8px;">${html}</div>`;

  // Restaurar selección visual si ya hay una condición seleccionada en state
  if (state.cond) {
    const chip = container.querySelector(`.cond-chip[data-cond="${state.cond}"]`);
    if (chip) {
      chip.classList.add('selected');
      chip.style.borderColor = '#2a5bd7';
      chip.style.background = '#eef2ff';
      chip.style.color = '#1a2340';
    }
  }
}

function selectCond(el) {
  document.querySelectorAll('.cond-chip').forEach(c => {
    c.classList.remove('selected');
    c.style.borderColor = '#dde4f0';
    c.style.background = 'white';
    c.style.color = '#444';
  });
  el.classList.add('selected');
  el.style.borderColor = '#2a5bd7';
  el.style.background = '#eef2ff';
  el.style.color = '#1a2340';
  state.cond = el.dataset.cond;
  state.disciplineIds = [];
  state.disciplineAttendances = null;
  state.disciplineAttendancesScope = 'total';
  state.instructorIds = [];
  state.timeSlotIds = [];
  state.customTimeSlots = [];
  state.packageIds = [];
  state.packagePurchasesScope = 'total';
  state.threshold = null;
  state.difficulty = null;
  state.weeklyMinWeeks = null;
  state.periodWeeks = null;
  // Resetear período porque puede cambiar de opciones disponibles según condición
  state.period = null;
  state.periodDays = null;
  state.periodDeadline = null;
  state.periodWindowStart = null;

  // Limpiar entrada personalizada de paso anterior
  const customInput = document.getElementById('custom-threshold-input');
  if (customInput) {
    customInput.style.display = 'none';
    const customValue = document.getElementById('custom-threshold-value');
    if (customValue) customValue.value = '';
  }

  if (state.cat === 'disciplina' && state.cond !== 'multi_discipline_count') {
    // Mostrar picker de disciplinas en el mismo paso 2 — NO auto-avanzar
    renderDisciplineInStep2();
    checkStep2();
    updatePreview();
  } else if (state.cat === 'compras' && state.cond === 'specific_package_count') {
    // Mostrar picker de paquetes en el mismo paso 2 — NO auto-avanzar
    renderPackageInStep2();
    checkStep2();
    updatePreview();
  } else {
    // multi_discipline_count y otras categorías: avanzar directo al paso 3
    renderThresholds();
    updatePreview();
    setTimeout(() => goStep(3), 300);
  }
}

function advanceFromStep2() {
  renderThresholds();
  goStep(3);
}

function backToStep2() {
  goStep(2);
  if (state.cat === 'disciplina') {
    renderDisciplineInStep2();
    checkStep2();
  }
  if (state.cat === 'compras' && state.cond === 'specific_package_count') {
    renderPackageInStep2();
    checkStep2();
  }
}

function checkStep2() {
  const btn = document.getElementById('btn2next');
  if (!btn) return;
  const isDisciplina = state.cat === 'disciplina';
  const isPackage    = state.cat === 'compras' && state.cond === 'specific_package_count';
  const isMultiCount = state.cond === 'multi_discipline_count';

  // Para categorías que normalmente auto-avanzan (no disciplina-individual ni paquete específico),
  // mostrar btn2next solo si hay condición seleccionada (permite navegar en modo edición)
  if (!isDisciplina && !isPackage) {
    if (state.cond) {
      btn.style.display = 'inline-block';
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.cursor = 'pointer';
    } else {
      btn.style.display = 'none';
    }
    return;
  }

  btn.style.display = 'inline-block';
  let ok = !!state.cond;
  if (isDisciplina && !isMultiCount) ok = ok && state.disciplineIds.length > 0;
  if (isPackage) ok = ok && state.packageIds.length > 0;
  btn.disabled = !ok;
  btn.style.opacity = ok ? '1' : '0.5';
  btn.style.cursor = ok ? 'pointer' : 'not-allowed';
}

const INDIVIDUAL_DISCIPLINE_ID = 0;

function renderDisciplineInStep2() {
  const container = document.getElementById('discipline-picker-step2');
  if (!container) return;
  // Para multi_discipline_count: el picker va en paso 3, no aquí
  if (!isDisciplineConditionActive() || state.cond === 'multi_discipline_count') { container.innerHTML = ''; return; }

  const isMulti = isMultiDisciplineCondition();
  const scopeTitle = isMulti ? 'Disciplinas a considerar' : 'Disciplina a evaluar';
  const scopeHint = isMulti
    ? 'Selecciona una o más disciplinas. Puedes incluir clases individuales como opción especial.'
    : 'Selecciona la disciplina sobre la que se evaluará esta condición.';

  // Chip especial: Clases individuales
  const indivSel = state.disciplineIds.includes(INDIVIDUAL_DISCIPLINE_ID);
  const individualChip = `<div class="discipline-chip${indivSel ? ' selected' : ''}" data-discipline-id="${INDIVIDUAL_DISCIPLINE_ID}"
    style="border: 2px solid ${indivSel ? '#7c3aed' : '#dde4f0'}; background: ${indivSel ? '#f3e8ff' : 'white'}; color: ${indivSel ? '#4c1d95' : '#444'}; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;"
    onclick="toggleDisciplineScope(this)">🧘 Clases individuales</div>`;

  // Chips de disciplinas activas
  const disciplineChips = activeDisciplines.map(d => {
    const sel = state.disciplineIds.includes(Number(d.id));
    return `<div class="discipline-chip${sel ? ' selected' : ''}" data-discipline-id="${d.id}"
      style="border: 2px solid ${sel ? '#2a5bd7' : '#dde4f0'}; background: ${sel ? '#eef2ff' : 'white'}; color: ${sel ? '#1a2340' : '#444'}; border-radius: 20px; padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;"
      onclick="toggleDisciplineScope(this)">🥋 ${d.name}</div>`;
  }).join('');

  container.innerHTML = `
    <div style="margin-top: 14px; padding: 12px; border: 1px solid #dde4f0; border-radius: 8px; background: #fbfcff;">
      <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin-bottom: 4px;">${scopeTitle}</div>
      <div style="font-size: 11px; color: #8a93aa; margin-bottom: 10px;">${scopeHint}</div>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">${individualChip}${disciplineChips}</div>
    </div>`;
}

function isDisciplineConditionActive() {
  return state.cat === 'disciplina' && !!state.cond;
}

function isMultiDisciplineCondition() {
  return state.cond === 'multi_discipline_count';
}

function isPackageConditionActive() {
  return state.cat === 'compras' && state.cond === 'specific_package_count';
}

function renderPackageInStep2() {
  const container = document.getElementById('package-picker-step2');
  if (!container) return;
  if (!isPackageConditionActive()) { container.innerHTML = ''; return; }

  function buildChips(pkgs) {
    if (!pkgs.length) return '<span style="font-size:12px;color:#aaa;">Sin paquetes</span>';
    return pkgs.map(pkg => {
      const sel = state.packageIds.includes(Number(pkg.id));
      return `<div class="package-chip${sel ? ' selected' : ''}" data-pkg-id="${pkg.id}"
        style="border: 2px solid ${sel ? '#2a5bd7' : '#dde4f0'}; background: ${sel ? '#eef2ff' : 'white'}; color: ${sel ? '#1a2340' : '#444'}; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;"
        onclick="togglePackageScope(this)">📦 ${pkg.name}</div>`;
    }).join('');
  }

  const grupales    = activePackages.filter(p => p.type === 'g');
  const individuales = activePackages.filter(p => p.type === 'i');

  container.innerHTML = `
    <div style="margin-top: 14px; padding: 12px; border: 1px solid #dde4f0; border-radius: 8px; background: #fbfcff;">
      <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin-bottom: 4px;">Paquetes a considerar</div>
      <div style="font-size: 11px; color: #8a93aa; margin-bottom: 12px;">Selecciona uno o más paquetes. El logro se cumplirá cuando el usuario haya comprado cualquiera de ellos el número de veces indicado.</div>
      ${grupales.length ? `
      <div style="font-size: 11px; font-weight: 700; color: #444; margin-bottom: 6px; display: flex; align-items: center; gap: 6px;">
        <span style="background:#e8f0fe; color:#2a5bd7; border-radius: 4px; padding: 1px 7px; font-size: 10px; letter-spacing: .4px;">GRUPALES</span>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px;">${buildChips(grupales)}</div>` : ''}
      ${individuales.length ? `
      <div style="font-size: 11px; font-weight: 700; color: #444; margin-bottom: 6px; display: flex; align-items: center; gap: 6px;">
        <span style="background:#fef3e2; color:#b45309; border-radius: 4px; padding: 1px 7px; font-size: 10px; letter-spacing: .4px;">INDIVIDUALES</span>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">${buildChips(individuales)}</div>` : ''}
      ${!grupales.length && !individuales.length ? '<span style="font-size:12px;color:#aaa;">No hay paquetes activos</span>' : ''}
    </div>`;
}

function togglePackageScope(el) {
  const pkgId = Number(el.dataset.pkgId);
  if (state.packageIds.includes(pkgId)) {
    state.packageIds = state.packageIds.filter(id => id !== pkgId);
    el.style.borderColor = '#dde4f0';
    el.style.background = 'white';
    el.style.color = '#444';
    el.classList.remove('selected');
  } else {
    state.packageIds = [...state.packageIds, pkgId];
    el.style.borderColor = '#2a5bd7';
    el.style.background = '#eef2ff';
    el.style.color = '#1a2340';
    el.classList.add('selected');
  }
  checkStep2();
  updatePreview();
}

function getSelectedPackageNames() {
  if (!state.packageIds.length) return [];
  return activePackages
    .filter(p => state.packageIds.includes(Number(p.id)))
    .map(p => p.name);
}

function isInstructorScopeCondition() {
  return state.cond === 'top_instructor_classes' || state.cond === 'instructor_consistency';
}

// Condiciones cuyo umbral ya define una duración de tiempo → período libre (sin-limite) o fecha de vencimiento
function isTimeBoundCondition() {
  if (!state.cond) return false;
  const cond = (conditionsByCategory[state.cat] || []).find(c => c.conditionKey === state.cond);
  const type = cond ? cond.thresholdType : null;
  // thresholdType = months o days: el umbral es tiempo
  if (type === 'months' || type === 'days') return true;
  // conditionKeys con semántica de semanas aunque su thresholdType sea count
  const weekBasedKeys = ['consecutive_weeks', 'instructor_consistency'];
  return weekBasedKeys.includes(state.cond);
}

function isTimeSlotCondition() {
  return state.cond === 'consecutive_same_time_slot';
}

function getSelectedTimeSlotLabels() {
  const predefined = timeSlots
    .filter(s => state.timeSlotIds.includes(s.value))
    .map(s => s.label);
  const custom = (state.customTimeSlots || [])
    .filter(s => state.timeSlotIds.includes(s.value))
    .map(s => `⏰ ${s.value}`);
  return [...predefined, ...custom];
}

function getSelectedInstructorNames() {
  if (!state.instructorIds.length) return [];
  const selectedSet = new Set(state.instructorIds.map(id => String(id)));
  return activeInstructors
    .filter(i => selectedSet.has(String(i.id)))
    .map(i => i.name);
}

function getSelectedDisciplineNames() {
  if (!state.disciplineIds.length) return [];
  const result = [];
  if (state.disciplineIds.includes(INDIVIDUAL_DISCIPLINE_ID)) {
    result.push('Clases individuales');
  }
  const selectedSet = new Set(state.disciplineIds.filter(id => id !== INDIVIDUAL_DISCIPLINE_ID).map(id => String(id)));
  activeDisciplines
    .filter(d => selectedSet.has(String(d.id)))
    .forEach(d => result.push(d.name));
  return result;
}

function setDisciplineChipVisual(el, enabled) {
  if (enabled) {
    el.classList.add('selected');
    el.style.borderColor = '#2a5bd7';
    el.style.background = '#eef2ff';
    el.style.color = '#1a2340';
  } else {
    el.classList.remove('selected');
    el.style.borderColor = '#dde4f0';
    el.style.background = 'white';
    el.style.color = '#444';
  }
}

function toggleDisciplineScope(el) {
  const raw = el.dataset.disciplineId;
  if (raw === undefined || raw === '') return;
  const disciplineId = parseInt(raw, 10);
  if (isNaN(disciplineId)) return;

  if (isMultiDisciplineCondition()) {
    if (state.disciplineIds.includes(disciplineId)) {
      state.disciplineIds = state.disciplineIds.filter(id => id !== disciplineId);
    } else {
      state.disciplineIds = [...state.disciplineIds, disciplineId];
    }
  } else {
    state.disciplineIds = [disciplineId];
  }

  // Actualizar visual de todos los chips
  document.querySelectorAll('.discipline-chip').forEach(chip => {
    const chipRaw = chip.dataset.disciplineId;
    if (chipRaw === undefined || chipRaw === '') return;
    const chipId = parseInt(chipRaw, 10);
    const sel = state.disciplineIds.includes(chipId);
    const isIndiv = chipId === INDIVIDUAL_DISCIPLINE_ID;
    if (sel) {
      chip.classList.add('selected');
      chip.style.borderColor = isIndiv ? '#7c3aed' : '#2a5bd7';
      chip.style.background  = isIndiv ? '#f3e8ff' : '#eef2ff';
      chip.style.color       = isIndiv ? '#4c1d95' : '#1a2340';
    } else {
      chip.classList.remove('selected');
      chip.style.borderColor = '#dde4f0';
      chip.style.background  = 'white';
      chip.style.color       = '#444';
    }
  });

  updatePreview();
  checkStep2();
  checkStep3();
}

function renderDisciplineScopeHtml() {
  if (!isDisciplineConditionActive()) {
    return '';
  }

  if (!activeDisciplines.length) {
    return `<div style="margin-bottom: 12px; border: 1px dashed #d9deea; background: #f9fafd; border-radius: 8px; padding: 10px; font-size: 11px; color: #8a93aa;">No hay disciplinas activas disponibles para evaluar esta condición.</div>`;
  }

  const scopeTitle = isMultiDisciplineCondition() ? 'Disciplinas a considerar' : 'Disciplina a evaluar';
  const scopeHint = isMultiDisciplineCondition()
    ? 'Selecciona una o más disciplinas activas para aplicar esta condición.'
    : 'Selecciona la disciplina activa sobre la que se evaluará la condición.';

  const chips = activeDisciplines.map(d => {
    const selected = state.disciplineIds.includes(Number(d.id));
    return `<div class="discipline-chip${selected ? ' selected' : ''}" data-discipline-id="${d.id}" style="border: 2px solid ${selected ? '#2a5bd7' : '#dde4f0'}; background: ${selected ? '#eef2ff' : 'white'}; border-radius: 20px; padding: 6px 12px; font-size: 12px; font-weight: 600; color: ${selected ? '#1a2340' : '#444'}; cursor: pointer; transition: all 0.15s;" onclick="toggleDisciplineScope(this)">🥋 ${d.name}</div>`;
  }).join('');

  return `<div style="margin-bottom: 12px; padding: 10px; border: 1px solid #dde4f0; border-radius: 8px; background: #fbfcff;">
            <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin-bottom: 4px;">${scopeTitle}</div>
            <div style="font-size: 11px; color: #8a93aa; margin-bottom: 8px;">${scopeHint}</div>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">${chips}</div>
          </div>`;
}

function renderThresholds() {
  const container = document.getElementById('threshold-container');
  const extraFields = document.getElementById('threshold-extra-fields');
  if (extraFields) extraFields.innerHTML = '';
  const cond = (conditionsByCategory[state.cat] || []).find(item => item.conditionKey === state.cond);
  const vals = (cond && cond.thresholdOptions && cond.thresholdOptions.length)
    ? cond.thresholdOptions
    : [];

  const unitByType = {
    amount: 'MXN',
    days: 'días',
    months: 'meses',
    rating: 'estrellas',
    count: 'unidades'
  };

  const thresholdType = cond && cond.thresholdType ? cond.thresholdType : 'count';
  const unitLabel = unitByType[thresholdType] || 'unidades';
  const isWeeklyFrequency = cond && cond.conditionKey === 'weekly_frequency';
  const isMultiCount = state.cond === 'multi_discipline_count';
  const maxDisciplines = activeDisciplines.length + 1; // +1 por clases individuales
  const isRatingType = thresholdType === 'rating';
  const condIcon = cond ? getConditionIcon(cond.conditionKey) : '🎯';
  const condName = cond ? cond.conditionLabel : 'Condición';

  if (vals.length === 0) {
    container.innerHTML = '<p style="color: #aab;">Sin umbrales configurados para esta condición.</p>';
    return;
  }

  // Resumen read-only de disciplinas (solo para condiciones que eligen disciplina en paso 2)
  let disciplineSummaryHtml = '';
  if (isDisciplineConditionActive() && state.cond !== 'multi_discipline_count' && state.disciplineIds.length > 0) {
    const names = getSelectedDisciplineNames();
    disciplineSummaryHtml = `<div style="margin-bottom: 12px; padding: 8px 12px; background: #f3e8ff; border: 1px solid #c4b5fd; border-radius: 8px; font-size: 11px; color: #4c1d95;">
      <span style="font-weight:700;">Disciplina${names.length > 1 ? 's' : ''} seleccionada${names.length > 1 ? 's' : ''}:</span> ${names.join(', ')}
    </div>`;
  }

  let html = `<div style="display: inline-flex; align-items: center; gap: 8px; background: #f6f8ff; border: 1px solid #dde4f0; border-radius: 999px; padding: 5px 10px; margin-bottom: 10px; font-size: 11px; font-weight: 700; color: #2a5bd7;"><span>${condIcon}</span><span>${condName}</span></div>
             ${disciplineSummaryHtml}
             <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin: 0 0 8px;">Valor objetivo</p>
             <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(88px, 1fr)); gap: 8px;">`;
  
  vals.forEach(opt => {
    const rawValue = opt.value;
    let showLabel = opt.label || String(rawValue);
    let cardUnitLabel = unitLabel;

    if (isWeeklyFrequency) {
      showLabel = showLabel
        .replace(/\s*\/\s*semana/gi, '')
        .replace(/\s+por\s+semana/gi, '')
        .trim();
      cardUnitLabel = 'por semanas';
    }

    // Para multi_discipline_count: deshabilitar tarjetas que superan el máximo disponible
    const isDisabled = isMultiCount && Number(rawValue) > maxDisciplines;
    if (isDisabled) {
      html += `<div class="threshold-card" data-val="${rawValue}" data-disabled="true" title="No hay suficientes disciplinas activas" style="border: 2px solid #e5e7eb; background: #f9fafb; border-radius: 8px; padding: 10px 6px; text-align: center; cursor: not-allowed; opacity: 0.45; transition: all 0.15s;" onclick="selectThreshold(this)">
                <div style="font-size: 15px; font-weight: 700; color: #9ca3af;">${showLabel}</div>
                <div style="font-size: 10px; color: #9ca3af;">${cardUnitLabel}</div>
              </div>`;
    } else {
      html += `<div class="threshold-card" data-val="${rawValue}" style="border: 2px solid #dde4f0; background: white; border-radius: 8px; padding: 10px 6px; text-align: center; cursor: pointer; transition: all 0.15s;" onclick="selectThreshold(this)">
                <div style="font-size: 15px; font-weight: 700; color: #2a5bd7;">${showLabel}</div>
                <div style="font-size: 10px; color: #8a93aa;">${cardUnitLabel}</div>
              </div>`;
    }
  });

  html += `<div class="threshold-card custom-threshold-trigger" data-val="custom" style="border: 2px solid #dde4f0; background: white; border-radius: 8px; padding: 10px 6px; text-align: center; cursor: pointer; transition: all 0.15s;" onclick="selectThreshold(this)">
            <div style="font-size: 15px; font-weight: 700; color: #2a5bd7;">+</div>
            <div style="font-size: 10px; color: #8a93aa;">Personalizado</div>
          </div>`;

  let inputMin, inputMax, inputStep, inputPlaceholder, inputUnit;
  if (isMultiCount) {
    inputMin = 1; inputMax = maxDisciplines; inputStep = 1;
    inputPlaceholder = `1 – ${maxDisciplines}`; inputUnit = 'disciplinas';
  } else if (isRatingType) {
    inputMin = 1; inputMax = 5; inputStep = 0.1;
    inputPlaceholder = 'ej. 4.7'; inputUnit = 'estrellas';
  } else {
    inputMin = 1; inputMax = 9999; inputStep = 1;
    inputPlaceholder = 'ej. 35'; inputUnit = unitLabel;
  }

  html += `</div><div id="custom-threshold-input" style="display: none; margin-top: 14px; padding: 12px; background: #f9fafc; border: 1px solid #dde4f0; border-radius: 8px;">
    <label style="font-size: 11px; font-weight: 700; color: #556; margin-bottom: 6px; display: block;">Ingresa el valor personalizado</label>
    <div style="display: flex; gap: 8px; align-items: center;">
      <input type="number" id="custom-threshold-value" placeholder="${inputPlaceholder}" min="${inputMin}" max="${inputMax}" step="${inputStep}" style="flex: 1; border: 1.5px solid #dde4f0; border-radius: 6px; padding: 8px 10px; font-size: 13px;" oninput="setCustomThreshold(this.value)">
      <span style="align-self: center; font-size: 11px; color: #8a93aa; font-weight: 600;">${inputUnit}</span>
    </div>
    <div id="custom-threshold-error" style="display:none; font-size: 11px; color: #dc2626; margin-top: 4px;"></div>
  </div>`;

  // Para multi_discipline_count: agregar área donde aparecerá el picker de disciplinas al seleccionar umbral
  if (state.cond === 'multi_discipline_count') {
    html += `<div id="discipline-picker-step3"></div>`;
  }

  // Para top_instructor_classes: agregar área donde aparecerá el picker de instructores al seleccionar umbral
  if (isInstructorScopeCondition()) {
    html += `<div id="instructor-picker-step3"></div>`;
  }

  // Para consecutive_same_time_slot: picker de horarios
  if (isTimeSlotCondition()) {
    html += `<div id="timeslot-picker-step3"></div>`;
  }

  // Para challenges_completed: selector de dificultad a contabilizar
  if (state.cond === 'challenges_completed') {
    html += `<div id="challenge-diff-step3" style="margin-top: 16px;"></div>`;
  }

  // Para specific_package_count: selector de scope (en total vs en cada uno)
  if (isPackageConditionActive()) {
    html += `<div id="package-scope-step3"></div>`;
  }

  container.innerHTML = html;

  // Restaurar selección visual del umbral si ya hay uno en state
  if (state.threshold !== null && state.threshold !== undefined) {
    const threshStr = String(state.threshold);
    const card = container.querySelector(`.threshold-card[data-val="${threshStr}"]`);
    if (card) {
      card.classList.add('selected');
      card.style.borderColor = '#2a5bd7';
      card.style.background = '#eef2ff';
    } else {
      // Umbral personalizado: mostrar el input con el valor guardado
      const customInput = document.getElementById('custom-threshold-input');
      const customCard = container.querySelector('.threshold-card[data-val="custom"]');
      if (customInput && customCard) {
        customCard.classList.add('selected');
        customCard.style.borderColor = '#2a5bd7';
        customCard.style.background = '#eef2ff';
        customInput.style.display = 'block';
        const customValue = document.getElementById('custom-threshold-value');
        if (customValue) customValue.value = threshStr;
      }
    }
  }

  // Si ya había un umbral seleccionado (vuelta atrás), re-renderizar el picker
  if (state.cond === 'multi_discipline_count' && state.threshold) {
    renderDisciplinePickerStep3(Number(state.threshold));
  }

  // Si vuelve atrás con instructores ya seleccionados, re-renderizar picker
  if (isInstructorScopeCondition() && state.threshold) {
    renderInstructorPickerStep3();
  }

  // Si vuelve atrás con time slots ya seleccionados, re-renderizar picker
  if (isTimeSlotCondition() && state.threshold) {
    renderTimeSlotPickerStep3();
  }

  // Si vuelve atrás con dificultad ya elegida en challenges_completed, restaurar panel
  if (state.cond === 'challenges_completed' && state.threshold) {
    renderDifficultyFilter('challenge-diff-step3');
  }

  // Si vuelve atrás en specific_package_count, restaurar selector de scope
  if (isPackageConditionActive() && state.threshold) {
    renderPackageScopeStep3();
  }

  // Si vuelve atrás con weekly_frequency ya configurado, restaurar input de semanas
  if (state.cond === 'weekly_frequency' && state.threshold !== null) {
    const extraFields = document.getElementById('threshold-extra-fields');
    if (extraFields) {
      extraFields.innerHTML = `<div style="margin-top:12px;padding:10px 12px;background:#f6f8ff;border:1px solid #dde4f0;border-radius:8px;">
        <label style="font-size:11px;font-weight:700;color:#2a5bd7;margin-bottom:4px;display:block;">Semanas de evaluación</label>
        <p style="font-size:10px;color:#8a93aa;margin:0 0 6px;">Mínimo de semanas que debe mantener este promedio semanal</p>
        <input type="number" id="weekly-min-weeks-input" placeholder="ej. 4" min="1" max="52"
          style="width:100%;border:1.5px solid #dde4f0;border-radius:6px;padding:8px 10px;font-size:13px;outline:none;"
          oninput="setWeeklyMinWeeks(this.value)">
      </div>`;
      if (state.weeklyMinWeeks) {
        const inp = document.getElementById('weekly-min-weeks-input');
        if (inp) inp.value = state.weeklyMinWeeks;
      }
    }
  }

}

function renderDifficultyFilter(panelId) {
  panelId = panelId || 'difficulty-filter-panel';
  const panel = document.getElementById(panelId);
  if (!panel) return;

  const isChallengeFilter = state.cond === 'challenges_completed';
  const title  = isChallengeFilter ? 'Filtrar por dificultad de reto' : '¿Es este logro un reto? (opcional)';
  const hint   = isChallengeFilter
    ? 'Solo contará retos de la dificultad seleccionada. Sin selección = cuenta todos los retos.'
    : 'Asigna dificultad para que este logro cuente como reto en la condición "Retos completados".';

  const opts = [
    { key: '__null__', label: isChallengeFilter ? 'Cualquiera' : 'No es reto', icon: '—' },
    { key: 'easy',   label: 'Fácil',    icon: '🟢' },
    { key: 'medium', label: 'Media',    icon: '🟡' },
    { key: 'hard',   label: 'Difícil',  icon: '🟠' },
    { key: 'expert', label: 'Experto',  icon: '🔴' },
  ];

  const chips = opts.map(o => {
    const dataKey = o.key;
    const isSel   = (state.difficulty === null && o.key === '__null__') || (state.difficulty === o.key);
    return `<div class="difficulty-chip${isSel ? ' selected' : ''}" data-diff="${dataKey}"
      style="border: 2px solid ${isSel ? '#2a5bd7' : '#dde4f0'}; background: ${isSel ? '#eef2ff' : 'white'};
             color: ${isSel ? '#1a2340' : '#444'}; border-radius: 20px; padding: 6px 14px;
             font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;"
      onclick="selectDifficulty(this)">${o.icon} ${o.label}</div>`;
  }).join('');

  panel.innerHTML = `<div style="padding: 10px; border: 1px solid #dde4f0; border-radius: 8px; background: #fbfcff;">
    <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #2a5bd7; margin-bottom: 4px;">${title}</div>
    <div style="font-size: 11px; color: #8a93aa; margin-bottom: 10px;">${hint}</div>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">${chips}</div>
  </div>`;
}

function selectDifficulty(el) {
  const raw = el.dataset.diff;
  state.difficulty = (raw === '__null__') ? null : raw;
  document.querySelectorAll('.difficulty-chip').forEach(c => {
    const sel = c.dataset.diff === (state.difficulty === null ? '__null__' : state.difficulty);
    c.classList.toggle('selected', sel);
    c.style.borderColor = sel ? '#2a5bd7' : '#dde4f0';
    c.style.background  = sel ? '#eef2ff' : 'white';
    c.style.color       = sel ? '#1a2340' : '#444';
  });
  updatePreview();
}

function selectThreshold(el) {
  document.querySelectorAll('.threshold-card').forEach(c => {
    c.classList.remove('selected');
    c.style.borderColor = '#dde4f0';
    c.style.background = 'white';
  });
  el.classList.add('selected');
  el.style.borderColor = '#2a5bd7';
  el.style.background = '#eef2ff';
  
  if (el.dataset.val === 'custom') {
    // Mostrar input personalizado
    const customInput = document.getElementById('custom-threshold-input');
    if (customInput) {
      customInput.style.display = 'block';
      document.getElementById('custom-threshold-value').focus();
    }
    checkStep3();
    // No avanzar automáticamente, esperar que el usuario ingrese valor
    return;
  }
  
  // Opción genérica seleccionada
  state.threshold = el.dataset.val;
  
  // Ocultar input personalizado si estaba visible
  const customInput = document.getElementById('custom-threshold-input');
  if (customInput) {
    customInput.style.display = 'none';
    document.getElementById('custom-threshold-value').value = '';
  }

  // Para multi_discipline_count: validar límite y mostrar picker de disciplinas
  if (state.cond === 'multi_discipline_count') {
    const maxAvail = activeDisciplines.length + 1;
    if (el.dataset.disabled === 'true' || Number(state.threshold) > maxAvail) {
      // Revertir selección visual
      el.classList.remove('selected');
      el.style.borderColor = '#e5e7eb';
      el.style.background = '#f9fafb';
      state.threshold = null;
      const errEl = document.getElementById('custom-threshold-error');
      if (errEl) {
        errEl.textContent = `Solo hay ${maxAvail} opción${maxAvail !== 1 ? 'es' : ''} disponible${maxAvail !== 1 ? 's' : ''} (${activeDisciplines.length} disciplina${activeDisciplines.length !== 1 ? 's' : ''} + clases individuales).`;
        errEl.style.display = 'block';
      }
      updatePreview();
      checkStep3();
      return;
    }
    state.disciplineIds = []; // resetear disciplinas al cambiar umbral
    state.disciplineAttendances = null;
    renderDisciplinePickerStep3(Number(state.threshold));
    updatePreview();
    checkStep3();
    return;
  }

  // Para top_instructor_classes: mostrar picker de instructores, no auto-avanzar
  if (isInstructorScopeCondition()) {
    state.instructorIds = []; // resetear instructores al cambiar umbral
    renderInstructorPickerStep3();
    updatePreview();
    checkStep3();
    return;
  }

  // Para consecutive_same_time_slot: mostrar picker de horarios, no auto-avanzar
  if (isTimeSlotCondition()) {
    state.timeSlotIds = []; // resetear slots al cambiar umbral
    state.customTimeSlots = [];
    renderTimeSlotPickerStep3();
    updatePreview();
    checkStep3();
    return;
  }

  // Para weekly_frequency: mostrar input de semanas mínimas, no auto-avanzar
  if (state.cond === 'weekly_frequency') {
    state.weeklyMinWeeks = null;
    state.periodWeeks = null;
    state.period = null;
    const extraFields = document.getElementById('threshold-extra-fields');
    if (extraFields) {
      extraFields.innerHTML = `<div style="margin-top:12px;padding:10px 12px;background:#f6f8ff;border:1px solid #dde4f0;border-radius:8px;">
        <label style="font-size:11px;font-weight:700;color:#2a5bd7;margin-bottom:4px;display:block;">Semanas de evaluación</label>
        <p style="font-size:10px;color:#8a93aa;margin:0 0 6px;">Mínimo de semanas que debe mantener este promedio semanal</p>
        <input type="number" id="weekly-min-weeks-input" placeholder="ej. 4" min="1" max="52"
          style="width:100%;border:1.5px solid #dde4f0;border-radius:6px;padding:8px 10px;font-size:13px;outline:none;"
          oninput="setWeeklyMinWeeks(this.value)">
      </div>`;
    }
    updatePreview();
    checkStep3();
    return;
  }

  // Para challenges_completed: mostrar selector de dificultad en paso 3, no auto-avanzar
  if (state.cond === 'challenges_completed') {
    renderDifficultyFilter('challenge-diff-step3');
    updatePreview();
    checkStep3();
    return;
  }

  // Para specific_package_count: mostrar selector de scope, no auto-avanzar
  if (isPackageConditionActive()) {
    renderPackageScopeStep3();
    updatePreview();
    checkStep3();
    return;
  }

  updatePreview();
  checkStep3();
  setTimeout(() => goStep(4), 300);
}

function setCustomThreshold(value) {
  const numValue = parseFloat(value);
  const errorEl = document.getElementById('custom-threshold-error');

  const showError = (msg) => {
    state.threshold = null;
    if (errorEl) { errorEl.textContent = msg; errorEl.style.display = 'block'; }
    updatePreview(); checkStep3();
  };

  if (!value || isNaN(numValue)) {
    state.threshold = null;
    if (errorEl) errorEl.style.display = 'none';
    updatePreview();
    checkStep3();
    return;
  }

  // Para multi_discipline_count: limitar al total de opciones disponibles
  if (state.cond === 'multi_discipline_count') {
    const maxAllowed = activeDisciplines.length + 1; // +1 individual
    if (!Number.isInteger(numValue))   return showError('El valor debe ser un número entero.');
    if (numValue < 1)                  return showError('El valor mínimo es 1.');
    if (numValue > maxAllowed)         return showError(`El valor máximo es ${maxAllowed}.`);
    // Resetear disciplinas seleccionadas al cambiar el valor personalizado
    if (state.threshold !== numValue) {
      state.disciplineIds = [];
      state.disciplineAttendances = null;
    }
    if (errorEl) errorEl.style.display = 'none';
    state.threshold = numValue;
    renderDisciplinePickerStep3(numValue);
    updatePreview();
    checkStep3();
    return;
  }

  // Para tipo rating (avg_rating): limitar a 1.0 – 5.0
  const condData = (conditionsByCategory[state.cat] || []).find(c => c.conditionKey === state.cond);
  if (condData && condData.thresholdType === 'rating') {
    if (numValue < 1) return showError('El valor mínimo es 1.0 estrellas.');
    if (numValue > 5) return showError('El valor máximo es 5.0 estrellas.');
    if (errorEl) errorEl.style.display = 'none';
    state.threshold = numValue;
    updatePreview();
    checkStep3();
    return;
  }

  // Caso genérico: debe ser entero positivo >= 1
  if (!Number.isInteger(numValue)) return showError('El valor debe ser un número entero.');
  if (numValue < 1)                return showError('El valor mínimo es 1.');

  if (errorEl) errorEl.style.display = 'none';
  state.threshold = numValue;
  updatePreview();
  checkStep3();

  // Para top_instructor_classes: mostrar/actualizar picker de instructores
  if (isInstructorScopeCondition()) {
    if (!document.getElementById('instructor-picker-step3')) {
      // El contenedor aún no existe, añadirlo después del custom-threshold-input
      const threshContainer = document.getElementById('threshold-container');
      if (threshContainer) {
        const div = document.createElement('div');
        div.id = 'instructor-picker-step3';
        threshContainer.appendChild(div);
      }
    }
    renderInstructorPickerStep3();
  }

  // Para consecutive_same_time_slot: mostrar/actualizar picker de horarios
  if (isTimeSlotCondition()) {
    if (!document.getElementById('timeslot-picker-step3')) {
      const threshContainer = document.getElementById('threshold-container');
      if (threshContainer) {
        const div = document.createElement('div');
        div.id = 'timeslot-picker-step3';
        threshContainer.appendChild(div);
      }
    }
    renderTimeSlotPickerStep3();
  }

  // Para specific_package_count: actualizar selector de scope
  if (isPackageConditionActive()) {
    if (!document.getElementById('package-scope-step3')) {
      const threshContainer = document.getElementById('threshold-container');
      if (threshContainer) {
        const div = document.createElement('div');
        div.id = 'package-scope-step3';
        threshContainer.appendChild(div);
      }
    }
    renderPackageScopeStep3();
  }
}

function checkStep3() {
  const btn = document.getElementById('btn3next');

  let disciplineOk;
  if (state.cond === 'multi_discipline_count') {
    // Requiere exactamente N disciplinas donde N = umbral seleccionado + asistencias definidas
    disciplineOk = state.threshold !== null &&
                   state.disciplineIds.length === Number(state.threshold) &&
                   state.disciplineAttendances !== null;
  } else if (isInstructorScopeCondition()) {
    // Requiere al menos 1 instructor seleccionado
    disciplineOk = state.instructorIds.length > 0;
  } else if (isTimeSlotCondition()) {
    // Requiere al menos 1 horario seleccionado
    disciplineOk = state.timeSlotIds.length > 0;
  } else {
    const requiresDiscipline = isDisciplineConditionActive();
    disciplineOk = !requiresDiscipline || state.disciplineIds.length > 0;
  }

  const weeklyOk = state.cond !== 'weekly_frequency' || !!state.weeklyMinWeeks;

  if (btn) {
    if (state.threshold !== null && state.threshold !== undefined && disciplineOk && weeklyOk) {
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.cursor = 'pointer';
    } else {
      btn.disabled = true;
      btn.style.opacity = '0.5';
      btn.style.cursor = 'not-allowed';
    }
  }
}

function renderDisciplinePickerStep3(n) {
  const container = document.getElementById('discipline-picker-step3');
  if (!container) return;

  const indivSel = state.disciplineIds.includes(INDIVIDUAL_DISCIPLINE_ID);
  const individualChip = `<div class="discipline-chip${indivSel ? ' selected' : ''}" data-discipline-id="${INDIVIDUAL_DISCIPLINE_ID}"
    style="border: 2px solid ${indivSel ? '#7c3aed' : '#dde4f0'}; background: ${indivSel ? '#f3e8ff' : 'white'}; color: ${indivSel ? '#4c1d95' : '#444'}; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;"
    onclick="toggleDisciplineStep3(this)">🧘 Clases individuales</div>`;

  const disciplineChips = activeDisciplines.map(d => {
    const sel = state.disciplineIds.includes(Number(d.id));
    return `<div class="discipline-chip${sel ? ' selected' : ''}" data-discipline-id="${d.id}"
      style="border: 2px solid ${sel ? '#2a5bd7' : '#dde4f0'}; background: ${sel ? '#eef2ff' : 'white'}; color: ${sel ? '#1a2340' : '#444'}; border-radius: 20px; padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;"
      onclick="toggleDisciplineStep3(this)">🥋 ${d.name}</div>`;
  }).join('');

  const selCount = state.disciplineIds.length;
  const counterColor = selCount === n ? '#16a34a' : '#f59e0b';

  const attVal = state.disciplineAttendances !== null ? state.disciplineAttendances : '';
  const scopeTotal = state.disciplineAttendancesScope === 'total';
  const scopeEach  = state.disciplineAttendancesScope === 'each';

  container.innerHTML = `
    <div style="margin-top: 14px; padding: 12px; border: 1px solid #c4b5fd; border-radius: 8px; background: #faf5ff;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; gap: 8px; flex-wrap: wrap;">
        <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #7c3aed;">Selecciona exactamente ${n} disciplina${n !== 1 ? 's' : ''}</div>
        <div id="discipline-step3-counter" style="font-size: 11px; font-weight: 700; color: ${counterColor}; white-space: nowrap;">${selCount}/${n} seleccionadas</div>
      </div>
      <div style="font-size: 11px; color: #8a93aa; margin-bottom: 10px;">Elige las disciplinas que el usuario debe combinar para obtener este logro.</div>
      <div class="disc-chips-wrap">${individualChip}${disciplineChips}</div>
    </div>
    <div style="margin-top: 12px; padding: 12px; border: 1px solid #c4b5fd; border-radius: 8px; background: #fdf8ff;">
      <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #7c3aed; margin-bottom: 10px;">Asistencias requeridas</div>
      <div class="disc-picker-row">
        <div class="disc-picker-input-col">
          <label style="font-size: 11px; color: #8a93aa; margin-bottom: 4px; display: block;">Cantidad de clases</label>
          <div class="disc-input-inner" style="display: flex; gap: 6px; align-items: center;">
            <input type="number" id="discipline-attendances-input" min="1" max="9999" step="1" placeholder="ej. 5" value="${attVal}" style="flex: 1; min-width: 0; border: 1.5px solid #c4b5fd; border-radius: 6px; padding: 7px 10px; font-size: 13px; outline: none;" oninput="onDisciplineAttendancesInput(this.value)">
            <span style="font-size: 11px; color: #8a93aa; font-weight: 600; white-space: nowrap;">clases</span>
          </div>
        </div>
        <div class="disc-picker-scope-col">
          <label style="font-size: 11px; color: #8a93aa; margin-bottom: 4px; display: block;">¿Cómo se cuenta?</label>
          <div class="disc-scope-cards-row">
            <div class="disc-scope-card" data-scope="total" onclick="selectDisciplineAttendancesScope(this)" style="flex: 1; border: 2px solid ${scopeTotal ? '#7c3aed' : '#dde4f0'}; background: ${scopeTotal ? '#f3e8ff' : 'white'}; border-radius: 8px; padding: 8px 10px; cursor: pointer; text-align: center; transition: all 0.15s;">
              <div class="disc-scope-icon" style="font-size: 20px; margin-bottom: 3px;">🔢</div>
              <div style="font-size: 11px; font-weight: 700; color: ${scopeTotal ? '#4c1d95' : '#556'};">En total</div>
              <div class="disc-scope-desc" style="font-size: 10px; color: #8a93aa; margin-top: 2px; line-height: 1.3;">Entre todas las disciplinas</div>
            </div>
            <div class="disc-scope-card" data-scope="each" onclick="selectDisciplineAttendancesScope(this)" style="flex: 1; border: 2px solid ${scopeEach ? '#7c3aed' : '#dde4f0'}; background: ${scopeEach ? '#f3e8ff' : 'white'}; border-radius: 8px; padding: 8px 10px; cursor: pointer; text-align: center; transition: all 0.15s;">
              <div class="disc-scope-icon" style="font-size: 20px; margin-bottom: 3px;">🎯</div>
              <div style="font-size: 11px; font-weight: 700; color: ${scopeEach ? '#4c1d95' : '#556'};">En cada una</div>
              <div class="disc-scope-desc" style="font-size: 10px; color: #8a93aa; margin-top: 2px; line-height: 1.3;">Por disciplina elegida</div>
            </div>
          </div>
        </div>
      </div>
      <div id="discipline-attendances-error" style="display:none; font-size: 11px; color: #dc2626; margin-top: 6px;"></div>
    </div>`;
}

function toggleDisciplineStep3(el) {
  const raw = el.dataset.disciplineId;
  if (raw === undefined) return;
  const disciplineId = parseInt(raw, 10);
  if (isNaN(disciplineId)) return;
  const maxCount = Number(state.threshold);

  if (state.disciplineIds.includes(disciplineId)) {
    state.disciplineIds = state.disciplineIds.filter(id => id !== disciplineId);
  } else {
    if (state.disciplineIds.length >= maxCount) return; // ya al límite
    state.disciplineIds = [...state.disciplineIds, disciplineId];
  }

  // Actualizar visual chips en step 3
  document.querySelectorAll('#discipline-picker-step3 .discipline-chip').forEach(chip => {
    const chipId = parseInt(chip.dataset.disciplineId, 10);
    const sel = state.disciplineIds.includes(chipId);
    const isIndiv = chipId === INDIVIDUAL_DISCIPLINE_ID;
    if (sel) {
      chip.classList.add('selected');
      chip.style.borderColor = isIndiv ? '#7c3aed' : '#2a5bd7';
      chip.style.background  = isIndiv ? '#f3e8ff' : '#eef2ff';
      chip.style.color       = isIndiv ? '#4c1d95' : '#1a2340';
    } else {
      chip.classList.remove('selected');
      chip.style.borderColor = '#dde4f0';
      chip.style.background  = 'white';
      chip.style.color       = '#444';
    }
  });

  // Actualizar contador
  const counter = document.getElementById('discipline-step3-counter');
  if (counter) {
    counter.textContent = `${state.disciplineIds.length}/${maxCount} seleccionadas`;
    counter.style.color = state.disciplineIds.length === maxCount ? '#16a34a' : '#f59e0b';
  }

  updatePreview();
  checkStep3();
}

function onDisciplineAttendancesInput(value) {
  const num = parseInt(value, 10);
  const isValid = !isNaN(num) && num >= 1 && String(num) === String(value).trim();
  state.disciplineAttendances = isValid ? num : null;
  const errEl = document.getElementById('discipline-attendances-error');
  if (errEl) {
    if (value !== '' && !isValid) {
      errEl.textContent = 'Ingresa un número entero positivo (sin decimales).';
      errEl.style.display = 'block';
    } else {
      errEl.style.display = 'none';
    }
  }
  updatePreview();
  checkStep3();
}

function selectDisciplineAttendancesScope(el) {
