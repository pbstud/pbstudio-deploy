function renderInstructorPickerStep3() {
  const container = document.getElementById('instructor-picker-step3');
  if (!container) return;

  if (!activeInstructors.length) {
    container.innerHTML = `<div style="margin-top: 14px; padding: 10px; border: 1px dashed #d9deea; background: #f9fafd; border-radius: 8px; font-size: 11px; color: #8a93aa;">No hay instructores activos disponibles.</div>`;
    return;
  }

  const chips = activeInstructors.map(inst => {
    const sel = state.instructorIds.includes(Number(inst.id));
    return `<div class="instructor-chip${sel ? ' selected' : ''}" data-instructor-id="${inst.id}"
      style="border: 2px solid ${sel ? '#0e7490' : '#dde4f0'}; background: ${sel ? '#ecfeff' : 'white'}; color: ${sel ? '#164e63' : '#444'}; border-radius: 20px; padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s;"
      onclick="toggleInstructorStep3(this)">🤵 ${inst.name}</div>`;
  }).join('');

  const isSingle = state.cond === 'instructor_consistency';
  const title = isSingle ? 'Instructor a evaluar' : 'Instructor(es) a evaluar';
  const hint = isSingle
    ? 'Selecciona el instructor con quien el cliente debe mantener la racha de semanas consecutivas.'
    : 'Selecciona uno o más instructores. El logro contará las clases impartidas por cualquiera de ellos.';
  const selCount = state.instructorIds.length;
  const counterText = isSingle
    ? (selCount === 1 ? '✓ Seleccionado' : 'Selecciona 1')
    : `${selCount} seleccionado${selCount !== 1 ? 's' : ''}`;
  const counterColor = (isSingle ? selCount === 1 : selCount > 0) ? '#16a34a' : '#f59e0b';
  container.innerHTML = `
    <div style="margin-top: 14px; padding: 12px; border: 1px solid #a5f3fc; border-radius: 8px; background: #f0fdff;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
        <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #0e7490;">${title}</div>
        <div id="instructor-step3-counter" style="font-size: 11px; font-weight: 700; color: ${counterColor};">${counterText}</div>
      </div>
      <div style="font-size: 11px; color: #8a93aa; margin-bottom: 10px;">${hint}</div>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">${chips}</div>
    </div>`;
}

function toggleInstructorStep3(el) {
  const raw = el.dataset.instructorId;
  if (raw === undefined) return;
  const instructorId = parseInt(raw, 10);
  if (isNaN(instructorId)) return;

  const isSingle = state.cond === 'instructor_consistency';

  if (isSingle) {
    // Selección única: reemplazar siempre (deseleccionar si ya estaba)
    state.instructorIds = state.instructorIds.includes(instructorId) ? [] : [instructorId];
  } else {
    if (state.instructorIds.includes(instructorId)) {
      state.instructorIds = state.instructorIds.filter(id => id !== instructorId);
    } else {
      state.instructorIds = [...state.instructorIds, instructorId];
    }
  }

  // Actualizar visual chips
  document.querySelectorAll('#instructor-picker-step3 .instructor-chip').forEach(chip => {
    const chipId = parseInt(chip.dataset.instructorId, 10);
    const sel = state.instructorIds.includes(chipId);
    if (sel) {
      chip.classList.add('selected');
      chip.style.borderColor = '#0e7490';
      chip.style.background = '#ecfeff';
      chip.style.color = '#164e63';
    } else {
      chip.classList.remove('selected');
      chip.style.borderColor = '#dde4f0';
      chip.style.background = 'white';
      chip.style.color = '#444';
    }
  });

  // Actualizar contador
  const counter = document.getElementById('instructor-step3-counter');
  if (counter) {
    const count = state.instructorIds.length;
    if (isSingle) {
      counter.textContent = count === 1 ? '✓ Seleccionado' : 'Selecciona 1';
      counter.style.color = count === 1 ? '#16a34a' : '#f59e0b';
    } else {
      counter.textContent = `${count} seleccionado${count !== 1 ? 's' : ''}`;
      counter.style.color = count > 0 ? '#16a34a' : '#f59e0b';
    }
  }

  updatePreview();
  checkStep3();
}

function renderTimeSlotPickerStep3() {
  const container = document.getElementById('timeslot-picker-step3');
  if (!container) return;
  if (!state.customTimeSlots) state.customTimeSlots = [];

  const predefinedChips = timeSlots.map(slot => {
    const sel = state.timeSlotIds.includes(slot.value);
    return `<div class="timeslot-chip${sel ? ' selected' : ''}" data-slot="${slot.value}"
      style="border: 2px solid ${sel ? '#0f766e' : '#dde4f0'}; background: ${sel ? '#f0fdfa' : 'white'}; color: ${sel ? '#134e4a' : '#444'}; border-radius: 20px; padding: 5px 12px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap;"
      onclick="toggleTimeSlotStep3('${slot.value}')">⏰ ${slot.label}</div>`;
  }).join('');

  const customChips = state.customTimeSlots.map((slot, idx) => {
    const sel = state.timeSlotIds.includes(slot.value);
    return `<div style="display:inline-flex; align-items:center; border: 2px solid ${sel ? '#0f766e' : '#2a5bd7'}; background: ${sel ? '#f0fdfa' : '#f0f4ff'}; border-radius: 20px; overflow:hidden;">
      <div class="timeslot-chip${sel ? ' selected' : ''}" data-slot="${slot.value}"
        style="padding: 5px 6px 5px 12px; font-size: 12px; font-weight: 600; cursor: pointer; color: ${sel ? '#134e4a' : '#2a5bd7'};"
        onclick="toggleTimeSlotStep3('${slot.value}')">⏰ ${slot.value}</div>
      <button onclick="removeCustomTimeSlot(${idx})" style="background:none; border:none; border-left:1px solid ${sel ? '#99f6e4' : '#c7d2fe'}; padding: 5px 8px; cursor:pointer; color:#e05c2a; font-size:11px; line-height:1;" title="Eliminar">✕</button>
    </div>`;
  }).join('');

  const selCount = state.timeSlotIds.length;
  const hhOptions = Array.from({length:12}, (_,i) => `<option value="${String(i+1).padStart(2,'0')}">${String(i+1).padStart(2,'0')}</option>`).join('');
  const mmOptions = Array.from({length:60}, (_,i) => `<option value="${String(i).padStart(2,'0')}">${String(i).padStart(2,'0')}</option>`).join('');

  container.innerHTML = `
    <div style="margin-top: 14px; padding: 12px; border: 1px solid #99f6e4; border-radius: 8px; background: #f0fdfa;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
        <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: #0f766e;">Horario(s) a evaluar</div>
        <div style="font-size: 11px; font-weight: 700; color: ${selCount > 0 ? '#16a34a' : '#f59e0b'};">${selCount} seleccionado${selCount !== 1 ? 's' : ''}</div>
      </div>
      <div style="font-size: 11px; color: #8a93aa; margin-bottom: 10px;">Selecciona el o los horarios en los que el cliente debe asistir consecutivamente.</div>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">${predefinedChips}</div>
      ${state.customTimeSlots.length > 0 ? `
        <div style="border-top: 1px solid #c6f0ea; padding-top: 8px; margin-top: 8px;">
          <div style="font-size: 10px; font-weight: 600; color: #0f766e; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;">Personalizados</div>
          <div style="display: flex; flex-wrap: wrap; gap: 8px;">${customChips}</div>
        </div>` : ''}
      <div style="border-top: 1px solid #c6f0ea; padding-top: 8px; margin-top: 8px;">
        <button onclick="showAddCustomSlotForm()" id="btn-add-custom-slot" style="background:#eef2ff; color:#2a5bd7; border:1.5px dashed #2a5bd7; border-radius:16px; padding:5px 14px; font-size:11px; font-weight:700; cursor:pointer;">+ Horario personalizado</button>
        <div id="custom-slot-form" style="display:none; margin-top:8px; align-items:flex-end; gap:8px; background:white; border:1.5px solid #2a5bd7; border-radius:8px; padding:8px 12px; flex-wrap:wrap;">
          <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
            <span style="font-size:10px; color:#8a93aa; font-weight:600;">HH</span>
            <select id="custom-slot-hh" style="font-size:13px; font-weight:700; border:1px solid #dde4f0; border-radius:4px; padding:2px 4px; color:#1a2340; background:white;">${hhOptions}</select>
          </div>
          <span style="font-size:18px; font-weight:700; color:#556; padding-bottom:4px;">:</span>
          <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
            <span style="font-size:10px; color:#8a93aa; font-weight:600;">MM</span>
            <select id="custom-slot-mm" style="font-size:13px; font-weight:700; border:1px solid #dde4f0; border-radius:4px; padding:2px 4px; color:#1a2340; background:white;">${mmOptions}</select>
          </div>
          <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
            <span style="font-size:10px; color:#8a93aa; font-weight:600;">AM/PM</span>
            <select id="custom-slot-ampm" style="font-size:13px; font-weight:700; border:1px solid #dde4f0; border-radius:4px; padding:4px 6px; color:#1a2340; background:white;">
              <option value="am">AM</option>
              <option value="pm">PM</option>
            </select>
          </div>
          <div style="display:flex; gap:4px; padding-bottom:2px;">
            <button onclick="confirmAddCustomSlot()" style="background:#2a5bd7; color:white; border:none; border-radius:6px; padding:6px 12px; font-size:11px; font-weight:700; cursor:pointer;">✓ Agregar</button>
            <button onclick="cancelAddCustomSlot()" style="background:#f0f2f7; color:#556; border:1px solid #dde4f0; border-radius:6px; padding:6px 8px; font-size:11px; cursor:pointer;">✕</button>
          </div>
        </div>
      </div>
    </div>`;
}

function toggleTimeSlotStep3(slotValue) {
  if (!slotValue) return;
  if (state.timeSlotIds.includes(slotValue)) {
    state.timeSlotIds = state.timeSlotIds.filter(s => s !== slotValue);
  } else {
    state.timeSlotIds = [...state.timeSlotIds, slotValue];
  }
  renderTimeSlotPickerStep3();
  updatePreview();
  checkStep3();
}

function showAddCustomSlotForm() {
  const btn = document.getElementById('btn-add-custom-slot');
  const form = document.getElementById('custom-slot-form');
  if (btn) btn.style.display = 'none';
  if (form) form.style.display = 'flex';
}

function cancelAddCustomSlot() {
  const btn = document.getElementById('btn-add-custom-slot');
  const form = document.getElementById('custom-slot-form');
  if (btn) btn.style.display = '';
  if (form) form.style.display = 'none';
}

function confirmAddCustomSlot() {
  const hh12 = parseInt(document.getElementById('custom-slot-hh').value, 10);
  const mm = document.getElementById('custom-slot-mm').value;
  const ampm = document.getElementById('custom-slot-ampm').value;
  // Convertir de 12h a 24h
  let hh24;
  if (ampm === 'am') {
    hh24 = hh12 === 12 ? 0 : hh12;
  } else {
    hh24 = hh12 === 12 ? 12 : hh12 + 12;
  }
  const value = `${String(hh24).padStart(2,'0')}:${mm}`;
  if (!state.customTimeSlots) state.customTimeSlots = [];
  // Si ya existe en predefinidos, solo seleccionarlo
  if (timeSlots.some(s => s.value === value)) {
    if (!state.timeSlotIds.includes(value)) state.timeSlotIds = [...state.timeSlotIds, value];
    renderTimeSlotPickerStep3();
    updatePreview();
    checkStep3();
    return;
  }
  // Si ya existe en personalizados, solo seleccionarlo
  if (state.customTimeSlots.some(s => s.value === value)) {
    if (!state.timeSlotIds.includes(value)) state.timeSlotIds = [...state.timeSlotIds, value];
    renderTimeSlotPickerStep3();
    updatePreview();
    checkStep3();
    return;
  }
  // Nuevo slot personalizado: agregar y auto-seleccionar
  state.customTimeSlots = [...state.customTimeSlots, { value }];
  state.timeSlotIds = [...state.timeSlotIds, value];
  renderTimeSlotPickerStep3();
  updatePreview();
  checkStep3();
}

function removeCustomTimeSlot(idx) {
  if (!state.customTimeSlots) return;
  const slot = state.customTimeSlots[idx];
  if (slot) {
    state.timeSlotIds = state.timeSlotIds.filter(s => s !== slot.value);
    state.customTimeSlots = state.customTimeSlots.filter((_, i) => i !== idx);
  }
  renderTimeSlotPickerStep3();
  updatePreview();
  checkStep3();
}

function renderBadges() {
  const grid = document.getElementById('badge-grid');
  const groups = {{ badgesData.groups|json_encode|raw }};

  let html = '';
  groups.forEach((group, gi) => {
    const selectedInGroup = group.badges.some(b => b.key === state.badge);
    const open = gi === 0 || selectedInGroup;
    const groupId = 'bgroup-' + gi;

    html += `
      <div style="width:100%; margin-bottom:3px;">
        <div onclick="toggleBadgeGroup(${gi})" style="display:flex; align-items:center; gap:8px; padding:6px 10px; background:#f5f7fc; border:1px solid #e0e6f0; border-radius:${open ? '8px 8px 0 0' : '8px'}; cursor:pointer; user-select:none;" id="bheader-${gi}">
          <span style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:#556; flex:1;">${group.label}</span>
          <span style="font-size:10px; color:#aab;">${group.badges.length}</span>
          <span id="arrow-${gi}" style="font-size:10px; color:#8a93aa; display:inline-block; transform:${open ? 'rotate(180deg)' : 'rotate(0deg)'}; transition:transform 0.2s;">▼</span>
        </div>
        <div id="${groupId}" style="display:${open ? 'flex' : 'none'}; flex-wrap:wrap; gap:7px; padding:8px; border:1px solid #e0e6f0; border-top:none; border-radius:0 0 8px 8px; background:#fafbfe;">
    `;

    group.badges.forEach(b => {
      const isSelected = state.badge === b.key;
      const selStyle = isSelected
        ? `border-color:${b.color}; background:${b.color}; color:white;`
        : 'border-color:#dde4f0; background:white; color:inherit;';
      const ptsColor = isSelected ? 'rgba(255,255,255,0.75)' : '#8a93aa';
      html += `<div class="badge-card${isSelected ? ' selected' : ''}" data-badge="${b.key}" data-group="${gi}" style="${selStyle} border:2px solid; border-radius:9px; padding:8px 10px; text-align:center; min-width:66px; max-width:80px; cursor:pointer; transition:all 0.15s; --badge-color:${b.color};" onclick="selectBadge(this)">
        <div style="font-size:18px; line-height:1;">${b.icon}</div>
        <div style="font-size:9px; font-weight:700; margin-top:3px; line-height:1.2;">${b.name}</div>
        ${b.pts > 0 ? `<div style="font-size:8px; color:${ptsColor};">${b.pts} pts</div>` : ''}
      </div>`;
    });

    html += `</div></div>`;
  });

  grid.innerHTML = html;
}

function toggleBadgeGroup(gi) {
  const body   = document.getElementById('bgroup-'  + gi);
  const arrow  = document.getElementById('arrow-'   + gi);
  const header = document.getElementById('bheader-' + gi);
  const isOpen = body.style.display !== 'none';
  body.style.display        = isOpen ? 'none'  : 'flex';
  arrow.style.transform     = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
  header.style.borderRadius = isOpen ? '8px'   : '8px 8px 0 0';
}

function selectBadge(el) {
  document.querySelectorAll('.badge-card').forEach(c => {
    c.classList.remove('selected');
    c.style.borderColor = '#dde4f0';
    c.style.background = 'white';
    c.querySelectorAll('div').forEach(d => d.style.color = '');
  });
  el.classList.add('selected');
  const color = el.style.getPropertyValue('--badge-color');
  el.style.borderColor = color;
  el.style.background = color;
  el.querySelectorAll('div').forEach(d => d.style.color = 'white');
  state.badge = el.dataset.badge;

  // Expandir el grupo del badge seleccionado si está colapsado
  const groupIdx = el.dataset.group;
  if (groupIdx !== undefined) {
    const body = document.getElementById('bgroup-' + groupIdx);
    if (body && body.style.display === 'none') {
      toggleBadgeGroup(parseInt(groupIdx));
    }
  }

  // Solo rellenar con defaults si el usuario NO ha editado manualmente
  if (!state.iconManual) {
    state.customIcon = badgeIcons[state.badge] || '';
    const iconInput = document.getElementById('badge-icon-input');
    if (iconInput) iconInput.value = state.customIcon;
  }
  if (!state.labelManual) {
    // Nombre del nivel sin emoji
    const rawLabel = (badgeLabels[state.badge] || '').replace(/^\S+\s/, '');
    state.customLabel = rawLabel;
    const labelInput = document.getElementById('badge-label-input');
    if (labelInput) labelInput.value = rawLabel;
  }
  if (!state.ptsManual) {
    state.customPts = badgePts[state.badge] !== undefined ? String(badgePts[state.badge]) : '';
    const ptsInput = document.getElementById('badge-pts-input');
    if (ptsInput) ptsInput.value = state.customPts;
  }

  updatePreview();
  checkStep4();
}

function onCustomIconInput() {
  const val = (document.getElementById('badge-icon-input')?.value || '').trim();
  state.customIcon = val;
  state.iconManual = val !== '';
  updatePreview();
}

function onCustomLabelInput() {
  const val = (document.getElementById('badge-label-input')?.value || '').trim();
  state.customLabel = val;
  state.labelManual = val !== '';
  updatePreview();
}

function onCustomPtsInput() {
  const val = (document.getElementById('badge-pts-input')?.value || '').trim();
  state.customPts = val;
  state.ptsManual = val !== '';
  updatePreview();
}

