{% extends 'backend/layout.html.twig' %}

{% set page_section = 'Páginas' %}
{% set page_title   = 'Contenido · Página de Clases' %}
{% set return_to    = path('backend_page') %}

{% set slug_labels = {
    'pilates-reformer': 'Pilates Reformer',
    'beastformer':      'BeastFormer',
    'dual-pilates':     'Dual Pilates',
    'clase-privada':    'Clase Privada'
} %}

{% set field_labels = {
    'audience':    'Audiencia',
    'duration':    'Duración',
    'intensity':   'Intensidad',
    'focus':       'Enfoque principal',
    'summary':     'Resumen (tarjeta)',
    'description': 'Descripción (modal)'
} %}

{% set array_labels = {
    'bestFor':     'Ideal para…',
    'keyPostures': 'Ejercicios / posturas clave',
    'guidedFlow':  'Flujo guiado',
    'benefits':    'Beneficios',
    'tips':        'Tips'
} %}

{% block content %}
<div class="">
    <div class="page-title">
        <div class="title_left">
            <h3>
                <a href="{{ return_to }}" class="btn btn-default btn-return-to">
                    <i class="fa fa-chevron-left" aria-hidden="true"></i>
                </a>
                {{ page_section }}
            </h3>
        </div>
    </div>
    <div class="clearfix"></div>

    <div class="row">
        <div class="col-md-12 col-sm-12">
            <div class="x_panel">
                <div class="x_title">
                    <h2>
                        {{ page_title }}
                        {% if post %}
                            &nbsp;<small class="text-success"><i class="fa fa-check-circle"></i> Guardado en BD{% if post.updatedAt %} · {{ post.updatedAt|date('d/m/Y H:i') }}{% endif %}</small>
                        {% else %}
                            &nbsp;<small class="text-warning"><i class="fa fa-exclamation-triangle"></i> Sin datos guardados — ejecuta <code>php bin/console app:class-content:seed</code> o guarda el formulario</small>
                        {% endif %}
                    </h2>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content">

                    {% for msg in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible" role="alert">
                            <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                            <i class="fa fa-check-circle"></i> {{ msg }}
                        </div>
                    {% endfor %}

                    {% if data is empty %}
                        <div class="alert alert-info">
                            <i class="fa fa-info-circle"></i>
                            No hay contenido guardado aún. El formulario muestra campos vacíos.
                            Guarda para crear el registro en BD, o ejecuta
                            <code>php bin/console app:class-content:seed</code> para cargar los textos predeterminados.
                        </div>
                    {% endif %}

                    <form method="POST" action="{{ path('backend_class_content') }}" class="form-horizontal form-label-left">

                        {# ── ENCABEZADO DE PÁGINA ──────────────────────────────── #}
                        <div class="panel panel-default" style="margin-bottom:20px;">
                            <div class="panel-heading">
                                <strong><i class="fa fa-font"></i> Encabezado de la página /clases</strong>
                            </div>
                            <div class="panel-body">
                                <div class="form-group">
                                    <label class="control-label col-md-2 col-sm-3">Título</label>
                                    <div class="col-md-7 col-sm-9">
                                        <input type="text"
                                               name="header[title]"
                                               class="form-control"
                                               maxlength="120"
                                               placeholder="Nuestras clases"
                                               value="{{ data.header.title ?? '' }}">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="control-label col-md-2 col-sm-3">Subtítulo</label>
                                    <div class="col-md-7 col-sm-9">
                                        <textarea name="header[subtitle]"
                                                  class="form-control"
                                                  rows="2"
                                                  maxlength="300"
                                                  placeholder="Conoce los tipos de clases que ofrecemos…">{{ data.header.subtitle ?? '' }}</textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# ── TABS POR CLASE ────────────────────────────────────── #}
                        <ul class="nav nav-tabs" role="tablist" style="margin-bottom:0; border-bottom: 2px solid #ddd;">
                            {% for slug in slugs %}
                                <li role="presentation"{% if loop.first %} class="active"{% endif %}>
                                    <a href="#tab-{{ slug }}" role="tab" data-toggle="tab" style="font-weight:600;">
                                        {{ slug_labels[slug] ?? slug }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>

                        <div class="tab-content" style="border:1px solid #ddd; border-top:none; padding:24px 20px 10px; margin-bottom:20px; background:#fff;">
                            {% for slug in slugs %}
                                {% set classData = data.classes[slug] ?? {} %}
                                <div id="tab-{{ slug }}" class="tab-pane{% if loop.first %} active{% endif %}">

                                    <p class="text-muted" style="margin-top:0; margin-bottom:16px; font-size:12px;">
                                        <i class="fa fa-info-circle"></i>
                                        Slug en URL: <code>/clases/{{ slug }}</code>
                                    </p>

                                    {# ── Campos de texto ── #}
                                    {% for field in scalarFields %}
                                        <div class="form-group">
                                            <label class="control-label col-md-2 col-sm-3">
                                                {{ field_labels[field] ?? field }}
                                            </label>
                                            <div class="col-md-8 col-sm-9">
                                                {% if field in ['summary', 'description'] %}
                                                    <textarea name="classes[{{ slug }}][{{ field }}]"
                                                              class="form-control"
                                                              rows="{{ field == 'description' ? 4 : 2 }}"
                                                              maxlength="400">{{ classData[field] ?? '' }}</textarea>
                                                    <span class="help-block" style="font-size:11px;">
                                                        {% if field == 'summary' %}Aparece en la tarjeta de la grilla de clases.{% endif %}
                                                        {% if field == 'description' %}Aparece en el modal de detalle al hacer clic en la clase.{% endif %}
                                                    </span>
                                                {% else %}
                                                    <input type="text"
                                                           name="classes[{{ slug }}][{{ field }}]"
                                                           class="form-control"
                                                           maxlength="120"
                                                           value="{{ classData[field] ?? '' }}">
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endfor %}

                                    <div class="ln_solid"></div>

                                    {# ── Campos de lista ── #}
                                    {% for field in arrayFields %}
                                        {% set items = classData[field] ?? [] %}
                                        <div class="form-group">
                                            <label class="control-label col-md-2 col-sm-3" style="padding-top:0;">
                                                {{ array_labels[field] ?? field }}
                                            </label>
                                            <div class="col-md-8 col-sm-9">
                                                <div class="cc-items" id="{{ slug }}-{{ field }}-items">
                                                    {% for item in items %}
                                                        <div class="input-group cc-item" style="margin-bottom:5px;">
                                                            <input type="text"
                                                                   name="classes[{{ slug }}][{{ field }}][]"
                                                                   class="form-control"
                                                                   maxlength="220"
                                                                   value="{{ item }}">
                                                            <span class="input-group-btn">
                                                                <button type="button" class="btn btn-danger btn-sm cc-remove" title="Eliminar">
                                                                    <i class="fa fa-times"></i>
                                                                </button>
                                                            </span>
                                                        </div>
                                                    {% else %}
                                                        {# Sin datos guardados: 3 líneas vacías para comenzar #}
                                                        {% for i in 1..3 %}
                                                            <div class="input-group cc-item" style="margin-bottom:5px;">
                                                                <input type="text"
                                                                       name="classes[{{ slug }}][{{ field }}][]"
                                                                       class="form-control"
                                                                       maxlength="220"
                                                                       value="">
                                                                <span class="input-group-btn">
                                                                    <button type="button" class="btn btn-danger btn-sm cc-remove" title="Eliminar">
                                                                        <i class="fa fa-times"></i>
                                                                    </button>
                                                                </span>
                                                            </div>
                                                        {% endfor %}
                                                    {% endfor %}
                                                </div>
                                                <button type="button"
                                                        class="btn btn-default btn-xs cc-add"
                                                        data-container="{{ slug }}-{{ field }}-items"
                                                        data-name="classes[{{ slug }}][{{ field }}][]">
                                                    <i class="fa fa-plus"></i> Agregar línea
                                                </button>
                                                <span class="help-block" style="font-size:11px;">Máximo 8. Las líneas en blanco se ignoran al guardar.</span>
                                            </div>
                                        </div>
                                    {% endfor %}

                                </div>{# /tab-pane #}
                            {% endfor %}
                        </div>{# /tab-content #}

                        <div class="ln_solid"></div>
                        <div class="form-group">
                            <div class="col-xs-12">
                                <div class="pull-right">
                                    <a href="{{ return_to }}" class="btn btn-default" style="margin-right:8px;">Cancelar</a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa fa-save"></i> Guardar cambios
                                    </button>
                                </div>
                            </div>
                        </div>

                    </form>

                </div>{# /x_content #}
            </div>{# /x_panel #}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function () {
        // Agregar línea a una lista
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.cc-add');
            if (!btn) return;

            var containerId = btn.getAttribute('data-container');
            var fieldName   = btn.getAttribute('data-name');
            var container   = document.getElementById(containerId);
            if (!container) return;

            if (container.querySelectorAll('.cc-item').length >= 8) {
                alert('Máximo 8 elementos por sección.');
                return;
            }

            var div = document.createElement('div');
            div.className = 'input-group cc-item';
            div.style.marginBottom = '5px';
            div.innerHTML =
                '<input type="text" name="' + fieldName + '" class="form-control" maxlength="220" value="">' +
                '<span class="input-group-btn">' +
                    '<button type="button" class="btn btn-danger btn-sm cc-remove" title="Eliminar">' +
                        '<i class="fa fa-times"></i>' +
                    '</button>' +
                '</span>';
            container.appendChild(div);
            div.querySelector('input').focus();
        });

        // Eliminar línea de una lista
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.cc-remove');
            if (!btn) return;
            var item = btn.closest('.cc-item');
            if (item) item.remove();
        });
    })();
    </script>
{% endblock %}
