{% extends 'backend/layout.html.twig' %}

{% block title %}Sin acceso{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-md-6 col-md-offset-3 col-sm-8 col-sm-offset-2">
            <div class="x_panel">
                <div class="x_title">
                    <h2><i class="fa fa-lock"></i> Acceso restringido</h2>
                    <div class="clearfix"></div>
                </div>
                <div class="x_content" style="padding: 30px 20px; text-align: center;">
                    <p style="font-size: 64px; color: #e74c3c; margin: 0 0 10px;">
                        <i class="fa fa-ban"></i>
                    </p>
                    <h3 style="margin-top: 0;">No tienes permiso para acceder a esta sección</h3>
                    <p class="text-muted">
                        Si crees que esto es un error, comunícate con el administrador del sistema.
                    </p>
                    <div style="margin-top: 30px;">
                        <a href="javascript:history.back()" class="btn btn-default">
                            <i class="fa fa-arrow-left"></i> Volver atrás
                        </a>
                        &nbsp;
                        <a href="{{ path('backend_dashboard') }}" class="btn btn-primary">
                            <i class="fa fa-home"></i> Ir al dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
