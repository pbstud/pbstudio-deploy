{{ form_start(form, {'attr': {'id': 'form-branch-office'}}) }}
    <div class="row">
        {{ form_row(form.name, {'row_attr': {'class': 'col-md-6'}}) }}
        {{ form_row(form.place, {'row_attr': {'class': 'col-md-6'}}) }}
    </div>

    <div class="row">
        {{ form_row(form.zone, {'row_attr': {'class': 'col-md-6'}}) }}
        {{ form_row(form.plaza, {'row_attr': {'class': 'col-md-6'}}) }}
    </div>

    <div class="row">
        {{ form_row(form.address, {'row_attr': {'class': 'col-md-12'}}) }}
    </div>

    <div class="row">
        {{ form_row(form.phone, {'row_attr': {'class': 'col-md-6'}}) }}
        {{ form_row(form.public, {'row_attr': {'class': 'col-md-6'}}) }}
    </div>

    <div class="ln_solid"></div>

    {{ include('backend/default/_btn_save.html.twig') }}
{{ form_end(form) }}

<script>
    (function () {
        var form = document.getElementById('form-branch-office');
        if (!form) {
            return;
        }

        var textareas = form.querySelectorAll('textarea.js-autogrow');

        var autoGrow = function (el) {
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
        };

        for (var i = 0; i < textareas.length; i++) {
            autoGrow(textareas[i]);
            textareas[i].addEventListener('input', function () {
                autoGrow(this);
            });
        }
    })();
</script>
