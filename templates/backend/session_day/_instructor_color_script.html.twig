<script>
    (function () {
        var softPalette = [
            '#D9EEF9',
            '#E5F5E1',
            '#FDEBD3',
            '#F8E1EA',
            '#E8E4FA',
            '#DDF3EE',
            '#FBE6DC',
            '#E6EEF7'
        ];

        function hexToRgba(hex, alpha) {
            if (!hex || !/^#[0-9A-Fa-f]{6}$/.test(hex)) {
                return '';
            }

            var r = parseInt(hex.slice(1, 3), 16);
            var g = parseInt(hex.slice(3, 5), 16);
            var b = parseInt(hex.slice(5, 7), 16);

            return 'rgba(' + r + ', ' + g + ', ' + b + ', ' + alpha + ')';
        }

        function resolveFallbackInstructorColor(instructorId) {
            if (!instructorId) {
                return '';
            }

            var numericId = parseInt(instructorId, 10);
            if (!Number.isNaN(numericId)) {
                return softPalette[Math.abs(numericId) % softPalette.length];
            }

            var hash = 0;
            for (var i = 0; i < instructorId.length; i++) {
                hash += instructorId.charCodeAt(i);
            }

            return softPalette[Math.abs(hash) % softPalette.length];
        }

        function applyInstructorColor(selectEl) {
            if (!selectEl) {
                return;
            }

            var cell = selectEl.closest('.js-instructor-cell');
            if (!cell) {
                return;
            }

            var selectedOption = selectEl.options[selectEl.selectedIndex];
            var colorHex = selectedOption ? selectedOption.getAttribute('data-instructor-color') : null;

            if ((!colorHex || !/^#[0-9A-Fa-f]{6}$/.test(colorHex)) && selectedOption) {
                colorHex = resolveFallbackInstructorColor(selectedOption.getAttribute('data-instructor-id'));
            }

            if (colorHex && /^#[0-9A-Fa-f]{6}$/.test(colorHex)) {
                cell.style.backgroundColor = hexToRgba(colorHex, 0.5);
                cell.style.borderLeft = '4px solid ' + colorHex;
                return;
            }

            cell.style.backgroundColor = '';
            cell.style.borderLeft = '';
        }

        function applyCurrentInstructorValue(selectEl) {
            if (!selectEl) {
                return;
            }

            var currentValue = (selectEl.getAttribute('data-current') || '').trim();
            if (!currentValue) {
                return;
            }

            var hasOption = false;
            for (var i = 0; i < selectEl.options.length; i++) {
                if (String(selectEl.options[i].value) === currentValue) {
                    hasOption = true;
                    break;
                }
            }

            if (hasOption) {
                selectEl.value = currentValue;
            }
        }

        function bindInstructorColorScope(root) {
            var scope = root || document;
            var selects = scope.querySelectorAll('.js-instructor-select');

            selects.forEach(function (selectEl) {
                applyCurrentInstructorValue(selectEl);
                applyInstructorColor(selectEl);
                selectEl.addEventListener('change', function () {
                    applyInstructorColor(selectEl);
                });
            });

            if (!window.__instructorColorDelegated) {
                document.addEventListener('change', function (event) {
                    var target = event.target;
                    if (target && target.classList && target.classList.contains('js-instructor-select')) {
                        applyInstructorColor(target);
                    }
                });
                window.__instructorColorDelegated = true;
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function () {
                bindInstructorColorScope(document);
            });
        } else {
            bindInstructorColorScope(document);
        }
    })();
</script>
