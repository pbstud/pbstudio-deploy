{% extends 'mail/layout.html.twig' %}

{% block body %}
    <tr>
        <td align="center" style="font-family:arial,sans-serif; color:#67ccbb; font-size:30px; text-align:center; text-transform:uppercase; font-weight:100">
            Te asignamos un lugar desde lista de espera
        </td>
    </tr>
    <tr>
        <td>
            <table width="600px" style="margin:20px;" class="w320">
                <tr>
                    <td class="blockwrap" style="margin-bottom:10px;">
                        <table width="600px">
                            <tr>
                                <td style="font-family:arial,sans-serif; color:#6D6E70; font-size:16px; text-align:center; padding: 10px;">
                                    <strong>Hola {{ user.name }}</strong>
                                    <br /><br />

                                    Se liberó un lugar en la clase a la que te suscribiste y ya quedó reservado para ti.
                                    <br /><br />
                                    <strong>Importante:</strong> desde este momento cuentas con una ventana de <strong>1 hora</strong>
                                    para cancelar la reservación sin penalización en caso de que ya no puedas asistir.
                                    <br />
                                    Si no cancelas dentro de ese plazo, la reservación se mantiene activa y entra en el modelo de negocio normal.
                                    <br /><br /><br /><br />

                                    <strong style="color:#67ccbb;">Detalles de operación:</strong>

                                    <br />

                                    <p><strong>Clase:</strong> {{ discipline }}</p>
                                    <p><strong>Hora:</strong> {{ session.timeStart|date('h:i a') }}</p>
                                    <p><strong>Fecha:</strong> {{ session.dateStart|format_date(null, "EEEE d 'de' MMMM") }}</p>
                                    <p><strong>Instructor:</strong> {{ instructor.profile.firstname }}</p>
                                    <p><strong>Camilla/Silla:</strong> {{ reservation.placeNumber }}</p>
                                    {% if sentAt is defined %}
                                        <p><strong>Hora de envío del correo:</strong> {{ sentAt|date('d/m/Y h:i a') }}</p>
                                    {% endif %}
                                    {% if graceDeadline is defined %}
                                        <p><strong>Hora límite para cancelar sin penalización:</strong> {{ graceDeadline|date('d/m/Y h:i a') }}</p>
                                    {% endif %}
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
{% endblock %}
