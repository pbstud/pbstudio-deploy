{% extends 'mail/layout.html.twig' %}

{% block body %}
    <tr>
        <td align="center" style="font-family:arial,sans-serif; color:#67ccbb; font-size:30px; text-align:center; text-transform:uppercase; font-weight:100">
            Tus clases de mañana
        </td>
    </tr>
    <tr>
        <td>
            <table width="600px" style="margin:20px;" class="w320">
                <tr>
                    <td class="blockwrap" style="margin-bottom:10px;">
                        <table width="600px">
                            <tr>
                                <td style="font-family:arial,sans-serif; color:#6D6E70; font-size:16px; text-align:center; padding:10px;">
                                    <strong>Hola {{ user.name }}</strong>
                                    <br /><br />

                                    Estas son tus reservaciones para mañana
                                    <strong>{{ targetDate|format_date(null, "EEEE d 'de' MMMM") }}</strong>.
                                    <br /><br /><br />

                                    <strong style="color:#67ccbb;">Detalles de operación:</strong>
                                    <br /><br />

                                    {% for reservation in reservations %}
                                        {% set session = reservation.session %}
                                        <p><strong>Clase {{ loop.index }}:</strong> {{ session.discipline }} {{ session.type|PackageSessionType }}</p>
                                        <p><strong>Hora:</strong> {{ session.timeStart|date('h:i a') }}</p>
                                        <p><strong>Instructor:</strong> {{ session.instructor.profile.firstname }}</p>
                                        <p><strong>Sucursal:</strong> {{ session.branchOffice.name }}</p>
                                        <p><strong>Camilla/Silla:</strong> {{ reservation.placeNumber }}</p>

                                        {% if not loop.last %}
                                            <hr style="border:0; border-top:1px solid #E5E5E5; margin:18px 40px;" />
                                        {% endif %}
                                    {% endfor %}
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td style="font-family:arial,sans-serif; color:#AFAFB1; font-size:13px; text-align:center; padding:10px 20px;">
                        Este resumen se envía una vez al día para evitar correos duplicados.
                    </td>
                </tr>
                <tr>
                    <td style="height:10px;">&nbsp;</td>
                </tr>
            </table>
        </td>
    </tr>
{% endblock %}
