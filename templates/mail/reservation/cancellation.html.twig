{% extends 'mail/layout.html.twig' %}

{% block body %}
    <tr>
        <td align="center" style="font-family:arial,sans-serif; color:#67ccbb; font-size:30px; text-align:center; text-transform:uppercase; font-weight:100">
            Reservación Cancelada
        </td>
    </tr>
    <tr>
        <td>
            <table width="600px" style="margin:20px;" class="w320">
                <tr>
                    <td class="blockwrap" style="margin-bottom:10px;">
                        <table width="600px">
                            <tr>
                                <td style="font-family:arial,sans-serif; color:#6D6E70; font-size:16px; text-align:center; padding: 10px;">
                                    <strong>Hola {{ user.name }}</strong>
                                    <br /><br />

                                    {{ cancellationHeadline|default('Tu reservación ha sido cancelada.') }}
                                    <br /><br /><br /><br />

                                    <strong style="color:#67ccbb;">Detalles de operación:</strong>

                                    <br />

                                    {% if cancellationSource is defined and cancellationSource != 'user' and (isStaffOperationalCancellation is not defined or not isStaffOperationalCancellation) and cancellationTypeLabel is defined and cancellationTypeLabel %}
                                        <p><strong>Tipo de cancelación:</strong> {{ cancellationTypeLabel }}</p>
                                    {% endif %}
                                    <p><strong>Clase:</strong> {{ discipline }}</p>
                                    <p><strong>Hora:</strong> {{ session.timeStart|date('h:i a') }}</p>
                                    <p><strong>Fecha:</strong> {{ session.dateStart|format_date(null, "EEEE d 'de' MMMM") }}</p>
                                    <p><strong>Instructor:</strong> {{ instructor.profile.firstname }}</p>
                                    <p><strong>Fecha de cancelación:</strong> {{ reservation.cancellationAt|format_date(null, "EEEE d 'de' MMMM") }}</p>

                                    {% if isStaffOperationalCancellation is defined and isStaffOperationalCancellation %}
                                        <p style="margin-top:16px;"><strong>¿Necesitas más información?</strong><br />
                                            Esta cancelación fue realizada por motivos operativos del staff. Si deseas más detalles,
                                            presentar una queja o recibir seguimiento, comunícate con nuestro equipo de ayuda en
                                            <strong>contacto@pbstudio.mx</strong>.
                                        </p>
                                    {% endif %}

                                    {% if cancellationSource is defined and cancellationSource != 'user' and cancellationReason is defined and cancellationReason %}
                                        <p><strong>Motivo:</strong> {{ cancellationReason }}</p>
                                    {% endif %}
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
{% endblock %}
