{% extends 'mail/layout.html.twig' %}

{% block body %}
    <tr>
        <td align="center" style="font-family:arial,sans-serif; color:#67ccbb; font-size:30px; text-align:center; text-transform:uppercase; font-weight:100">
            No pudimos procesar tu pago
        </td>
    </tr>
    <tr>
        <td>
            <table width="600px" style="margin:20px;" class="w320">
                <tr>
                    <td class="blockwrap" style="margin-bottom:10px;">
                        <table width="600px">
                            <tr>
                                <td style="font-family:arial,sans-serif; color:#6D6E70; font-size:16px; text-align:center; padding: 10px;">
                                    <strong>Hola {{ user.name }}</strong>
                                    <br /><br />

                                    Intentamos procesar tu pago, pero fue rechazado.
                                    <br /><br /><br />

                                    <strong style="color:#67ccbb;">Detalles del intento:</strong>

                                    <br />

                                    <p><strong>Transacción:</strong> #{{ transaction.id }}</p>
                                    <p><strong>Método:</strong> {{ transaction.chargeMethod|ChargeMethodDescription }}</p>
                                    <p><strong>Motivo:</strong> {{ transaction.errorMessage ?: 'Tu banco/proveedor rechazó el cargo.' }}</p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
{% endblock %}
