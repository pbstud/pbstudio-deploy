{% extends 'mail/layout.html.twig' %}

{% block body %}
    <tr>
        <td align="center" style="font-family:arial,sans-serif; color:#67ccbb; font-size:30px; text-align:center; text-transform:uppercase; font-weight:100">
            Tarjeta de regalo
        </td>
    </tr>
    <tr>
        <td>
            <table width="600px" style="margin:20px;" class="w320">
                <tr>
                    <td class="blockwrap" style="margin-bottom:10px;">
                        <table width="600px">
                            <tr>
                                <td style="font-family:arial,sans-serif; color:#6D6E70; font-size:16px; text-align:center; padding: 10px;">
                                    <strong>Hola {{ user.name }}</strong>
                                    <br /><br />

                                    Se generó una compra como tarjeta de regalo para tu cuenta.
                                    <br />
                                    Usa este código para canjearla desde tu perfil:

                                    <br /><br />

                                    <div style="display:inline-block; padding:14px 18px; border:1px dashed #67ccbb; border-radius:6px; font-size:24px; letter-spacing:2px; color:#2a2a2a; font-weight:bold;">
                                        {{ giftCard.code }}
                                    </div>

                                    <br /><br />

                                    <p style="margin:0;">Si no reconoces esta operación, comunícate con soporte de P&B Studio.</p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
{% endblock %}
