{% extends 'mail/layout.html.twig' %}

{% block body %}
    <tr>
        <td align="center" style="font-family:arial,sans-serif; color:#67ccbb; font-size:30px; text-align:center; text-transform:uppercase; font-weight:100">
            Alerta de seguridad
        </td>
    </tr>
    <tr>
        <td>
            <table width="600px" style="margin:20px;" class="w320">
                <tr>
                    <td class="blockwrap" style="margin-bottom:10px;">
                        <table width="600px">
                            <tr>
                                <td style="font-family:arial,sans-serif; color:#6D6E70; font-size:16px; text-align:center; padding:10px;">
                                    <strong>Hola {{ user.name }}</strong>
                                    <br /><br />

                                    Detectamos un cambio en tus credenciales de acceso.
                                    <br /><br /><br />

                                    <strong style="color:#67ccbb;">Detalles:</strong>

                                    <br />

                                    <p><strong>Tipo de cambio:</strong> {{ credentialLabel }}</p>
                                    {% if oldValue is not null %}
                                        <p><strong>Valor anterior:</strong> {{ oldValue }}</p>
                                    {% endif %}
                                    {% if newValue is not null %}
                                        <p><strong>Valor nuevo:</strong> {{ newValue }}</p>
                                    {% endif %}
                                    {% if ip %}
                                        <p><strong>IP:</strong> {{ ip }}</p>
                                    {% endif %}
                                    {% if userAgent %}
                                        <p><strong>Dispositivo/Navegador:</strong> {{ userAgent }}</p>
                                    {% endif %}

                                    <br />
                                    <p style="color:#AFAFB1; font-size: 0.9em; margin: 0;">
                                        Si no reconoces este cambio, comunícate con soporte de inmediato.
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
{% endblock %}
