<section class="pop_box class-detail-modal">
    <div class="row clearfix">
        <a data-remodal-action="close" class="nav-toggle close" aria-label="Cerrar">
            <span class="iconMenu"></span>
        </a>

        <div class="center class-detail-modal__hero">
            <h3>{{ classDescription.name }}</h3>
            <small>{{ classDescription.focus }}</small>
            <p>{{ classDescription.description }}</p>
        </div>

        <div class="class-detail-modal__chips">
            <span>{{ classDescription.audience }}</span>
            <span>{{ classDescription.duration }}</span>
            <span>Intensidad {{ classDescription.intensity }}</span>
        </div>

        {% set sections = classDescription.sections ?? [] %}
        {% if sections is empty %}
            {% set sections = [
                { title: (classDescription.bestForTitle ?? 'Ideal para ti si...'), items: (classDescription.bestFor ?? []) },
                { title: (classDescription.keyPosturesTitle ?? 'Posturas y guias clave'), items: (classDescription.keyPostures ?? []) },
                { title: (classDescription.guidedFlowTitle ?? 'Como se estructura la clase'), items: (classDescription.guidedFlow ?? []) },
                { title: (classDescription.benefitsTitle ?? 'Beneficios esperados'), items: (classDescription.benefits ?? []) },
                { title: (classDescription.tipsTitle ?? 'Recomendaciones previas'), items: (classDescription.tips ?? []) }
            ] %}
        {% endif %}

        {% set leftSections = [] %}
        {% set rightSections = [] %}
        {% for section in sections %}
            {% if loop.index is odd %}
                {% set leftSections = leftSections|merge([section]) %}
            {% else %}
                {% set rightSections = rightSections|merge([section]) %}
            {% endif %}
        {% endfor %}

        <div class="class-detail-modal__content">
            <div class="class-detail-modal__column">
                {% for section in leftSections %}
                    {% set sectionItems = section.items ?? [] %}
                    {% if sectionItems is not empty %}
                        <h5>{{ section.title ?? 'Sección' }}</h5>
                        <ul>
                            {% for item in sectionItems %}
                                <li>{{ item }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                {% endfor %}
            </div>

            <div class="class-detail-modal__column">
                {% for section in rightSections %}
                    {% set sectionItems = section.items ?? [] %}
                    {% if sectionItems is not empty %}
                        <h5>{{ section.title ?? 'Sección' }}</h5>
                        <ul>
                            {% for item in sectionItems %}
                                <li>{{ item }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                {% endfor %}
            </div>
        </div>

        <div class="modal-actions class-detail-modal__actions">
            <a href="{{ path('reservation_calendar', {'slug': config_first_branch_slug()}) }}{% if classDescription.slug == 'clase-privada' %}?type=i{% else %}?discipline={{ classDescription.name|url_encode }}{% endif %}"
               class="btn"
               data-remodal-action="close">Reservar clase</a>
        </div>
    </div>
</section>
