<section class="pop_box">
    <div class="row clearfix">
        <a data-remodal-action="close" class="nav-toggle close"><span class="iconMenu"></span></a>

        <div class="grid-1-8 right right-container">
            {% if restrictNewUser %}
                <div class="alert error">
                    <p>El paquete seleccionado sólo aplica para nuevos usuarios</p>
                </div>
            {% else %}
                <div class="checkout-form">
                    {% if isGiftMode|default(false) %}
                        <div class="checkout-gift-purchase-banner">
                            <i class="bi bi-gift"></i>
                            <div>
                                <strong>Comprando como regalo</strong>
                                <small>Se generará un código único para compartir. Tú no recibirás las clases.</small>
                            </div>
                        </div>
                        <input type="checkbox" id="is-gift-purchase" checked class="sr-only">
                    {% endif %}
                    <h4 class="checkout-form__title"><span id="checkout-main-title">Datos de pago</span><small id="checkout-main-subtitle">Ingresa los datos de tu tarjeta</small></h4>

                    <div id="checkout-gift-redeem-content" class="hidden checkout-form__field">
                        <div id="checkout-gift-redeem-form">
                            <label class="checkout-form__label" for="gift-card-code-modal">Canjear codigo</label>
                            <div class="checkout-gift-redeem-panel">
                                <input type="text"
                                       id="gift-card-code-modal"
                                       maxlength="64"
                                       placeholder="Ingresa tu codigo"
                                       autocomplete="off"
                                       data-url="{{ path('gift_card_redeem') }}"
                                       data-token="{{ csrf_token('gift_card_redeem') }}">
                                <button type="button" id="btn-gift-card-redeem" class="checkout-gift-redeem-btn">Canjear</button>
                            </div>

                            <div id="checkout-gift-visual" class="checkout-gift-visual checkout-gift-visual--3">
                                <div class="checkout-gift-visual-option checkout-gift-visual-option--3">
                                    <h5>Tu regalo se asigna como un paquete sin costo</h5>
                                    <ul>
                                        <li>Al canjear el codigo, se te activa un paquete nuevo con importe $0.</li>
                                        <li>Este paquete funciona igual que cualquier compra normal: clases, vigencia y reglas del plan.</li>
                                        <li>Cuando termine el canje, podras reservar y usarlo de inmediato desde tu cuenta.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div id="checkout-gift-redeem-success" class="hidden">
                            <div class="checkout-gift-done-header">
                                <span class="checkout-gift-done-check">&#10003;</span>
                                <h5 class="checkout-gift-done-title">¡Código canjeado!</h5>
                            </div>
                            <p class="checkout-gift-done-body">
                                Tu paquete está activo. Ahora puedes reservar tus clases desde el calendario en cualquier momento.
                            </p>
                            <p class="checkout-gift-done-hint">
                                ¿Quieres regalar clases a alguien especial? Compra una tarjeta de regalo desde
                                <a href="{{ path('package_index') }}" data-remodal-action="close">la sección de paquetes</a>
                                y comparte el código con quien quieras.
                            </p>
                            <div class="checkout-gift-done-actions">
                                <a href="{{ path('reservation_calendar') }}" class="btn checkout-gift-action-btn" data-remodal-action="close">Reservar clase</a>
                                <a href="{{ path('profile') }}" class="btn secondary checkout-gift-action-btn" data-remodal-action="close">Ir a mi cuenta</a>
                            </div>
                        </div>
                    </div>

                    <form id="checkout-form" action="{{ path('package_checkout', { 'id': package.id }) }}" method="POST" autocomplete="off">
                        <div class="checkout-form__field">
                            <label class="checkout-form__label">Titular de la tarjeta</label>
                            <input type="text"
                                   data-conekta="card[name]"
                                   placeholder="Nombre como aparece en la tarjeta"
                                   maxlength="100"
                                   autocomplete="cc-name"
                                   required="required">
                        </div>
                        <div class="checkout-form__field">
                            <label class="checkout-form__label">Número de tarjeta</label>
                            <input type="text"
                                   data-conekta="card[number]"
                                   placeholder="0000 0000 0000 0000"
                                   inputmode="numeric"
                                   maxlength="19"
                                   pattern="[0-9\s]{13,19}"
                                   autocomplete="cc-number"
                                   required="required">
                        </div>
                        <div class="checkout-form__row">
                            <div class="checkout-form__field checkout-form__field--expiry">
                                <label class="checkout-form__label">Vigencia</label>
                                <div class="checkout-form__expiry-selects">
                                    <select data-conekta="card[exp_month]" required="required">
                                        <option value="">Mes</option>
                                        {% for i in 1..12 %}
                                            <option value="{{ '%02d'|format(i) }}">{{ '%02d'|format(i) }}</option>
                                        {% endfor %}
                                    </select>
                                    <span class="checkout-form__slash">/</span>
                                    <select data-conekta="card[exp_year]" required="required">
                                        <option value="">Año</option>
                                        {% set startYear = 'now'|date('Y') %}
                                        {% set endYear = startYear + 10 %}
                                        {% for i in startYear..endYear %}
                                            <option value="{{ i }}">{{ i }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="checkout-form__field checkout-form__field--cvv">
                                <label class="checkout-form__label">CVV</label>
                                <input type="text"
                                       data-conekta="card[cvc]"
                                       placeholder="•••"
                                       inputmode="numeric"
                                       maxlength="4"
                                       pattern="[0-9]{3,4}"
                                       autocomplete="off"
                                       required="required">
                            </div>
                        </div>
                        <div id="frm-coupon">
                            <input type="text" id="coupon-field" placeholder="Cupón de descuento" maxlength="50" autocomplete="off">
                            <button type="button" id="btn-coupon" data-url="{{ path('coupon_validate', {'id': package.id}) }}">
                                Aplicar
                            </button>
                        </div>
                        <div id="coupon-valid">
                            <p>
                                Descuento: <span id="coupon-discount"></span>
                            </p>
                            <p>
                                Importe: <span id="coupon-total"></span>
                            </p>
                            <input type="hidden" id="coupon-validated">
                        </div>
                        <button type="submit" class="btn-submit">Comprar</button>
                    </form>
                </div>

                <div class="checkout-success center" style="display:none;">
                    <h3>Tu compra ha sido exitosa<small>¡Comienza ahora!</small></h3>

                    <a href="{{ path('reservation_calendar') }}" class="btn">Reservar clase</a>

                    <a href="{{ path('profile') }}" class="btn secondary">Ir a mi cuenta</a>
                </div>
            {% endif %}
        </div>

        {{ include('package/_checkout_detail.html.twig') }}
    </div>
</section>

<script type="text/javascript">
    checkoutHandler('{{ conektaPublicKey }}');
</script>