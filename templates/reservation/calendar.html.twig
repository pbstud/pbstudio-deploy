{% extends 'layout.html.twig' %}

{% block page_title %}{{ branchOffice.name }} | Horarios y reservas | {% endblock %}

{% block content %}
<div class="rcv2-wrapper" id="reservation-calendar"
     x-data="{ filtersOpen: false }">

    {# ── BARRA SUPERIOR: título mobile + botón toggle filtros ── #}
    <div class="rcv2-topbar">
        <div class="rcv2-topbar__title">
            <h1 class="rcv2-topbar__h1">Reserva tu clase</h1>
            <p class="rcv2-topbar__sub">Elige la fecha, el tipo de clase y tu instructor.</p>
        </div>
        <button
            class="rcv2-filters-btn"
            type="button"
            @click="filtersOpen = !filtersOpen"
            :aria-expanded="filtersOpen"
            aria-controls="rcv2-left-panel"
        >
            <i class="bi bi-sliders2" aria-hidden="true"></i>
            <span x-text="filtersOpen ? 'Cerrar' : 'Filtros'">Filtros</span>
            <i class="bi bi-chevron-down rcv2-filters-btn__chevron"
               :class="filtersOpen && 'rcv2-filters-btn__chevron--open'"
               aria-hidden="true"></i>
        </button>
    </div>

    {# ── LAYOUT DOS COLUMNAS ── #}
    <div class="rcv2-layout" :class="filtersOpen && 'rcv2-layout--filters-open'">

        {# Panel izquierdo: filtros + mini-calendario #}
        <aside id="rcv2-left-panel" class="rcv2-left" aria-label="Filtros de búsqueda">
            {{ include('reservation/_calendar_filters_panel.html.twig') }}
        </aside>

        {# Panel derecho: sesiones #}
        <main class="rcv2-right" id="sessions-panel">
            {% if isDailyView %}
                {{ include('reservation/_calendar_day_list.html.twig') }}
            {% else %}
                {{ include('reservation/_calendar_week_v2.html.twig') }}
            {% endif %}
        </main>

    </div>
</div>
{% endblock %}
