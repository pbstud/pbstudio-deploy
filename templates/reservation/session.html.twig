<section class="pop_box rcv2-modal">

    {# Botón cerrar #}
    <a data-remodal-action="close" class="rcv2-modal__close" aria-label="Cerrar">
        <i class="bi bi-x-lg" aria-hidden="true"></i>
    </a>

    {# ── CUERPO: dos columnas ── #}
    <div class="rcv2-modal__body">

        {# ── Columna izquierda: estado + toggle + mapa + WhatsApp ── #}
        <div class="rcv2-modal__col rcv2-modal__col--left" x-data="{ seatView: 'grid' }">

            {# Encabezado según estado #}
            <div class="rcv2-modal__state">
                {% if not userReservations and session.open %}
                    <p class="rcv2-modal__state-title">¡Tu clase te espera!</p>
                    <p class="rcv2-modal__state-sub">Selecciona un lugar</p>
                {% elseif userReservations %}
                    <p class="rcv2-modal__state-title">¡Ya estás suscrito a esta clase!</p>
                    <p class="rcv2-modal__state-sub">Tu lugar seleccionado</p>
                {% elseif on_waitinglist %}
                    <p class="rcv2-modal__state-title">¡Ya estás en lista de espera!</p>
                    <p class="rcv2-modal__state-sub">Si se libera un lugar, te lo asignaremos automáticamente.</p>
                {% elseif waiting_list_closed %}
                    <p class="rcv2-modal__state-title">¡Ya no hay lugares disponibles!</p>
                    <p class="rcv2-modal__state-sub">Esta clase está llena y la lista de espera cerró 2 horas antes del inicio.</p>
                {% elseif show_waitinglist %}
                    <p class="rcv2-modal__state-title">¡Ya no hay lugares disponibles!</p>
                    <p class="rcv2-modal__state-sub">Regístrate en lista de espera y te avisamos si se libera un lugar.</p>
                {% elseif msg_no_classes_available %}
                    <p class="rcv2-modal__state-title">¡Ya no hay lugares disponibles!</p>
                    <p class="rcv2-modal__state-sub">No cuentas con clases disponibles para la lista de espera.</p>
                {% endif %}
            </div>

            {# Toggle de vista (grid / lista) — solo cuando hay mapa #}
            {% if session.open or userReservations %}
                <div class="rcv2-seat-toggle">
                    <button type="button"
                            class="rcv2-seat-toggle__btn"
                            :class="{ 'active': seatView === 'grid' }"
                            @click="seatView = 'grid'"
                            aria-label="Vista cuadrícula">
                        <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>
                    </button>
                    <button type="button"
                            class="rcv2-seat-toggle__btn"
                            :class="{ 'active': seatView === 'list' }"
                            @click="seatView = 'list'"
                            aria-label="Vista lista">
                        <i class="bi bi-list-ul" aria-hidden="true"></i>
                    </button>
                </div>
            {% endif %}

            {# Mapa de asientos #}
            {% if session.open or userReservations %}
                <div class="rcv2-modal__seats" :class="{ 'rcv2-view-list': seatView === 'list' }">
                    <div class="classroom-layout">
                        <div class="seat-map-frame">
                            {{ include('reservation/_modal_seat_map.html.twig', {
                                mode:         'select',
                                slot_to_seat: slot_to_seat,
                                capacity:     capacity,
                                session:      session,
                                reservations: reservations,
                                user_places:  userReservations
                            }) }}
                        </div>
                    </div>
                </div>
            {% endif %}

            {# WhatsApp help #}
            <a href="{{ config_whatsapp_url() }}"
               target="_blank"
               rel="noopener noreferrer"
               class="rcv2-whatsapp-help">
                <span class="rcv2-whatsapp-help__icon">
                    <i class="bi bi-whatsapp" aria-hidden="true"></i>
                </span>
                <span class="rcv2-whatsapp-help__text">
                    <strong>¿Necesitas ayuda?</strong>
                    Escríbenos por WhatsApp
                </span>
                <i class="bi bi-chevron-right rcv2-whatsapp-help__arrow" aria-hidden="true"></i>
            </a>

        </div>

        {# ── Columna derecha: resumen de clase + CTA ── #}
        <div class="rcv2-modal__col rcv2-modal__col--right">

            {# Resumen de la clase #}
            <div class="rcv2-modal__summary">
                <div class="rcv2-modal__summary-hero">
                    <i class="bi bi-{{ session.individual ? 'person' : 'people-fill' }}" aria-hidden="true"></i>
                    <p class="rcv2-modal__summary-classname">{{ discipline }}</p>
                    <p class="rcv2-modal__summary-time">{{ session.timeStart|date('h:i a') }}</p>
                    <p class="rcv2-modal__summary-instructor">{{ session.instructor.profile.firstname }}</p>
                </div>
                <hr class="rcv2-modal__summary-divider">
                <dl class="rcv2-modal__summary-details">
                    <div class="rcv2-modal__summary-row">
                        <dt><i class="bi bi-calendar3" aria-hidden="true"></i></dt>
                        <dd>Día: {{ session.dateStart|date('d/m/y') }}</dd>
                    </div>
                    <div class="rcv2-modal__summary-row">
                        <dt><i class="bi bi-geo-alt" aria-hidden="true"></i></dt>
                        <dd>
                            {% set branch_label = 'Sucursal: ' ~ session.branchOffice.name %}
                            {% if session.branchOffice.plaza %}
                                {% set branch_label = branch_label ~ ' — ' ~ session.branchOffice.plaza %}
                            {% elseif session.branchOffice.zone %}
                                {% set branch_label = branch_label ~ ' — ' ~ session.branchOffice.zone %}
                            {% endif %}
                            {{ branch_label }}
                        </dd>
                    </div>
                </dl>
            </div>

            {# Aviso de consumo (si aplica) #}
            {% if session.open %}
                {% if consumption_options.unlimitedDailyLimitNotice %}
                    <div class="rcv2-modal__info-box">
                        <i class="bi bi-info-circle" aria-hidden="true"></i>
                        <p><strong>Aviso:</strong> {{ consumption_options.unlimitedDailyLimitNotice }}</p>
                    </div>
                {% elseif consumption_options.forcedPackageNotice %}
                    <div class="rcv2-modal__info-box">
                        <i class="bi bi-info-circle" aria-hidden="true"></i>
                        <p><strong>Aviso:</strong> {{ consumption_options.forcedPackageNotice }}</p>
                    </div>
                {% endif %}

                {% if consumption_options.availableTransactions|length > 1 %}
                    <div class="rcv2-modal__consumption">
                        <label for="consumption_source_selector" class="rcv2-modal__consumption-label">
                            ¿Con qué paquete deseas reservar?
                        </label>
                        <select id="consumption_source_selector" class="rcv2-select rcv2-modal__consumption-select">
                            {% for option in consumption_options.availableTransactions %}
                                <option value="{{ option.value }}">{{ option.label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% endif %}
            {% endif %}

            {# CTA según estado #}
            <div class="rcv2-modal__actions">
                {% if session.open %}
                    <a href="#" class="rcv2-btn-modal rcv2-btn-modal--primary btn-confirm btn-submit">
                        Confirmar reservación
                    </a>
                    <p class="rcv2-modal__trust-badge">
                        <i class="bi bi-lock" aria-hidden="true"></i>
                        Tu reserva está segura
                    </p>
                {% elseif not userReservations and show_waitinglist and not on_waitinglist %}
                    <a href="#" class="rcv2-btn-modal rcv2-btn-modal--secondary btn-waitinglist btn-submit">
                        Suscribirme a lista de espera
                    </a>
                {% elseif msg_no_classes_available %}
                    <p class="rcv2-modal__note">
                        No cuentas con clases disponibles. Adquiere más para poder registrarte en lista de espera.
                    </p>
                {% endif %}
            </div>

        </div>
    </div>

    {# ── FOOTER: nota de política ── #}
    <div class="rcv2-modal__footer">
        <i class="bi bi-stars" aria-hidden="true"></i>
        <p><strong>IMPORTANTE:</strong> Puedes cancelar o reprogramar tu clase hasta 12&nbsp;h antes sin penalización.</p>
    </div>

    {# ── Formularios ocultos — IDs/actions intocables ── #}
    {% if session.open %}
        <form id="frmReservation"
              action="{{ path('reservation_confirm', {'id': session.id}) }}"
              method="post" class="m-fjx">
            <input type="hidden" name="place_number" value="" />
            <input type="hidden" name="consumption_source" value="auto" />
        </form>
    {% elseif not userReservations and show_waitinglist and not on_waitinglist %}
        <form id="frmWaitingList"
              action="{{ path('reservation_waitinglist', {'id': session.id}) }}"
              method="post" class="m-fjx">
            <input type="hidden" name="_token" value="{{ csrf_token('reservation_waitinglist_' ~ session.id) }}" />
        </form>
    {% endif %}

</section>

<script>reservationInit();</script>
