<section class="box-form">
    {% if retry_after %}
        <div class="error" id="authThrottleNotice">
            <p>Demasiados intentos fallidos. Por favor espera <strong id="authThrottleCountdown">30</strong> segundo(s) antes de volver a intentarlo.</p>
        </div>
    {% elseif error %}
        <div class="error">
            <p>{{ error.messageKey|trans(error.messageData, 'security') }}</p>
        </div>
    {% endif %}

    <div class="gradient">
        <a data-remodal-action="close" class="nav-toggle close"><span class="iconMenu"></span></a>
        <div class="row">
            <h3>Iniciar sesión</h3>

            <div>
                <form action="{{ path("app_login") }}" method="post" class="m-fjx">
                    <input type="email" class="form-control" id="username" name="username" value="{{ last_username }}" placeholder="Correo" required>
                    <input type="password" class="form-control" id="password" name="password" placeholder="Contraseña" required>

                    <button type="submit" class="btn-submit" id="authSubmitBtn"{% if retry_after %} disabled{% endif %}>Entrar</button>

                    <div class="remember-me">
                        <label>
                            <input type="checkbox" name="_remember_me" checked> Recordarme
                        </label>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                </form>

                <br>
                <br>
                <br>
                <a href="#" data-url="{{ path('resetting_request', {'_modaltarget': 1}) }}" data-remodal>¿Olvidaste tu contraseña?</a>
            </div>
            <p>
                ¿Aún no tienes cuenta?
                <a href="#" data-url="{{ path('register') }}" data-remodal>¡Regístrate ahora!</a>
            </p>
        </div>
    </div>
</section>

{% if retry_after %}
<script type="text/javascript">
(function () {
    var retryAt = {{ retry_after }} * 1000;
    var countdownEl = document.getElementById('authThrottleCountdown');
    var submitBtn   = document.getElementById('authSubmitBtn');

    function tick() {
        var remaining = Math.ceil((retryAt - Date.now()) / 1000);
        if (remaining <= 0) {
            var notice = document.getElementById('authThrottleNotice');
            if (notice) { notice.style.display = 'none'; }
            if (submitBtn) { submitBtn.disabled = false; }
            return;
        }
        if (countdownEl) { countdownEl.textContent = remaining; }
        setTimeout(tick, 500);
    }
    tick();
})();
</script>
{% endif %}
