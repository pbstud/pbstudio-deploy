{#
  Componente: Toast / notificación inline
  Uso: se muestra via Alpine store o JS directo.
  El contenedor se coloca una vez en base.html.twig.

  Para lanzar desde JS:
    Alpine.store('toast').show('Mensaje guardado', 'success')
    Alpine.store('toast').show('Algo salió mal', 'error')
    Alpine.store('toast').show('Atención', 'warning')
#}
<div
    x-data
    x-show="$store.toast.visible"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-4"
    :class="{
        'bg-charcoal text-white':        $store.toast.type === 'success',
        'bg-red-600 text-white':         $store.toast.type === 'error',
        'bg-amber-500 text-white':       $store.toast.type === 'warning',
        'bg-brand-teal text-charcoal':   $store.toast.type === 'info'
    }"
    class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 px-5 py-3 rounded-full shadow-lg text-sm font-medium max-w-sm w-max"
    role="status"
    aria-live="polite"
    style="display: none;"
>
    <span x-text="$store.toast.message"></span>
    <button type="button" @click="$store.toast.hide()" class="opacity-70 hover:opacity-100 transition-opacity" aria-label="Cerrar">
        <i class="bi bi-x-lg text-xs" aria-hidden="true"></i>
    </button>
</div>
