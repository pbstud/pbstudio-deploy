{% extends 'layout.html.twig' %}

{% block page_title %}Mis notificaciones | {% endblock %}

{% block content %}
    <section class="bg-sand min-h-[calc(100vh-4rem)] py-8 md:py-12">
        <div class="max-w-4xl mx-auto px-4 sm:px-6">
            <div class="bg-white rounded-2xl border border-linen shadow-sm overflow-hidden">
                <header class="px-5 sm:px-7 pt-6 pb-4 border-b border-linen">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <h1 class="text-2xl sm:text-3xl font-bold text-charcoal">Centro de notificaciones</h1>
                            <p class="text-sm text-muted mt-1">Registro histórico.</p>
                        </div>
                    </div>
                </header>

                {% if notifications is empty %}
                    <div class="px-6 py-16 text-center">
                        <div class="w-16 h-16 rounded-full bg-sand mx-auto mb-4 flex items-center justify-center text-muted">
                            <i class="bi bi-bell-slash text-3xl"></i>
                        </div>
                        <p class="notifications-empty text-base">No tienes notificaciones aun.</p>
                    </div>
                {% else %}
                    {%- set unread_filters = { unread: 0, reserva: 0, logro: 0, paquetes: 0 } -%}
                    {%- for n in notifications -%}
                        {%- set ntype = (n.type|default('')|lower) -%}
                        {%- set category = 'sistema' -%}
                        {%- if ntype starts with 'achievement_' -%}
                            {%- set category = 'logro' -%}
                        {%- elseif ntype starts with 'package_'
                            or ntype starts with 'payment_'
                            or ntype starts with 'checkout_'
                            or ntype starts with 'transaction_' -%}
                            {%- set category = 'paquetes' -%}
                        {%- elseif ntype starts with 'reservation_'
                            or ntype starts with 'waiting_list_'
                            or ntype starts with 'waitlist_'
                            or ntype starts with 'lista_espera_'
                            or ntype starts with 'class_'
                            or ntype starts with 'session_'
                            or ntype starts with 'rating_' -%}
                            {%- set category = 'reserva' -%}
                        {%- endif -%}
                        {%- if n.readAt is null -%}
                            {%- set unread_filters = unread_filters|merge({
                                unread: unread_filters.unread + 1,
                                (category): attribute(unread_filters, category) + 1
                            }) -%}
                        {%- endif -%}
                    {%- endfor -%}

                    {%- set today = "now"|date("Y-m-d") -%}
                    {%- set yesterday = "-1 day"|date("Y-m-d") -%}

                    {%- set groups = { hoy: [], ayer: [], semana: [], anteriores: [] } -%}
                    {%- for n in notifications -%}
                        {%- set d = n.createdAt|date("Y-m-d") -%}
                        {%- if d == today -%}
                            {%- set groups = groups|merge({ hoy: groups.hoy|merge([n]) }) -%}
                        {%- elseif d == yesterday -%}
                            {%- set groups = groups|merge({ ayer: groups.ayer|merge([n]) }) -%}
                        {%- elseif n.createdAt|date("U") >= ("now - 7 days"|date("U")) -%}
                            {%- set groups = groups|merge({ semana: groups.semana|merge([n]) }) -%}
                        {%- else -%}
                            {%- set groups = groups|merge({ anteriores: groups.anteriores|merge([n]) }) -%}
                        {%- endif -%}
                    {%- endfor -%}

                    <div class="px-5 sm:px-7 pt-4">
                        <div class="fullpage__tabs" data-page-tabs>
                            <button type="button" class="fullpage__tab active" data-page-filter="all">Todas</button>
                            <button type="button" class="fullpage__tab" data-page-filter="unread">Sin leer <span class="tab-count" data-page-count="unread">{{ unread_filters.unread }}</span></button>
                            <button type="button" class="fullpage__tab" data-page-filter="reserva">Reservas <span class="tab-count" data-page-count="reserva">{{ unread_filters.reserva }}</span></button>
                            <button type="button" class="fullpage__tab" data-page-filter="logro">Logros <span class="tab-count" data-page-count="logro">{{ unread_filters.logro }}</span></button>
                            <button type="button" class="fullpage__tab" data-page-filter="paquetes">Paquetes <span class="tab-count" data-page-count="paquetes">{{ unread_filters.paquetes }}</span></button>
                        </div>

                        <div class="notifications-controls-row">
                            <div class="notifications-controls-row__left">
                                <span class="notifications-toolbar__count" data-notif-toolbar-count></span>
                            </div>
                            <div class="notifications-controls-row__right">
                                <div class="notifications-select-controls">
                                    <button type="button" class="notifications-select-btn" data-select-all>
                                        <i class="bi bi-check2-square btn-icon"></i>
                                        <span class="btn-label">Seleccionar todos</span>
                                    </button>
                                    <button type="button" class="notifications-select-btn" data-select-invert>
                                        <i class="bi bi-arrow-down-up btn-icon"></i>
                                        <span class="btn-label">Seleccion inversa</span>
                                    </button>
                                </div>
                                <div class="notifications-toolbar" data-notif-toolbar>
                                    <button type="button" class="notifications-toolbar__btn" data-bulk-read>
                                        <i class="bi bi-eye btn-icon"></i>
                                        <span class="btn-label">Marcar leidas</span>
                                    </button>
                                    <button type="button" class="notifications-toolbar__btn notifications-toolbar__btn--unread" data-bulk-unread>
                                        <i class="bi bi-eye-slash btn-icon"></i>
                                        <span class="btn-label">Marcar no leidas</span>
                                    </button>
                                    <button type="button" class="notifications-toolbar__btn notifications-toolbar__btn--danger" data-bulk-delete>
                                        <i class="bi bi-trash btn-icon"></i>
                                        <span class="btn-label">Eliminar</span>
                                    </button>
                                    <button type="button" class="notifications-toolbar__btn notifications-toolbar__btn--outline" data-bulk-cancel>
                                        <i class="bi bi-x-circle btn-icon"></i>
                                        <span class="btn-label">Cancelar</span>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <ul class="notifications-page-list pb-4">
                            <li class="pb-empty notifications-filter-empty" data-filter-empty hidden>
                                <span class="pb-empty__icon"><i class="bi bi-bell-slash"></i></span>
                                <span class="pb-empty__text">Sin notificaciones por ahora</span>
                                <span class="pb-empty__sub">Prueba con otro filtro o vuelve a "Todas".</span>
                            </li>
                            {% for label, items in { 'Hoy': groups.hoy, 'Ayer': groups.ayer, 'Esta semana': groups.semana, 'Anteriores': groups.anteriores } %}
                                {% if items is not empty %}
                                    <li class="notifications-page-group-label" data-notif-group-label>{{ label }}</li>
                                    {% for n in items %}
                                        {%- set ntype = (n.type|default('')|lower) -%}
                                        {%- set category = 'sistema' -%}
                                        {%- if ntype starts with 'achievement_' -%}
                                            {%- set category = 'logro' -%}
                                        {%- elseif ntype starts with 'package_'
                                            or ntype starts with 'payment_'
                                            or ntype starts with 'checkout_'
                                            or ntype starts with 'transaction_' -%}
                                            {%- set category = 'paquetes' -%}
                                        {%- elseif ntype starts with 'reservation_'
                                            or ntype starts with 'waiting_list_'
                                            or ntype starts with 'waitlist_'
                                            or ntype starts with 'lista_espera_'
                                            or ntype starts with 'class_'
                                            or ntype starts with 'session_'
                                            or ntype starts with 'rating_' -%}
                                            {%- set category = 'reserva' -%}
                                        {%- endif -%}

                                        <li data-notif-li="{{ n.id }}" data-notif-item data-category="{{ category }}" class="py-0.5">
                                            <div class="notifications-page-item__row">
                                                <input
                                                    type="checkbox"
                                                    class="notifications-page-item__checkbox"
                                                    data-notif-checkbox
                                                    data-id="{{ n.id }}"
                                                    aria-label="Seleccionar notificacion"
                                                >
                                                <button
                                                    type="button"
                                                    class="notifications-page-item{% if n.readAt is null %} is-unread{% else %} is-read{% endif %} is-priority-{{ n.priority }}"
                                                    data-notification-page-item
                                                    data-id="{{ n.id }}"
                                                    data-notification-type="{{ n.type|default('_default') }}"
                                                    data-category="{{ category }}"
                                                    data-is-unread="{% if n.readAt is null %}1{% else %}0{% endif %}"
                                                    data-achievement-icon="{{ n.payload.badge_icon|default('') }}"
                                                    data-mark-read-url="{{ mark_read_url|replace({'__ID__': n.id}) }}"
                                                    data-target-url="{{ target_urls[n.id] ?? '' }}"
                                                >
                                                    <span class="notifications-page-item__type-row">
                                                        <span class="notifications-page-item__icon" data-notification-type-icon>
                                                            <i class="bi bi-bell"></i>
                                                        </span>
                                                    </span>
                                                    <span class="notifications-page-item__header">
                                                        <span class="notifications-page-item__title">{{ n.title }}</span>
                                                        <span class="notifications-page-item__time" data-created-at="{{ n.createdAt|date('c') }}" data-absolute-time="{{ n.createdAt|date('d/m/Y H:i') }}">{{ n.createdAt|date('d/m/Y H:i') }}</span>
                                                    </span>
                                                    <span class="notifications-page-item__body">{{ n.body }}</span>
                                                </button>
                                            </div>
                                        </li>
                                    {% endfor %}
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </div>

                    <div class="sessions-used-history-footer border-t border-linen py-4" data-filter-pagination hidden>
                        <div class="sessions-used-pagination"></div>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    <script>
    (function () {
        var unreadCount  = {{ unread_count|default(0) }};
        var bulkUrl      = '{{ path('api_notifications_bulk') }}';
        var unreadCountUrl = '{{ path('api_notifications_unread_count') }}';
        var pageMarkReadUrlTemplate = '{{ path('api_notifications_mark_read', {'id': '__ID__'}) }}';
        var selectedIds  = new Set();
        var selectionMode = false;

        /* ── Badge y boton "Marcar todas" ─────────────────────────────────── */
        function updateHeaderBadge(count) {
            // Persistir siempre en sessionStorage para que la siguiente página no dispare toasts
            try { sessionStorage.setItem('pb_last_unread_count', String(count)); } catch (e) {}

            var badge = document.querySelector('[data-notification-badge]');
            if (!badge) { return; }
            if (count > 0) {
                badge.textContent = count > 99 ? '99+' : String(count);
                badge.hidden = false;
            } else {
                badge.hidden = true;
            }
            // Sincronizar con NotificationCenter si está activo en la misma página
            if (window.NotificationCenter && null !== NotificationCenter.lastUnreadCount) {
                NotificationCenter.lastUnreadCount = count;
            }
        }

        function updateMarkAllBtn(count) {
            // Boton removido en la pagina central por redundancia con acciones bulk.
        }

        function syncUnreadStorageFromServer(fallbackCount) {
            var fallback = parseInt(fallbackCount, 10);
            if (isNaN(fallback)) { fallback = 0; }

            if (!unreadCountUrl || !window.fetch) {
                updateHeaderBadge(fallback);
                return;
            }

            fetch(unreadCountUrl, { headers: { 'Accept': 'application/json' } })
                .then(function (res) {
                    if (!res.ok) { throw new Error('unread-count-failed'); }
                    return res.json();
                })
                .then(function (payload) {
                    var count = parseInt(payload && payload.count, 10);
                    if (isNaN(count)) { count = fallback; }
                    unreadCount = count;
                    updateHeaderBadge(count);
                })
                .catch(function () {
                    updateHeaderBadge(fallback);
                });
        }

        function markNotificationsAsSeen(ids) {
            if (!Array.isArray(ids) || ids.length === 0) {
                return;
            }

            try {
                var key = 'pb_polled_toast_registry_v1';
                var raw = sessionStorage.getItem(key);
                var registry = raw ? JSON.parse(raw) : {};
                if (!registry || typeof registry !== 'object') {
                    registry = {};
                }

                var now = Date.now();
                ids.forEach(function (id) {
                    if (id === null || typeof id === 'undefined') { return; }
                    registry[String(id)] = now;
                });

                sessionStorage.setItem(key, JSON.stringify(registry));
            } catch (e) {}
        }

        /* ── Toolbar ───────────────────────────────────────────────────────── */
        var toolbar        = document.querySelector('[data-notif-toolbar]');
        var toolbarCount   = document.querySelector('[data-notif-toolbar-count]');
        var controlsLeft   = document.querySelector('.notifications-controls-row__left');
        var pageList       = document.querySelector('.notifications-page-list');
        var pageTabs       = document.querySelectorAll('[data-page-filter]');
        var filterEmpty    = document.querySelector('[data-filter-empty]');
        var selectControls = document.querySelector('.notifications-select-controls');
        var btnRead        = document.querySelector('[data-bulk-read]');
        var btnUnread      = document.querySelector('[data-bulk-unread]');
        var btnDelete      = document.querySelector('[data-bulk-delete]');
        var btnCancel      = document.querySelector('[data-bulk-cancel]');
        var activePageFilter = 'all';
        var currentFilterPage = 1;
        var FILTER_PAGE_SIZE = 20;
        var filterPaginationWrap = document.querySelector('[data-filter-pagination]');
        var itemLabelMap = new WeakMap();

        function getAllFilterItems() {
            return Array.from(document.querySelectorAll('[data-notif-item]'));
        }

        function rebuildItemLabelMap() {
            itemLabelMap = new WeakMap();
            if (!pageList) { return; }

            var currentLabel = null;
            Array.from(pageList.children).forEach(function (node) {
                if (!node || !node.hasAttribute) { return; }

                if (node.hasAttribute('data-notif-group-label')) {
                    currentLabel = node;
                    return;
                }

                if (node.hasAttribute('data-notif-item')) {
                    itemLabelMap.set(node, currentLabel);
                }
            });
        }

        function matchesFilter(btn) {
            if (!btn) { return false; }
            if (activePageFilter === 'all') { return true; }
            if (activePageFilter === 'unread') {
                return (btn.dataset.isUnread || (btn.classList.contains('is-unread') ? '1' : '0')) === '1';
            }
            return (btn.dataset.category || 'sistema') === activePageFilter;
        }

        function hydrateNotificationButtonDataset(btn, node) {
            if (!btn) { return; }

            var li = node || btn.closest('[data-notif-item]');
            var liId = li ? li.getAttribute('data-notif-li') : '';
            var liCategory = li ? (li.getAttribute('data-category') || '') : '';

            if (!btn.dataset.id && liId) {
                btn.dataset.id = String(liId);
            }

            if (!btn.dataset.category && liCategory) {
                btn.dataset.category = liCategory;
            }

            if (btn.dataset.isUnread !== '0' && btn.dataset.isUnread !== '1') {
                btn.dataset.isUnread = btn.classList.contains('is-unread') ? '1' : '0';
            }

            if (!btn.dataset.markReadUrl && btn.dataset.id) {
                btn.dataset.markReadUrl = pageMarkReadUrlTemplate.replace('__ID__', String(btn.dataset.id));
            }
        }

        function renderFilterPagination(totalPages, page) {
            if (!filterPaginationWrap) { return; }
            var slot = filterPaginationWrap.querySelector('.sessions-used-pagination');
            if (!slot) { return; }

            if (totalPages <= 1) {
                slot.innerHTML = '';
                filterPaginationWrap.hidden = true;
                return;
            }

            var winStart = Math.max(1, page - 2);
            var winEnd = Math.min(totalPages, page + 2);
            var html = '<ul class="pagination" data-filter-pagination-nav>';
            html += '<li class="' + (page <= 1 ? 'disabled' : '') + '"><a href="#" data-filter-page="' + (page - 1) + '">&laquo;</a></li>';

            if (winStart > 1) {
                html += '<li><a href="#" data-filter-page="1">1</a></li>';
                if (winStart > 2) { html += '<li class="pagination-ellipsis"><span>...</span></li>'; }
            }

            for (var p = winStart; p <= winEnd; p++) {
                html += '<li class="' + (p === page ? 'active' : '') + '"><a href="#" data-filter-page="' + p + '">' + p + '</a></li>';
            }

            if (winEnd < totalPages) {
                if (winEnd < totalPages - 1) { html += '<li class="pagination-ellipsis"><span>...</span></li>'; }
                html += '<li><a href="#" data-filter-page="' + totalPages + '">' + totalPages + '</a></li>';
            }

            html += '<li class="' + (page >= totalPages ? 'disabled' : '') + '"><a href="#" data-filter-page="' + (page + 1) + '">&raquo;</a></li>';
            html += '</ul>';
            slot.innerHTML = html;
            filterPaginationWrap.hidden = false;
        }

        function bindTabsRowDrag() {
            var tabsRow = document.querySelector('.fullpage__tabs');
            if (!tabsRow) { return; }

            var dragging = false;
            var startX = 0;
            var startScrollLeft = 0;

            tabsRow.addEventListener('pointerdown', function (event) {
                if ('mouse' === event.pointerType && 0 !== event.button) {
                    return;
                }

                dragging = true;
                startX = event.clientX;
                startScrollLeft = tabsRow.scrollLeft;
                tabsRow.classList.add('is-dragging');
            });

            tabsRow.addEventListener('pointermove', function (event) {
                if (!dragging) { return; }
                var dx = event.clientX - startX;
                tabsRow.scrollLeft = startScrollLeft - dx;
            });

            var stopDragging = function () {
                dragging = false;
                tabsRow.classList.remove('is-dragging');
            };

            tabsRow.addEventListener('pointerup', stopDragging);
            tabsRow.addEventListener('pointercancel', stopDragging);
            tabsRow.addEventListener('pointerleave', stopDragging);

            tabsRow.addEventListener('wheel', function (event) {
                if (Math.abs(event.deltaY) > Math.abs(event.deltaX)) {
                    tabsRow.scrollLeft += event.deltaY;
                    event.preventDefault();
                }
            }, { passive: false });
        }

        function formatRelativeTime(createdAtIso, absoluteText) {
            if (!createdAtIso) { return absoluteText || ''; }

            var createdAt = new Date(createdAtIso);
            if (isNaN(createdAt.getTime())) { return absoluteText || ''; }

            var now = new Date();
            var diffMs = now.getTime() - createdAt.getTime();
            if (diffMs >= 0 && diffMs < 86400000) {
                var totalMinutes = Math.floor(diffMs / 60000);
                if (totalMinutes < 1) { return '<1m'; }
                if (totalMinutes < 60) { return totalMinutes + 'm'; }
                return Math.floor(totalMinutes / 60) + 'h';
            }

            return absoluteText || '';
        }

        function updateRelativeTimes() {
            document.querySelectorAll('.notifications-page-item__time[data-created-at]').forEach(function (el) {
                var createdAtIso = el.getAttribute('data-created-at');
                var absoluteText = el.getAttribute('data-absolute-time') || el.textContent;
                el.textContent = formatRelativeTime(createdAtIso, absoluteText);
            });
        }

        function normalizeType(type) {
            var key = String(type || '').toLowerCase().trim();
            var aliases = {
                reserva_confirmada: 'reservation_confirmed',
                reserva_modificada: 'reservation_changed',
                reserva_cancelada: 'reservation_cancelled',
                lista_espera_entrada: 'waiting_list_confirmed',
                lista_espera_salida: 'waiting_list_removed',
                lista_espera_turno: 'waiting_list_denied',
                pago_confirmado: 'payment_confirmed',
            };

            if (!key) {
                return '_default';
            }

            return aliases[key] || key;
        }

        function getTypeConfig(type) {
            var map = window.PB_NOTIFICATION_TYPE_CONFIG || {};
            var key = normalizeType(type);
            return map[key] || map._default || {
                icon: 'bi-bell',
                label: 'Notificacion',
                barColor: '#9E9E9E',
                iconColor: '#9E9E9E',
                backgroundColor: '#FFFFFF',
                titleColor: '#2C2C2C',
                textColor: '#555555',
            };
        }

        function hasThemeConfigLoaded() {
            var map = window.PB_NOTIFICATION_TYPE_CONFIG;
            return !!(map && typeof map === 'object' && Object.keys(map).length > 0);
        }

        function applyTypeThemeWhenReady(attempt) {
            var currentAttempt = Number(attempt || 0);

            if (hasThemeConfigLoaded()) {
                applyTypeThemeToPageItems();
                return;
            }

            if (currentAttempt >= 12) {
                // Evita bucles infinitos: aplica fallback si la config no estuvo disponible.
                applyTypeThemeToPageItems();
                return;
            }

            setTimeout(function () {
                applyTypeThemeWhenReady(currentAttempt + 1);
            }, 120);
        }

        function softenHexColor(hex, mixWithWhiteRatio) {
            var fallback = '#FFFFFF';
            var value = String(hex || '').trim();
            if (!/^#[0-9a-fA-F]{6}$/.test(value)) {
                return fallback;
            }

            var ratio = Number(mixWithWhiteRatio);
            if (isNaN(ratio)) { ratio = 0.86; }
            ratio = Math.max(0, Math.min(0.95, ratio));

            var r = parseInt(value.slice(1, 3), 16);
            var g = parseInt(value.slice(3, 5), 16);
            var b = parseInt(value.slice(5, 7), 16);

            var mix = function (channel) {
                return Math.round(channel + (255 - channel) * ratio);
            };

            return 'rgb(' + mix(r) + ', ' + mix(g) + ', ' + mix(b) + ')';
        }

        function getUnreadBackgroundColor(cfg) {
            var source = (cfg && (cfg.barColor || cfg.iconColor || cfg.backgroundColor)) || '#C17A6A';

            if (!/^#[0-9a-fA-F]{6}$/.test(String(source || '').trim())) {
                source = '#C17A6A';
            }

            // Tinte suave para mantener contraste sin oscurecer.
            return softenHexColor(source, 0.88);
        }

        function applyTypeThemeToPageItems() {
            document.querySelectorAll('[data-notification-page-item]').forEach(function (btn) {
                var type = btn.dataset.notificationType || '_default';
                var cfg = getTypeConfig(type);
                var isSelected = btn.classList.contains('is-selected');

                var iconWrap = btn.querySelector('[data-notification-type-icon]');
                var title = btn.querySelector('.notifications-page-item__title');
                var body = btn.querySelector('.notifications-page-item__body');
                var accent = (cfg && (cfg.barColor || cfg.iconColor || cfg.backgroundColor)) || '#C17A6A';

                btn.style.borderLeftColor = cfg.barColor || '#9E9E9E';
                if (isSelected) {
                    btn.style.backgroundColor = softenHexColor(accent, 0.76);
                    btn.style.boxShadow = '0 0 0 1px ' + softenHexColor(accent, 0.58);
                } else if (btn.dataset.isUnread === '1') {
                    btn.style.backgroundColor = getUnreadBackgroundColor(cfg);
                    btn.style.boxShadow = '';
                } else {
                    btn.style.backgroundColor = '#FFFFFF';
                    btn.style.boxShadow = '';
                }

                if (iconWrap) {
                    iconWrap.style.backgroundColor = cfg.backgroundColor || '#FFFFFF';
                    iconWrap.style.color = cfg.iconColor || '#9E9E9E';
                    iconWrap.style.borderColor = cfg.barColor || '#9E9E9E';
                    var achievementIcon = (btn.dataset.achievementIcon || '').trim();
                    var isAchievement = String(type || '').toLowerCase().indexOf('achievement_') === 0;

                    if (isAchievement && achievementIcon) {
                        iconWrap.textContent = achievementIcon;
                    } else {
                        var iconEl = iconWrap.querySelector('i');
                        if (!iconEl) {
                            iconWrap.innerHTML = '<i class="bi"></i>';
                            iconEl = iconWrap.querySelector('i');
                        }
                        if (iconEl) {
                            iconEl.className = 'bi ' + (cfg.icon || 'bi-bell');
                        }
                    }
                }

                if (title) {
                    title.style.color = cfg.titleColor || '#2C2C2C';
                }

                if (body) {
                    body.style.color = cfg.textColor || '#555555';
                }
            });
        }

        function updatePageFilterBadges() {
            var counters = { unread: 0, reserva: 0, logro: 0, paquetes: 0 };
            document.querySelectorAll('[data-notif-item]').forEach(function (node) {
                var btn = node.querySelector('[data-notification-page-item]');
                if (!btn) { return; }

                hydrateNotificationButtonDataset(btn, node);
                if (btn.dataset.isUnread !== '1') { return; }
                counters.unread++;
                var category = btn.dataset.category || 'sistema';
                if (counters[category] !== undefined) {
                    counters[category]++;
                }
            });

            document.querySelectorAll('[data-page-count]').forEach(function (badge) {
                var key = badge.getAttribute('data-page-count');
                var value = counters[key] || 0;
                badge.textContent = value > 99 ? '99+' : String(value);
            });
        }

        function applyPageFilter() {
            if (!pageList) { return; }

            var allItems = getAllFilterItems();
            var labels = Array.from(pageList.querySelectorAll('[data-notif-group-label]'));

            labels.forEach(function (label) { label.style.display = 'none'; });

            var filtered = allItems.filter(function (node) {
                var btn = node.querySelector('[data-notification-page-item]');
                hydrateNotificationButtonDataset(btn, node);
                return !!btn && matchesFilter(btn);
            });

            var totalPages = Math.max(1, Math.ceil(filtered.length / FILTER_PAGE_SIZE));
            if (currentFilterPage > totalPages) { currentFilterPage = totalPages; }
            if (currentFilterPage < 1) { currentFilterPage = 1; }

            allItems.forEach(function (node) { node.style.display = 'none'; });

            var start = (currentFilterPage - 1) * FILTER_PAGE_SIZE;
            var visibleItems = filtered.slice(start, start + FILTER_PAGE_SIZE);
            var shownLabels = new Set();
            visibleItems.forEach(function (node) {
                node.style.display = '';
                var label = itemLabelMap.get(node);
                if (label && !shownLabels.has(label)) {
                    label.style.display = '';
                    shownLabels.add(label);
                }
            });

            if (filterEmpty) { filterEmpty.hidden = filtered.length > 0; }
            renderFilterPagination(totalPages, currentFilterPage);
            keepOnlyVisibleSelection();
        }

        if (filterPaginationWrap) {
            filterPaginationWrap.addEventListener('click', function (event) {
                var link = event.target.closest('[data-filter-page]');
                if (!link) { return; }
                event.preventDefault();

                var nextPage = parseInt(link.getAttribute('data-filter-page'), 10);
                if (!isNaN(nextPage) && nextPage > 0) {
                    currentFilterPage = nextPage;
                    applyPageFilter();
                }
            });
        }

        function setBulkButtonsState(enabled) {
            [btnRead, btnUnread, btnDelete, btnCancel].forEach(function (btn) {
                if (!btn) { return; }
                btn.disabled = !enabled;
            });
        }

        function updateToolbar() {
            var n = selectedIds.size;
            if (n > 0) {
                toolbarCount.textContent = n + (n === 1 ? ' seleccionada' : ' seleccionadas');
                if (controlsLeft) { controlsLeft.classList.add('show-count'); }
                setBulkButtonsState(true);
            } else {
                toolbarCount.textContent = '';
                if (controlsLeft) { controlsLeft.classList.remove('show-count'); }
                setBulkButtonsState(false);
                if (selectionMode) { exitSelectionMode(); }
            }
        }

        /* ── Modo seleccion ─────────────────────────────────────────────────── */
        function showSelectionUI() {
            if (pageList)       { pageList.classList.add('is-selection-mode'); }
        }

        function hideSelectionUI() {
            if (pageList)       { pageList.classList.remove('is-selection-mode'); }
        }

        function enterSelectionMode(id) {
            selectionMode = true;
            showSelectionUI();
            if (id) {
                var cb = document.querySelector('[data-notif-checkbox][data-id="' + id + '"]');
                if (cb) { setCheckbox(cb, true); }
            }
            updateToolbar();
        }

        function exitSelectionMode() {
            selectionMode = false;
            hideSelectionUI();
            document.querySelectorAll('[data-notif-checkbox]').forEach(function (cb) {
                setCheckbox(cb, false, { deferRepaint: true });
            });
            selectedIds.clear();
            applyTypeThemeToPageItems();
            if (toolbarCount) { toolbarCount.textContent = ''; }
            if (controlsLeft) { controlsLeft.classList.remove('show-count'); }
        }

        /* ── Seleccion individual ──────────────────────────────────────────── */
        function setCheckbox(cb, checked, options) {
            var opts = options || {};
            var id  = parseInt(cb.dataset.id, 10);
            var li  = document.querySelector('[data-notif-li="' + id + '"]');
            var btn = li ? li.querySelector('[data-notification-page-item]') : null;
            cb.checked = checked;
            if (checked) {
                selectedIds.add(id);
                if (btn) { btn.classList.add('is-selected'); }
            } else {
                selectedIds.delete(id);
                if (btn) { btn.classList.remove('is-selected'); }
            }

            if (!opts.deferRepaint) {
                applyTypeThemeToPageItems();
            }
        }

        function getVisiblePageCheckboxes() {
            return Array.from(document.querySelectorAll('[data-notif-item]')).reduce(function (acc, li) {
                if (li.style.display === 'none') { return acc; }

                var cb = li.querySelector('[data-notif-checkbox]');
                if (cb) { acc.push(cb); }
                return acc;
            }, []);
        }

        function keepOnlyVisibleSelection() {
            var visibleIds = new Set(getVisiblePageCheckboxes().map(function (cb) {
                return parseInt(cb.dataset.id, 10);
            }));
            var changed = false;

            selectedIds.forEach(function (id) {
                if (!visibleIds.has(id)) {
                    var cb = document.querySelector('[data-notif-checkbox][data-id="' + id + '"]');
                    if (cb) {
                        setCheckbox(cb, false, { deferRepaint: true });
                        changed = true;
                    }
                }
            });

            if (changed) {
                applyTypeThemeToPageItems();
            }
            updateToolbar();
        }

        document.querySelectorAll('[data-notif-checkbox]').forEach(function (cb) {
            cb.addEventListener('change', function () {
                setCheckbox(cb, cb.checked);
                updateToolbar();
            });
        });

        /* ── Seleccionar todos / inverso ───────────────────────────────────── */
        var btnSelectAll    = document.querySelector('[data-select-all]');
        var btnSelectInvert = document.querySelector('[data-select-invert]');

        if (btnSelectAll) {
            btnSelectAll.addEventListener('click', function () {
                getVisiblePageCheckboxes().forEach(function (cb) {
                    setCheckbox(cb, true, { deferRepaint: true });
                });
                applyTypeThemeToPageItems();
                updateToolbar();
            });
        }

        if (btnSelectInvert) {
            btnSelectInvert.addEventListener('click', function () {
                getVisiblePageCheckboxes().forEach(function (cb) {
                    setCheckbox(cb, !cb.checked, { deferRepaint: true });
                });
                applyTypeThemeToPageItems();
                updateToolbar();
            });
        }

        /* ── Cancelar seleccion ────────────────────────────────────────────── */
        function clearSelection() {
            document.querySelectorAll('[data-notif-checkbox]').forEach(function (cb) {
                setCheckbox(cb, false, { deferRepaint: true });
            });
            selectedIds.clear();
            applyTypeThemeToPageItems();
            updateToolbar();
        }

        if (btnCancel) { btnCancel.addEventListener('click', exitSelectionMode); }

        /* ── Accion bulk ───────────────────────────────────────────────────── */
        function applyBulkResult(action, ids) {
            ids.forEach(function (id) {
                var li  = document.querySelector('[data-notif-li="' + id + '"]');
                var btn = li ? li.querySelector('[data-notification-page-item]') : null;
                if (!btn && !li) { return; }

                if (action === 'delete') {
                    if (li) {
                        var deletedBtn = li.querySelector('[data-notification-page-item]');
                        if (deletedBtn && deletedBtn.dataset.isUnread === '1') {
                            unreadCount = Math.max(0, unreadCount - 1);
                        }
                        li.remove();
                    }
                    return;
                }

                if (!btn) { return; }

                if (action === 'read') {
                    if (btn.classList.contains('is-unread')) {
                        btn.classList.remove('is-unread');
                        btn.classList.add('is-read');
                        btn.dataset.isUnread = '0';
                        unreadCount = Math.max(0, unreadCount - 1);
                    }
                } else if (action === 'unread') {
                    if (btn.classList.contains('is-read') || !btn.classList.contains('is-unread')) {
                        btn.classList.remove('is-read');
                        btn.classList.add('is-unread');
                        btn.dataset.isUnread = '1';
                        unreadCount++;
                    }
                }
            });

            updateHeaderBadge(unreadCount);
            updateMarkAllBtn(unreadCount);
            updatePageFilterBadges();
            applyPageFilter();
            applyTypeThemeToPageItems();

            if (action === 'read' || action === 'delete') {
                markNotificationsAsSeen(ids);
            }

            syncUnreadStorageFromServer(unreadCount);

            if (action === 'delete') {
                var count = ids.length;
                var remaining = document.querySelectorAll('[data-notif-li]').length;
                var msg = count === 1 ? 'Notificación eliminada.' : count + ' notificaciones eliminadas.';
                if (window.PBNotify) {
                    PBNotify.toast(msg, 'success');
                }
                if (remaining === 0) {
                    setTimeout(function () { window.location.reload(); }, 1800);
                    return;
                }
            }

            clearSelection();
        }

        function doBulk(action) {
            if (selectedIds.size === 0) { return; }
            var ids = Array.from(selectedIds);

            fetch(bulkUrl, {
                method: 'POST',
                headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
                body: JSON.stringify({ ids: ids, action: action }),
            }).then(function (res) {
                if (res.ok) { applyBulkResult(action, ids); }
            }).catch(function () {});
        }

        pageTabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                activePageFilter = tab.getAttribute('data-page-filter') || 'all';
                currentFilterPage = 1;
                pageTabs.forEach(function (item) { item.classList.remove('active'); });
                tab.classList.add('active');
                applyPageFilter();
            });
        });

        if (btnRead)   { btnRead.addEventListener('click',   function () { doBulk('read'); }); }
        if (btnUnread) { btnUnread.addEventListener('click', function () { doBulk('unread'); }); }
        if (btnDelete) {
            btnDelete.addEventListener('click', function () {
                doBulk('delete');
            });
        }

        updateToolbar();
        rebuildItemLabelMap();

        /* ── Interaccion individual: long press = seleccion, click = accion ── */
        document.querySelectorAll('[data-notification-page-item]').forEach(function (btn) {
            hydrateNotificationButtonDataset(btn);

            var pressTimer     = null;
            var pressStartX    = 0;
            var pressStartY    = 0;
            var pressMoved     = false;
            var pressActivated = false;

            function startPress(e) {
                pressStartX    = e.clientX;
                pressStartY    = e.clientY;
                pressMoved     = false;
                pressActivated = false;
                btn.classList.add('is-pressing');
                pressTimer = setTimeout(function () {
                    pressTimer = null;
                    btn.classList.remove('is-pressing');
                    if (pressMoved) { return; }
                    pressActivated = true;
                    if (navigator.vibrate) { navigator.vibrate(30); }
                    enterSelectionMode(parseInt(btn.dataset.id, 10));
                }, 400);
            }

            function movePress(e) {
                if (Math.abs(e.clientX - pressStartX) > 10 || Math.abs(e.clientY - pressStartY) > 10) {
                    pressMoved = true;
                    cancelPress();
                }
            }

            function cancelPress() {
                if (pressTimer) { clearTimeout(pressTimer); pressTimer = null; }
                btn.classList.remove('is-pressing');
            }

            btn.addEventListener('pointerdown',   startPress);
            btn.addEventListener('pointermove',   movePress);
            btn.addEventListener('pointerup',     cancelPress);
            btn.addEventListener('pointercancel', cancelPress);
            btn.addEventListener('pointerleave',  cancelPress);

            btn.addEventListener('click', function (e) {
                e.stopPropagation();

                // Absorber el click que sigue inmediatamente a un long press
                if (pressActivated) { pressActivated = false; return; }

                if (selectionMode) {
                    // En modo seleccion: alternar seleccion del item, sin marcar leido ni navegar
                    var cb = document.querySelector('[data-notif-checkbox][data-id="' + btn.dataset.id + '"]');
                    if (cb) { setCheckbox(cb, !cb.checked); updateToolbar(); }
                    return;
                }

                // Modo normal: marcar leida y navegar
                hydrateNotificationButtonDataset(btn);

                var id        = btn.dataset.id || '';
                var markUrl   = btn.dataset.markReadUrl;
                var targetUrl = btn.dataset.targetUrl || null;

                if (!id) {
                    var li = btn.closest('[data-notif-item]');
                    id = li ? (li.getAttribute('data-notif-li') || '') : '';
                    if (id) {
                        btn.dataset.id = String(id);
                    }
                }

                if (!markUrl && id) {
                    markUrl = pageMarkReadUrlTemplate.replace('__ID__', String(id));
                    btn.dataset.markReadUrl = markUrl;
                }

                if (!id) { return; }

                if (btn.dataset.isUnread !== '1') {
                    if (targetUrl) { window.location.href = targetUrl; }
                    return;
                }

                fetch(markUrl, {
                    method: 'PATCH',
                    headers: { 'Accept': 'application/json' },
                }).then(function (res) {
                    if (res.ok) {
                        btn.classList.remove('is-unread');
                        btn.classList.add('is-read');
                        btn.dataset.isUnread = '0';
                        var titleEl = btn.querySelector('.notifications-page-item__title');
                        if (titleEl) { titleEl.style.fontWeight = '400'; }
                        unreadCount = Math.max(0, unreadCount - 1);
                        updateHeaderBadge(unreadCount);
                        markNotificationsAsSeen([id]);
                        syncUnreadStorageFromServer(unreadCount);
                        updateMarkAllBtn(unreadCount);
                        updatePageFilterBadges();
                        applyPageFilter();
                        applyTypeThemeToPageItems();
                    }
                    if (targetUrl) { window.location.href = targetUrl; }
                }).catch(function () {
                    if (targetUrl) { window.location.href = targetUrl; }
                });
            });
        });

        updateRelativeTimes();
        applyTypeThemeWhenReady(0);
        updatePageFilterBadges();
        applyPageFilter();
        bindTabsRowDrag();

        document.addEventListener('DOMContentLoaded', function () {
            applyTypeThemeWhenReady(0);
        });
    }());
    </script>
{% endblock %}
